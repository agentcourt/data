0ef50e84e","mime_type":"text/plain","original_name":"submitted-evidence-01-plaintiff-0ed0ef50e84e.txt","record_visibility":"juror_visible","relevance":"Official court source for public release/unsealing. It proves the court granted access to the note and identifies it as a suicide note purportedly authored by Jeffrey Epstein, recovered by Tartaglione, and submitted by Tartaglione attorneys; it also shows the order was about public access, not authenticity.","retrieval_timestamp":"2026-06-30T04:33:49Z","sha256":"0ed0ef50e84e5f90a63aeefcb840f628038958b10acf229c44b4babea0c133e9","size_bytes":2992,"source_description":"Official U.S. District Court for the Southern District of New York PDF, Case No. 16-CR-832 (KMK), order dated May 6, 2026; retrieved/rendered for relevant text extraction during this AAR run. Local PDF download succeeded at /aar-codex/sources-20260630-args/sdny-tartaglione-order-2026-05-06.pdf, 128,992 bytes, sha256 7225441cb802084e2b9485ebc2c6d246fbfa08e109fe650cb14f445dc4745ca0; local pdftotext was unavailable.","source_url":"https://www.nysd.uscourts.gov/sites/default/files/2026-05/16cr832%20-%20Tartaglione%20Order%20-%2026.5.6.pdf","storage_name":"0e/0ed0ef50e84e5f90a63aeefcb840f628038958b10acf229c44b4babea0c133e9","submitted_by_role":"plaintiff","submitted_phase":"arguments","text_readable":true,"title":"SDNY May 6, 2026 Tartaglione unsealing order - relevant extracted text"},{"admissibility_status":"case_packet","created_at":"2026-06-30T04:24:14Z","evidence_id":"ev_2680dc66be4e_unresolved-record-gaps","mime_type":"text/plain","original_name":"unresolved-record-gaps.txt","record_visibility":"juror_visible","sha256":"2680dc66be4e96f951c4c1bd1a178f89bec88340092c670e8895658ea128ba22","size_bytes":976,"source_description":"Initial case packet file","storage_name":"26/2680dc66be4e96f951c4c1bd1a178f89bec88340092c670e8895658ea128ba22","submitted_by_role":"system","submitted_phase":"case_packet","text_readable":true,"title":"unresolved-record-gaps.txt"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-30T04:35:36Z","evidence_id":"ev_58561d19c453_submitted-evidence-04-plaintiff-58561d19c453","mime_type":"text/plain","original_name":"submitted-evidence-04-plaintiff-58561d19c453.txt","record_visibility":"juror_visible","relevance":"Near-primary image-caption record from Reuters/SDNY handout. It directly describes the publicly released document image, includes the key goodbye line, dates the release to May 6, 2026, and identifies the source as U.S. District Court for the Southern District of New York/Handout via Reuters.","retrieval_timestamp":"2026-06-30T04:35:30Z","sha256":"58561d19c4537e7f3ade428fefe955b34c55ca688a331faa72187770ee5c8716","size_bytes":1360,"source_description":"Reuters Connect licensable picture page for image USN RC2T3LAL0C66, byline U.S. District Court/SDNY, retrieved/rendered during this AAR run.","source_url":"https://www.reutersconnect.com/item/document-described-as-a-suicide-note-purportedly-written-by-the-late-jeffrey-epstein/dGFnOnJldXRlcnMuY29tLDIwMjY6bmV3c21sX1JDMlQzTEFMMEM2Ng","storage_name":"58/58561d19c4537e7f3ade428fefe955b34c55ca688a331faa72187770ee5c8716","submitted_by_role":"plaintiff","submitted_phase":"arguments","text_readable":true,"title":"Reuters Connect May 6, 2026 image-caption record for Epstein note"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-30T04:38:13Z","evidence_id":"ev_5aa56aab2530_submitted-evidence-05-defendant-5aa56aab2530","mime_type":"text/plain","original_name":"submitted-evidence-05-defendant-5aa56aab2530.txt","record_visibility":"juror_visible","relevance":"Defense evidence on provenance, custody, and authentication. It reports DOJ's explanation that it never had the note, that the note had not yet been authenticated, that the note came through an unrelated Tartaglione attorney-client dispute, that it was in a court vault since 2021, and that DOJ lawyers involved in sealed proceedings could not disclose anything due to privilege restrictions.","retrieval_timestamp":"2026-06-30T04:39:50Z","sha256":"5aa56aab25302158d1be6b80426ed4d517ee436cea958297c34e648148db2bca","size_bytes":2780,"source_description":"Associated Press article by Ed White, retrieved via AP News page during defendant arguments; relevant text extraction from public article page.","source_url":"https://apnews.com/article/jeffrey-epstein-suicide-note-5297f49736e625a06d0db3c7b737b997","storage_name":"5a/5aa56aab25302158d1be6b80426ed4d517ee436cea958297c34e648148db2bca","submitted_by_role":"defendant","submitted_phase":"arguments","text_readable":true,"title":"AP May 7, 2026 report: DOJ seeing Epstein note for first time and authentication limits"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-30T04:34:52Z","evidence_id":"ev_757899113d89_submitted-evidence-02-plaintiff-757899113d89","mime_type":"text/plain","original_name":"submitted-evidence-02-plaintiff-757899113d89.txt","record_visibility":"juror_visible","relevance":"Corroborates that the note was publicly reported before May 8, 2026; identifies Judge Karas release, NYT petition, Tartaglione discovery claim, note language supporting final-message intent, and adverse uncertainty about authorship and government-report omissions.","retrieval_timestamp":"2026-06-30T04:30:00Z","sha256":"757899113d8967676e74909d141f7d97d4735bd8d75a4af34fb3950b18d871e1","size_bytes":2552,"source_description":"PBS NewsHour page carrying Associated Press reporting by Michael R. Sisak and Larry Neumeister, published May 6, 2026 and updated May 7, 2026; retrieved/rendered during this AAR run.","source_url":"https://www.pbs.org/newshour/nation/judge-releases-note-that-cellmate-says-he-found-after-epsteins-suspected-suicide-attempt","storage_name":"75/757899113d8967676e74909d141f7d97d4735bd8d75a4af34fb3950b18d871e1","submitted_by_role":"plaintiff","submitted_phase":"arguments","text_readable":true,"title":"PBS/AP May 6-7, 2026 report on Epstein note release - relevant extracted t