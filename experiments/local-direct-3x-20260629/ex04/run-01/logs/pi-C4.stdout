{"aar_log_filter":{"content_index":0,"dropped_prefix_bytes":293,"field":"text","message":"earlier repeated message_update events dropped","replaced_fields":2,"response_id":"gen-1782773909-XOIkivnldas39v4g2TV8","tail_bytes":1},"assistantMessageEvent":{"contentIndex":0,"delta":".","partial":{"api":"openai-completions","content":[{"text":".","type":"text"}],"model":"openai/gpt-oss-120b","provider":"openrouter","responseId":"gen-1782773909-XOIkivnldas39v4g2TV8","role":"assistant","stopReason":"stop","timestamp":1782773909430,"usage":{"cacheRead":0,"cacheWrite":0,"cost":{"cacheRead":0,"cacheWrite":0,"input":0,"output":0,"total":0},"input":0,"output":0,"totalTokens":0}},"type":"text_delta"},"message":{"api":"openai-completions","content":[{"text":".","type":"text"}],"model":"openai/gpt-oss-120b","provider":"openrouter","responseId":"gen-1782773909-XOIkivnldas39v4g2TV8","role":"assistant","stopReason":"stop","timestamp":1782773909430,"usage":{"cacheRead":0,"cacheWrite":0,"cost":{"cacheRead":0,"cacheWrite":0,"input":0,"output":0,"total":0},"input":0,"output":0,"totalTokens":0}},"type":"message_update"}
{"aar_log_filter":{"content_index":0,"dropped_prefix_bytes":294,"field":"text","message":"earlier repeated message_update events dropped","replaced_fields":2,"response_id":"gen-1782773909-XOIkivnldas39v4g2TV8","tail_bytes":0},"assistantMessageEvent":{"content":"My vote was accepted. I voted **demonstrated** with the rationale that the admitted evidence shows Israeli forces entered Syrian territory, captured Mount Hermon, and officials indicated they would remain there until a security arrangement—meeting the market’s offensive control criteria.","contentIndex":0,"partial":{"api":"openai-completions","content":[{"text":"","type":"text"}],"model":"openai/gpt-oss-120b","provider":"openrouter","responseId":"gen-1782773909-XOIkivnldas39v4g2TV8","role":"assistant","stopReason":"stop","timestamp":1782773909430,"usage":{"cacheRead":32,"cacheWrite":0,"cost":{"cacheRead":0,"cacheWrite":0,"input":0,"output":0,"total":0},"input":14115,"output":56,"totalTokens":14203}},"type":"text_end"},"message":{"api":"openai-completions","content":[{"text":"","type":"text"}],"model":"openai/gpt-oss-120b","provider":"openrouter","responseId":"gen-1782773909-XOIkivnldas39v4g2TV8","role":"assistant","stopReason":"stop","timestamp":1782773909430,"usage":{"cacheRead":32,"cacheWrite":0,"cost":{"cacheRead":0,"cacheWrite":0,"input":0,"output":0,"total":0},"input":14115,"output":56,"totalTokens":14203}},"type":"message_update"}
