":"openings","type":"run_initialized","payload":{"attorneys":[{"role":"plaintiff","interface":"lawyerapi"},{"role":"defendant","interface":"lawyerapi"}],"complaint":{"Proposition":"Israel invaded Syria in 2024.  In particular, Israel commenced a\nmilitary offensive intended to establish control over any portion of\nSyria between September 12, 2024 and December 31, 2024, 11:59 PM\nET. For the purposes of this market, the Golan Heights count as\nIsraeli territory.  The authorities for this proposition are official\nconfirmation by Syria, Israel, the United Nations, or any permanent\nmember of the UN Security Council, however a consensus of credible\nreporting will also be used."},"council":[{"member_id":"C1","model":"openrouter://nvidia/nemotron-3-super-120b-a12b","persona_file":"personas/generic.md","request_spec":{"endpoint":"openrouter","model":"nvidia/nemotron-3-super-120b-a12b","provider":{"only":["digitalocean"],"allow_fallbacks":false,"require_parameters":true},"request":{},"headers":{"X-OpenRouter-Experimental-Metadata":"enabled"},"persona":"personas/generic.md","variant_metadata":{"endpoint_tag":"digitalocean","endpoint_variant_id":"77172d5f0d6c398057da7cb3","equivalence_class_size":1,"equivalence_key":{"canonical_slug":"nvidia/nemotron-3-super-120b-a12b-20230311","endpoint_model_id":"nvidia/nemotron-3-super-120b-a12b","hugging_face_id":"nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-FP8","input_modalities":["text"],"openrouter_model_id":"nvidia/nemotron-3-super-120b-a12b","output_modalities":["text"],"quantization":"unknown"},"equivalent_endpoints":[{"canonical_slug":"nvidia/nemotron-3-super-120b-a12b-20230311","clusters":[2,3,3,4],"context_length":1000000,"context_limit_error_count":null,"deliberation_score":null,"endpoint_name":"DigitalOcean | nvidia/nemotron-3-super-120b-a12b-20230311","endpoint_tag":"digitalocean","endpoint_variant_id":"77172d5f0d6c398057da7cb3","filter_deliberation_score":1.0,"filter_provider_error_count":0,"hugging_face_id":"nvidia/NVIDIA-Ne