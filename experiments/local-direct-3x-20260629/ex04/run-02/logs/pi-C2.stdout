Z","sha256":"0d98a74d514423fb2dff49af0cc31ac1b604105eb75cb7b02dd7dd309b1864c8","size_bytes":2002,"source_description":"Israel government Prime Minister's Office page identified by web search/open; direct local fetch returned HTTP 403, so this is a concise capture of visible indexed page text returned by web search on 2026-06-29.","source_url":"https://www.gov.il/en/pages/event-hermon171224","storage_name":"0d/0d98a74d514423fb2dff49af0cc31ac1b604105eb75cb7b02dd7dd309b1864c8","submitted_by_role":"plaintiff","submitted_phase":"arguments","text_readable":true,"title":"Israel PMO Mount Hermon statement, 17 Dec. 2024"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-29T23:09:15Z","evidence_id":"ev_15b73465e3b7_submitted-evidence-02-plaintiff-15b73465e3b7","mime_type":"text/plain","original_name":"submitted-evidence-02-plaintiff-15b73465e3b7.txt","record_visibility":"juror_visible","relevance":"Official Israeli statement that Netanyahu ordered the IDF to temporarily take control of the buffer zone in Syria until an effective force enforces the 1974 Separation of Forces Agreement; supports Israeli official confirmation of control, while preserving the defensive/temporary framing.","retrieval_timestamp":"2026-06-29T23:10:30Z","sha256":"15b73465e3b7ba6773a7d5bf580e9b7e2a89780781c263fb74440cace16feb63","size_bytes":1134,"source_description":"Israel government Prime Minister's Office page identified by web search/open; direct local fetch returned HTTP 403, so this is a concise capture of the visible indexed page text returned by web search on 2026-06-29.","source_url":"https://www.gov.il/en/pages/event-us121224","storage_name":"15/15b73465e3b7ba6773a7d5bf580e9b7e2a89780781c263fb74440cace16feb63","submitted_by_role":"plaintiff","submitted_phase":"arguments","text_readable":true,"title":"Israel PMO statement on taking control of Syria buffer zone, 12 Dec. 2024"},{"admissibility_status":"case_packet","created_at":"2026-06-29T22:58:48Z","evidence_id":"ev_54607018