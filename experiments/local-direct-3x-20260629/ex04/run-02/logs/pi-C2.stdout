nt to both control and adverse characterization.","retrieval_timestamp":"2026-06-29T23:12:30Z","sha256":"be16a363f4996b3a3d99638997390e1879742db52212e1239ff98ec093a6d9e7","size_bytes":905,"source_description":"Israel government Prime Minister's Office page identified by web search/open; direct local fetch returned HTTP 403, so this is a concise capture of visible indexed page text returned by web search on 2026-06-29.","source_url":"https://www.gov.il/en/pages/event-golan081224","storage_name":"be/be16a363f4996b3a3d99638997390e1879742db52212e1239ff98ec093a6d9e7","submitted_by_role":"plaintiff","submitted_phase":"arguments","text_readable":true,"title":"Israel PMO Golan Heights statement, 8 Dec. 2024"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-29T23:10:04Z","evidence_id":"ev_c2dd3776f3e3_submitted-evidence-05-plaintiff-c2dd3776f3e3","mime_type":"text/plain","original_name":"submitted-evidence-05-plaintiff-c2dd3776f3e3.txt","record_visibility":"juror_visible","relevance":"Credible reporting that Netanyahu visited the Syrian side of Mount Hermon on 17 Dec. 2024 and said Israel and Israeli troops would remain until another arrangement guaranteed security; corroborates official PMO statement and location.","retrieval_timestamp":"2026-06-29T23:12:00Z","sha256":"c2dd3776f3e3724caaf91012371450dca86743b522bf7796ca52bebcaaea1803","size_bytes":1327,"source_description":"Ynet News article locally fetched and text-extracted 2026-06-29.","source_url":"https://www.ynetnews.com/article/rkhx7hybkx","storage_name":"c2/c2dd3776f3e3724caaf91012371450dca86743b522bf7796ca52bebcaaea1803","submitted_by_role":"plaintiff","submitted_phase":"arguments","text_readable":true,"title":"Ynet report: Netanyahu visits Syrian side of Mount Hermon, 17 Dec. 2024"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-29T23:09:00Z","evidence_id":"ev_ef202b15c89e_submitted-evidence-01-plaintiff-ef202b15c89e","mime_type":"text/plain","original_name":"submitted-evidenc