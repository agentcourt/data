{"case_id":"arb-ex04-20260629225838","run_id":"run-arb-ex04-20260629225838","started_at":"2026-06-29T22:58:38Z","finished_at":"2026-06-29T23:23:49Z","status":"ok","phase":"closed","resolution":"demonstrated","complaint":{"Proposition":"Israel invaded Syria in 2024.  In particular, Israel commenced a\nmilitary offensive intended to establish control over any portion of\nSyria between September 12, 2024 and December 31, 2024, 11:59 PM\nET. For the purposes of this market, the Golan Heights count as\nIsraeli territory.  The authorities for this proposition are official\nconfirmation by Syria, Israel, the United Nations, or any permanent\nmember of the UN Security Council, however a consensus of credible\nreporting will also be used."},"evidence_standard":"Preponderance of the evidence.","council_backend":"councilapi","attorneys":[{"role":"plaintiff","interface":"lawyerapi"},{"role":"defendant","interface":"lawyerapi"}],"case_files":[{"evidence_id":"ev_54607018b65c_market-rules","name":"market-rules.md","mime_type":"text/markdown","text_readable":true},{"evidence_id":"ev_ef202b15c89e_submitted-evidence-01-plaintiff-ef202b15c89e","name":"submitted-evidence-01-plaintiff-ef202b15c89e.txt","mime_type":"text/plain","text_readable":true},{"evidence_id":"ev_15b73465e3b7_submitted-evidence-02-plaintiff-15b73465e3b7","name":"submitted-evidence-02-plaintiff-15b73465e3b7.txt","mime_type":"text/plain","text_readable":true},{"evidence_id":"ev_0d98a74d5144_submitted-evidence-03-plaintiff-0d98a74d5144","name":"submitted-evidence-03-plaintiff-0d98a74d5144.txt","mime_type":"text/plain","text_readable":true},{"evidence_id":"ev_63f356380079_submitted-evidence-04-plaintiff-63f356380079","name":"submitted-evidence-04-plaintiff-63f356380079.txt","mime_type":"text/plain","text_readable":true},{"evidence_id":"ev_c2dd3776f3e3_submitted-evidence-05-plaintiff-c2dd3776f3e3","name":"submitted-evidence-05-plaintiff-c2dd3776f3e3.txt","mime_type":"text/plain","text_readable":true},{"evidence_id":"ev_b