:"","thinkingSignature":"reasoning","type":"thinking"},{"arguments":{"args":"{}","tool":"aar_wait_for_opportunity"},"id":"call_b1eff8230336436782fdce","name":"mcp","type":"toolCall"}],"model":"qwen/qwen3-next-80b-a3b-thinking","provider":"openrouter","responseId":"gen-1782836942-hCKDahzKu9XvOTo7PYOS","responseModel":"qwen/qwen3-next-80b-a3b-thinking-2509","role":"assistant","stopReason":"toolUse","timestamp":1782836942529,"usage":{"cacheRead":0,"cacheWrite":0,"cost":{"cacheRead":0,"cacheWrite":0,"input":0,"output":0,"total":0},"input":2405,"output":454,"totalTokens":2859}},"type":"thinking_end"},"message":{"api":"openai-completions","content":[{"thinking":"","thinkingSignature":"reasoning","type":"thinking"},{"arguments":{"args":"{}","tool":"aar_wait_for_opportunity"},"id":"call_b1eff8230336436782fdce","name":"mcp","type":"toolCall"}],"model":"qwen/qwen3-next-80b-a3b-thinking","provider":"openrouter","responseId":"gen-1782836942-hCKDahzKu9XvOTo7PYOS","responseModel":"qwen/qwen3-next-80b-a3b-thinking-2509","role":"assistant","stopReason":"toolUse","timestamp":1782836942529,"usage":{"cacheRead":0,"cacheWrite":0,"cost":{"cacheRead":0,"cacheWrite":0,"input":0,"output":0,"total":0},"input":2405,"output":454,"totalTokens":2859}},"type":"message_update"}
