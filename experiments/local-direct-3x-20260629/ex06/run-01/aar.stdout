.00000325","pricing_prompt":"0.00000065","provider_error_count":null,"provider_name":"Alibaba","quantization":"unknown","schema_violation_count":null,"source_row":22,"supported_parameters":["max_tokens","presence_penalty","response_format","seed","structured_outputs","temperature","tool_choice","tools","top_p"],"timeout_count":null,"uptime_last_1d":100,"uptime_last_30m":null}],"openrouter_model_id":"qwen/qwen3-coder-plus","provider_name":"Alibaba","quantization":"unknown","representative_endpoint_variant_id":"9c82a354109f1ca6abfcfbee","representative_source_row":22}}}],"events":[{"timestamp":"2026-06-30T00:54:38.561Z","turn":0,"role":"system","phase":"openings","type":"run_initialized","payload":{"attorneys":[{"role":"plaintiff","interface":"lawyerapi"},{"role":"defendant","interface":"lawyerapi"}],"complaint":{"Proposition":"The event below resolves to YES.\n\n| Property   | Value                                                                                                                                                                                                                                                                               |\n|------------|-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------|\n| Event      | The United States Armed Forces conduct a military operation involving ground troops entering Venezuelan sovereign territory with the objective of seizing or holding territory, removing the sitting government, or establishing operational control of a major population center.  |\n| Source     | Official statement from the U.S. Department of Defense or the White House confirming deployment of ground forces. Secondary: UN Security Council records.                                                                                                                           |\n| Criteria   | Resolves YES if U.S. ground forces enter Venezuelan territory in a combat capacity. Targeted strikes, naval blockades, special operations raids without territorial objectives, and cyber operations resolve NO.                                                                    |\n| Edge cases | Capture of a head of state without territorial occupation: NO (separate blueprint for regime change). U.S. forces entering from a third country: YES if troops cross into Venezuelan territory. Proxy forces directed by U.S. command: NO unless U.S. personnel physically present. |\n| Fallback   | If DoD and White House issue conflicting statements, UN Security Council records are binding. If no official statement within 72 hours of credible reports, resolution deferred 30 days.                                                                                            |\n| Expiration | January 31, 2026. Resolves NO if event has not occurred.                                                                                                                                                                                                                           |"},"council":[{"member_id":"C1","model":"openrouter://openai/gpt-4o-mini","persona_file":"personas/generic.md","request_spec":{"endpoint":"openrouter","model":"openai/gpt-4o-mini","provider":{"only":["openai"],"allow_fallbacks":false,"require_parameters":true},"request":{},"headers":{"X-OpenRouter-Experimental-Metadata":"enabled"},"persona":"personas/generic.md","variant_metadata":{"endpoint_tag":"openai","endpoint_variant_id":"88545caab5a2d54d4e1b9561","equivalence_class_size":1,"equivalence_key":{"canonical_slug":"openai/gpt-4o-mini","endpoint_model_id":"openai/gpt-4o-mini","hugging_face_id":null,"input_modalities":["file","image","text"],"openrouter_model_id":"openai/gpt-4o-mini","output_modalities":["text"],"quantization":"unknown"},"equivalent_endpoints":[{"cano