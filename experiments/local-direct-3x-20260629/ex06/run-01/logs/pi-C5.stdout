es.\n\nThe proposition specifically excludes \"special operations raids without territorial objectives\" and \"capture of a head of state without territorial occupation.\" Although Maduro was removed from power, the record indicates this was the result of his capture and removal from Venezuela, not through U.S. ground forces maintaining control over territory or a government-institutional structure after the capture.\n\n"},{"type":"toolCall","id":"call_89dda691574b4fa789c57bd4","name":"mcp","arguments":{"tool":"aar_submit_council_vote","args":"{\"vote"},"partialArgs":"{\"tool\": \"aar_submit_council_vote\", \"args\": \"{\\\"vote","streamIndex":0}],"api":"openai-completions","provider":"openrouter","model":"qwen/qwen3-coder-plus","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1782783133122,"responseId":"gen-1782783133-dDoOU5NNrohiuFN4rcKh"}}
