responses request failed: POST \"https://openrouter.ai/api/v1/responses\": 404 Not Found {\"message\":\"No endpoints found for anthropic/claude-opus-4.6-fast.\",\"code\":404}","member_id":"C1","replacement_model":"openrouter://nvidia/nemotron-3-super-120b-a12b","replacement_persona_filename":"personas/generic.md","unavailable_model":"openrouter://anthropic/claude-opus-4.6-fast","unavailable_persona_filename":"personas/generic.md"}},{"timestamp":"2026-06-30T13:54:49.801Z","turn":0,"role":"system","phase":"openings","type":"run_initialized","payload":{"attorneys":[{"role":"plaintiff","interface":"lawyerapi"},{"role":"defendant","interface":"lawyerapi"}],"complaint":{"Proposition":"By May 24, 2026, 11:59 PM ET, Iran initiated a major non-weather closure of its airspace within the meaning of the market rule.\n\nThis is an open-record/search-enabled arbitration of the factual condition behind the Polymarket market, not an adjudication of Polymarket, UMA, or resolution-governance correctness."},"council":[{"member_id":"C1","model":"openrouter://nvidia/nemotron-3-super-120b-a12b","persona_file":"personas/generic.md","request_spec":{"endpoint":"openrouter","model":"nvidia/nemotron-3-super-120b-a12b","provider":{"only":["dekallm/fp8"],"allow_fallbacks":false,"require_parameters":true,"quantizations":["fp8"]},"request":{},"headers":{"X-OpenRouter-Experimental-Metadata":"enabled"},"persona":"personas/generic.md","variant_metadata":{"endpoint_tag":"dekallm/fp8","endpoint_variant_id":"302d9b9502a2632686ad6191","equivalence_class_size":1,"equivalence_key":{"canonical_slug":"nvidia/nemotron-3-super-120b-a12b-20230311","endpoint_model_id":"nvidia/nemotron-3-super-120b-a12b","hugging_face_id":"nvidia/NVIDIA-Nemotron-3-Super-120B-A12B-FP8","input_modalities":["text"],"openrouter_model_id":"nvidia/nemotron-3-super-120b-a12b","output_modalities":["text"],"quantization":"fp8"},"equivalent_endpoints":[{"canonical_slug":"nvidia/nemotron-3-super-120b-a12b-20230311","clusters":[2,3,3,4],"co