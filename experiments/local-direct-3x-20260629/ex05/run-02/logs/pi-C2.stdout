{"aar_log_filter":{"content_index":0,"dropped_prefix_bytes":374,"field":"text","message":"earlier repeated message_update events dropped","replaced_fields":2,"response_id":"gen-1782779618-AsPTndJvTvbwbDtWE8f2","tail_bytes":1},"assistantMessageEvent":{"contentIndex":0,"delta":".","partial":{"api":"openai-completions","content":[{"text":".","type":"text"}],"model":"mistralai/mistral-medium-3-5","provider":"openrouter","responseId":"gen-1782779618-AsPTndJvTvbwbDtWE8f2","responseModel":"mistralai/mistral-medium-3.5-20260430","role":"assistant","stopReason":"stop","timestamp":1782779618077,"usage":{"cacheRead":0,"cacheWrite":0,"cost":{"cacheRead":0,"cacheWrite":0,"input":0,"output":0,"total":0},"input":0,"output":0,"totalTokens":0}},"type":"text_delta"},"message":{"api":"openai-completions","content":[{"text":".","type":"text"}],"model":"mistralai/mistral-medium-3-5","provider":"openrouter","responseId":"gen-1782779618-AsPTndJvTvbwbDtWE8f2","responseModel":"mistralai/mistral-medium-3.5-20260430","role":"assistant","stopReason":"stop","timestamp":1782779618077,"usage":{"cacheRead":0,"cacheWrite":0,"cost":{"cacheRead":0,"cacheWrite":0,"input":0,"output":0,"total":0},"input":0,"output":0,"totalTokens":0}},"type":"message_update"}
{"aar_log_filter":{"content_index":0,"dropped_prefix_bytes":375,"field":"text","message":"earlier repeated message_update events dropped","replaced_fields":2,"response_id":"gen-1782779618-AsPTndJvTvbwbDtWE8f2","tail_bytes":0},"assistantMessageEvent":{"content":"My vote was accepted. The proposition was found **not demonstrated** because, while the record proves a serious U.S. military raid inside Caracas with temporary tactical control, the official sources and credible reporting consistently frame the operational objective as capture/extraction rather than an intent to establish territorial control over any portion of Venezuela.","contentIndex":0,"partial":{"api":"openai-completions","content":[{"text":"","type":"text"}],"model":"mistralai/mistral-medium-3-5","provider":"openrouter","responseId":"gen-1782779618-AsPTndJvTvbwbDtWE8f2","responseModel":"mistralai/mistral-medium-3.5-20260430","role":"assistant","stopReason":"stop","timestamp":1782779618077,"usage":{"cacheRead":43632,"cacheWrite":0,"cost":{"cacheRead":0,"cacheWrite":0,"input":0,"output":0,"total":0},"input":799,"output":64,"totalTokens":44495}},"type":"text_end"},"message":{"api":"openai-completions","content":[{"text":"","type":"text"}],"model":"mistralai/mistral-medium-3-5","provider":"openrouter","responseId":"gen-1782779618-AsPTndJvTvbwbDtWE8f2","responseModel":"mistralai/mistral-medium-3.5-20260430","role":"assistant","stopReason":"stop","timestamp":1782779618077,"usage":{"cacheRead":43632,"cacheWrite":0,"cost":{"cacheRead":0,"cacheWrite":0,"input":0,"output":0,"total":0},"input":799,"output":64,"totalTokens":44495}},"type":"message_update"}
{"type":"message_end","message":{"role":"assistant","content":[{"type":"text","text":"My vote was accepted. The proposition was found **not demonstrated** because, while the record proves a serious U.S. military raid inside Caracas with temporary tactical control, the official sources and credible reporting consistently frame the operational objective as capture/extraction rather than an intent to establish territorial control over any portion of Venezuela."}],"api":"openai-completions","provider":"openrouter","model":"mistralai/mistral-medium-3-5","usage":{"input":799,"output":64,"cacheRead":43632,"cacheWrite":0,"totalTokens":44495,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1782779618077,"responseId":"gen-1782779618-AsPTndJvTvbwbDtWE8f2","responseModel":"mistralai/mistral-medium-3.5-20260430"}}
{"type":"turn_end","message":{"role":"assistant","content":[{"type":"text","text":"My vote was accepted. The proposition was found **not demonstrated** because, while the record proves a serious U.S. military raid inside Caracas with temporary tactical control, the official sources and credible reporting consistently frame the operational objective as capture/extraction rather than an intent to establish territorial control over any portion of Venezuela."}],"api":"openai-completions","provider":"openrouter","model":"mistralai/mistral-medium-3-5","usage":{"input":799,"output":64,"cacheRead":43632,"cacheWrite":0,"totalTokens":44495,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1782779618077,"responseId":"gen-1782779618-AsPTndJvTvbwbDtWE8f2","responseModel":"mistralai/mistral-medium-3.5-20260430"},"toolResults":[]}
{"type":"agent_end","messages":[{"role":"user","content":[{"type":"text","text":"You are council member C2 for AAR case arb-ex05-20260630001330. Use the Pi MCP proxy tool named `mcp` to call AAR tools. The Pi proxy exposes AAR tools with `aar_` prefixes.\n\nEvery `mcp` call must have exactly this shape: a `tool` string and an `args` string. Do not include `action`, `server`, or `connect`. Do not pass `args` as an object.\n\nFirst call `mcp` with `{\"tool\":\"aar_wait_for_opportunity\",\"args\":\"{}\"}`. If it returns `state: waiting`, call the same tool again with the returned `after_version`, using an args string such as `{\"after_version\":3}`. If it returns `state: ready`, read the returned prompt, turn, limits, remaining time, attempts remaining, and opportunity id.\n\nReview the visible arbitration record and admitted evidence. Use MCP tool calls for `aar_get_case`, `aar_list_evidence`, `aar_stat_evidence`, and `aar_read_evidence_range` when exact contents or provenance matter. You may use Pi's ordinary local tools to organize and analyze the record, but your vote must rely on admitted record evidence and the arbitration record.\n\nWhen ready, call `mcp` with tool `aar_submit_council_vote`, vote `demonstrated` or `not_demonstrated`, and a concise rationale grounded in the record. The `args` value must be a JSON string, for example `{\"vote\":\"demonstrated\",\"rationale\":\"The admitted record proves the proposition by a preponderance.\"}`. The AAR prompt and tool list use unprefixed names such as `submit_council_vote`; in Pi, call the corresponding `aar_submit_council_vote` tool through `mcp`. Do not write tool-call markup as plain text. After `aar_submit_council_vote` returns `ok: true`, report that your vote was accepted and stop. Do not call `aar_wait_for_opportunity` again after your vote is accepted. If `aar_wait_for_opportunity` returns `state: done`, report that the case is done and stop. If it returns `state: failed` or `state: error`, report the returned message and stop. Do not ask the user for the next turn. Do not create a cron job. Do not listen for inbound HTTP.\n"}],"timestamp":1782779602083},{"role":"assistant","content":[{"type":"toolCall","id":"kUMUhWAIi","name":"mcp","arguments":{"tool":"aar_wait_for_opportunity","args":"{}"}}],"api":"openai-completions","provider":"openrouter","model":"mistralai/mistral-medium-3-5","usage":{"input":1021,"output":22,"cacheRead":1360,"cacheWrite":0,"totalTokens":2403,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1782779602101,"responseId":"gen-1782779604-MnvgjGmDgiscfBxOYVhP","responseModel":"mistralai/mistral-medium-3.5-20260430"},{"role":"toolResult","toolCallId":"kUMUhWAIi","toolName":"mcp","content":[{"type":"text","text":"ok: true\nstatus: ready\nstate: ready\nmessage: An opportunity is ready. Use the returned prompt, turn, limits, and tools to act.\nafter_version: 19\nafter_opportunity_id: deliberation:1:C2\nmember_id: C2\ncase_id: arb-ex05-20260630001330\nwait_reason: ready\nphase: deliberation\nopportunity_id: deliberation:1:C2\nremaining_ms: 884568\nattempts_remaining: 3\njson: {\"after_opportunity_id\":\"deliberation:1:C2\",\"after_version\":19,\"case_id\":\"arb-ex05-20260630001330\",\"limits\":{\"attempts_max\":3,\"attempts_remaining\":3,\"max_evidence_read_bytes\":65536,\"max_evidence_read_bytes_per_opportunity\":524288,\"max_evidence_reads_per_opportunity\":32,\"max_response_bytes\":131072,\"remaining_evidence_read_bytes_for_opportunity\":524288,\"remaining_evidence_reads_for_opportunity\":32},\"member_id\":\"C2\",\"message\":\"An opportunity is ready. Use the returned prompt, turn, limits, and tools to act.\",\"ok\":true,\"prompt\":\"Role: council member\\nMember ID: C2\\nDeliberation round: 1\\nProposition: The United States invaded Venezuela between November 3, 2025, and\\nJanuary 31, 2026, 11:59 PM ET.  In particular,the United States\\ncommenced a military offensive intended to establish control over any\\nportion of Venezuela between November 3, 2025, and January 31, 2026,\\n11:59 PM ET. Land de facto controlled by Venezuela or the United\\nStates as of September 6, 2025, 12:00 PM ET, is considered to the\\nsovereign territory of that country. The resolution source is a\\nconsensus of credible sources.\\nStandard of evidence: Preponderance of the evidence.\\nPersona:\\nYou are a careful juror and council member.\\n\\nEvaluate the record faithfully. Decide only from the evidence, the stated rules, and the applicable burden of proof. Do not favor either side, fill gaps with speculation, or ignore uncertainty.\\n\\nGive weight to reliable sources, direct evidence, consistent reasoning, and clear admissions. Discount unsupported claims, rhetorical force, irrelevant facts, and conclusions that exceed the record.\\n\\nWhen the evidence supports one answer, state it plainly. When the evidence is incomplete or balanced, say so. Be concise, honest, and exact.\\n\\nRecord:\\nOpenings:\\n[plaintiff] Council members, the proposition is not asking whether the United States used harsh rhetoric toward Venezuela, or whether a short raid can be called an invasion in ordinary speech. It asks a narrower factual question: during the window from November 3, 2025 through January 31, 2026, did the United States commence a military offensive intended to establish control over any portion of Venezuelan territory?\\n\\nThe current record is empty. No case-packet evidence, source documents, exhibits, or submitted evidence are yet before you. For that reason, this opening is a roadmap, not a request to decide on assertions unsupported by admitted proof. The plaintiff’s burden is preponderance of the evidence, and the decisive proof will need to come from credible-source consensus, preferably including official U.S. statements, contemporaneous news reporting, and independent expert analysis.\\n\\nOur theory is that this was an invasion under the proposition’s definition because the expected evidence will show an integrated U.S. military campaign, not an isolated arrest. The relevant facts will likely include the sequence of military buildup, maritime interdiction or blockade, strikes on or against Venezuelan territory, armed entry into Caracas or other Venezuelan sites, seizure and removal of the sitting effective ruler, temporary U.S. control over the places and routes needed to carry out that seizure, and follow-on statements or acts showing an intent to dictate Venezuela’s political transition or control Venezuelan resources. If that proof is admitted, it satisfies the proposition even if the United States did not permanently annex land or maintain a long occupation. The proposition requires an offensive intended to establish control over any portion of territory; temporary military control of a target area, base, airspace, port, route, or government seat can be enough if credible sources show it was part of the intended operation.\\n\\nThe defense’s best answer is predictable and important: it will say the United States conducted a brief law-enforcement or counter-narcotics operation, that any ground presence lasted only long enough to capture a criminal defendant, and that there was no intent to hold Venezuelan territory. That is the real dispute. A mere strike, a naval seizure outside Venezuela, or a short exfiltration with no intended territorial control would not, standing alone, meet the proposition. Nor would generalized political pressure or sanctions. The council should therefore focus on evidence of planned control: operational objectives, official descriptions of the forces and targets, whether U.S. forces controlled Venezuelan land or facilities even temporarily, whether the operation displaced Venezuela’s effective government, and whether U.S. officials claimed authority to administer the aftermath.\\n\\nThe plaintiff will seek to build the record with primary and near-primary sources: official White House, State, Defense, and Justice materials; transcripts of relevant press briefings and interviews; contemporaneous wire-service reporting; and independent legal or foreign-policy analysis that addresses the same facts. We will also test adverse material, especially any official claim that this was not an invasion and not an occupation. Those claims matter, but they are not conclusive if the underlying conduct and intent show a military offensive to establish control over Venezuelan territory.\\n\\nAt the end of the case, the question should be answered by the weight of credible sources, not labels. If the admitted record shows only a narrow arrest operation without territorial-control intent, plaintiff should lose. But if the admitted record shows that the United States used military force inside Venezuela as part of a planned campaign to seize control of places, routes, institutions, or resources necessary to impose a political outcome, then the proposition is more likely than not true.\\n\\n[defendant] Council members, the proposition is not whether the United States used force against Venezuela, whether officials used aggressive rhetoric, whether Congress debated war-powers limits, or whether an operation was lawful under domestic or international law. The proposition asks a narrower factual question: did the United States commence a military offensive, during the defined window, intended to establish control over any portion of Venezuelan territory?\\n\\nThe answer cannot be supplied by labels. “Hostilities,” “intervention,” “aggression,” “raid,” “capture,” “extraction,” and “regime pressure” may all matter as evidence leads, but none is the element the council must find. The plaintiff must prove by a preponderance, through a consensus of credible sources, both military action and the specific intent to establish territorial control. If the eventual record shows only strikes, maritime interdictions, sanctions enforcement, a law-enforcement capture operation, temporary tactical presence for entry and exit, or political pressure on Venezuela’s leadership, plaintiff has not met the proposition as written.\\n\\nThe current record contains no admitted evidence at all. There are no case-packet files, no exhibits, and no submitted source materials. The plaintiff’s opening properly recognizes that a mere strike or short exfiltration without intended territorial control would not be enough. That concession identifies the real dispute. The defense will hold plaintiff to it.\\n\\nOur theory is that the decisive proof, if admitted, will show a counter-narcotics, interdiction, and extraction frame rather than an offensive to take and hold Venezuelan territory. The defense will not ask the council to ignore adverse evidence. If plaintiff later admits credible primary materials showing that U.S. forces set out to control ports, airfields, ministries, bases, roads, oil fields, neighborhoods, or other Venezuelan land as an object of the operation, that would be serious evidence for plaintiff. So would proof that the United States administered territory, installed a military authority over a place, maintained checkpoints for territorial governance, or claimed a continuing right to control Venezuelan facilities or resources.\\n\\nBut that is exactly the proof the plaintiff must produce. A military force can briefly control a doorway, route, landing zone, compound, airspace, or vessel as an incident of an arrest, strike, rescue, evacuation, or interdiction without intending to establish control over Venezuelan territory in the sense required by this proposition. Likewise, a government can seek a leader’s prosecution, weaken a hostile regime, interdict trafficking, or apply coercive pressure without crossing this proposition’s territorial-control line. The council should separate those categories carefully.\\n\\nThe coming evidence should therefore be tested around five questions. First, what was the actual operational objective, as shown by primary official materials, contemporaneous reporting, and reliable expert analysis? Second, what physical presence occurred inside land deemed Venezuelan territory as of September 6, 2025, and how long did it last? Third, did U.S. forces exercise control merely to complete a mission and leave, or did they seek to possess, administer, or deny Venezuela control of a place? Fourth, what did the United States do after the operation: withdraw, transfer custody, or govern territory? Fifth, do credible sources converge on territorial-control intent, or only on force, illegality, hostilities, or political consequences?\\n\\nProvenance will matter. Official statements may understate conflict; hostile governments may overstate occupation; secondary commentary may collapse legal “aggression” into the different factual standard here. The most valuable evidence will be original government documents, full transcripts, congressional materials, after-action or oversight reports, and contemporaneous reporting that distinguishes what happened from what advocates called it.\\n\\nAt the close of this case, if the record shows the United States began an offensive meant to establish control over Venezuelan territory, the plaintiff should prevail. But if the record shows military force, even serious and controversial force, without that intended territorial-control objective, the proposition fails. On the present empty record, and under the plaintiff’s burden, the defense position is that the council should require that missing link before finding an invasion.\\n\\nArguments:\\n[plaintiff] Council members, the admitted record now answers the defendant’s missing-link argument. The proposition requires a U.S. military offensive intended to establish control over any portion of Venezuelan territory. It does not require permanent annexation, a months-long occupation, or magic words from U.S. officials.\\n\\nThe record proves a campaign, not a one-off arrest. AP/PBS reports a months-long escalation: 35 known strikes against alleged drug-smuggling boats, a regional naval buildup including destroyers, amphibious assault ships, about 6,000 sailors and Marines, aircraft, F-35s and a cruise-missile submarine, then CIA operations inside Venezuela. It further reports a late-December direct operation on Venezuelan soil and, on January 3, a large-scale strike across Caracas, capture of Maduro and Flores, and their removal from the country. PX-3.\\n\\nThe official U.S. record confirms the coercive structure. The White House says President Trump authorized lethal force, ordered a total and complete blockade of sanctioned oil tankers going in and out of Venezuela, offered Maduro “off ramps,” and that U.S. armed forces conducted an extraordinary military operation to bring Maduro to justice. It also states Venezuelan sovereign oil revenues were held in U.S. custody and protected to advance U.S. foreign-policy objectives in Venezuela. PX-1.\\n\\nMost importantly, the official adverse source admits territorial entry. Secretary Rubio’s White House release says U.S. forces were on the ground in Venezuela for about two hours when they went to capture Maduro. It also says Venezuela would continue to face an oil quarantine, U.S. pressure, seizure of sanctioned boats, targeting of drug boats, and “potentially other things” until the changes demanded by the United States were made. PX-2. That is not just a completed criminal arrest; it is ground force, blockade, coercive options, and compelled policy change.\\n\\nIndependent sources confirm the meaning of those facts. Brookings describes the January 3 operation as a U.S. special operation to exfiltrate Maduro and his wife from Caracas; it fairly preserves Rubio’s answer that this was not an invasion and the U.S. did not occupy a country. PX-4. Chatham House goes further on the facts relevant here: U.S. forces operating in Venezuela, strikes on military targets in and around Caracas, U.S. special forces forcibly abducting the sitting president, and President Trump announcing that the United States would run Venezuela and administer a political transition or regime change under threat of further, more massive force. PX-5.\\n\\nThis record proves all elements by a preponderance. First, the date is inside the window: late December direct action on Venezuelan soil and the January 3 Caracas operation occurred before January 31, 2026. Second, it was military: armed forces, special forces, strikes, warships, aircraft, a submarine, lethal force, and blockade. Third, it reached Venezuelan territory: Caracas, a military-base home, military targets in and around the capital, and official admission of U.S. forces on Venezuelan ground. Fourth, the intended control element is satisfied by control over portions and sovereign functions: the target zone in Caracas for the capture, the air/strike environment needed to carry it out, sea lanes through blockade and oil quarantine, custody of Venezuelan sovereign oil revenues, and the announced plan to run or administer Venezuela’s transition under threat of more force.\\n\\nThe defense will lean on Rubio’s labels: not a war against Venezuela, not an invasion, not extended. But labels do not defeat underlying admissions. Rubio’s own statement supplies the key facts: U.S. forces were on Venezuelan ground, used a raid to capture the effective ruler, and retained coercive options until Venezuela changed course. The proposition’s phrase “any portion” is broad. Two hours of armed control in Caracas is still control over a portion; a blockade and oil quarantine are control over access and resources; removal of the effective ruler plus asserted transition authority is control over sovereign political functions.\\n\\nNor does the law-enforcement framing save the defense. A police purpose can coexist with a military offensive if the means are military and the intended effect is control. Here the operation was preceded by lethal strikes and blockade, executed by U.S. forces inside Venezuela, and followed by continuing threats and resource control. The credible-source consensus is not that nothing happened; it is that the United States used force inside Venezuela, captured and removed Maduro, and then sought to direct Venezuela’s course.\\n\\nProvenance and limits: PX-1 and PX-2 are official U.S. sources and therefore especially strong against U.S. denial of ground presence, blockade, and resource custody, though self-serving on legal labels. PX-3 is contemporaneous AP reporting carried by PBS. PX-4 and PX-5 are expert analyses, not primary operational records, so they carry less weight than official admissions but are valuable for independent assessment and adverse framing. The record lacks a full DOD after-action report or original video transcript for every statement, but the admitted sources converge on the decisive facts.\\n\\nOn this record, it is more likely than not that the United States commenced a military offensive intended to establish control over portions of Venezuela during the required period. The proposition should be found true.\\n\\n[defendant] Council members, the record now proves a serious U.S. military operation in and against Venezuela. The defense should not pretend otherwise. It proves strikes, a buildup, a Caracas raid, a two-hour ground presence, capture and removal of Maduro and Flores, oil/tanker pressure, and political leverage. But the proposition is still narrower: plaintiff must prove that the United States commenced a military offensive intended to establish control over Venezuelan territory. On this record, that missing intent remains unproved.\\n\\nStart with the official sources. PX-2 records Secretary Rubio admitting a two-hour ground presence, but in the same official statement he says the United States was not at war with Venezuela, was at war with drug-trafficking organizations, and that this was not an invasion or extended military operation. PX-4 independently preserves the same limiting point: Rubio’s answer was “not an invasion” and “we did not occupy a country.” Those labels are not conclusive, but they are highly relevant to intent.\\n\\nDX-1, the Department of War’s own article, confirms the adverse facts: an operation in Caracas, more than 150 aircraft covering a ground extraction force, and months of planning. But it repeatedly frames Operation Absolute Resolve as a capture, extraction, criminal-justice operation, and joint military/law-enforcement mission tied to a DOJ indictment. DX-2 gives the broader campaign frame: Operation Southern Spear was officially initiated to disrupt narcotics flows from designated terrorist and criminal organizations, primarily through boat strikes, interdictions, and regional deployments. That is evidence of coercive military force; it is not proof that the object was to establish control over Venezuelan land.\\n\\nPlaintiff’s argument turns “any portion” into “any tactical control during any raid.” That is too broad. Every armed entry temporarily controls some doorway, route, landing zone, airspace, or target room. If that incidental control is enough, the proposition would be true of any commando arrest or rescue operation inside foreign territory. The wording requires more: an offensive intended to establish control over a portion of Venezuela, not merely control incident to seizing a person and leaving.\\n\\nPX-1 likewise does not close the gap. It shows custody of Venezuelan oil revenues in U.S. Treasury accounts, a blockade of sanctioned oil tankers, lethal force against narcoterrorists, and an armed-forces operation in support of law enforcement. Those are grave acts of pressure and may be hostile, illegal, or interventionist. But money in Treasury accounts and tanker interdictions are not control over Venezuelan territory. A blockade may control maritime access; it does not, without more, show intent to possess, administer, or govern land that the proposition treats as Venezuelan sovereign territory.\\n\\nPX-3 is credible reporting, but its strongest points are still escalation and force: 35 boat strikes, warships, CIA operations, a late-December direct strike, and the January 3 Caracas capture. It also notes Maduro’s view that the campaign sought to oust him. Regime-change pressure is not the same as territorial-control intent. The related PBS watch-title about the United States “going to run Venezuela” is only a linked title in the submitted extract, not the video, transcript, context, or exact statement.\\n\\nPX-5 is plaintiff’s strongest source because Chatham House characterizes the operation as strikes around Caracas, special-forces abduction, and a U.S. announcement to run or administer a transition under threat of more force. The council should weigh it seriously, but also carefully. It is expert legal commentary about sovereignty and the UN Charter, not a primary operational order or full transcript. It supports that the operation may have been an unlawful use of force or aggression. It does not supply concrete facts that U.S. forces occupied, administered, or held any Venezuelan place after the raid.\\n\\nEven DX-1’s adverse transition language is equivocal. It says the United States would “oversee” Venezuela until a legitimate replacement could be identified and that Rubio was working with Delcy Rodriguez. That sounds like political direction and leverage. But the same source says Rodriguez was sworn in, that she was willing to work with the United States, and that the mission was an extraction/capture with no U.S. casualties. The record has no order establishing U.S. military government, no map of controlled territory, no duration beyond the two-hour raid, no U.S. checkpoints, no occupied ministries, no seized ports or bases held afterward, and no source showing U.S. forces remained to administer land.\\n\\nThat distinction decides the case. The record proves force, illegality arguments, coercion, and perhaps regime-change influence. It does not prove by a preponderance that territorial control was the intended object of the offensive. The credible-source consensus is mixed: official sources say capture, law enforcement, counter-narcotics, no invasion, no occupation; secondary sources condemn the operation and infer broader control, but rely on thinly captured transition language and legal characterization.\\n\\nThe plaintiff bears the burden. Because the admitted record does not show that the United States intended to establish control over Venezuelan territory, as opposed to conducting a short capture/extraction and applying continuing non-territorial pressure, the council should find the proposition not proved.\\n\\nRebuttals:\\n[plaintiff] Council members, defendant’s argument narrows the proposition too far. It concedes the record proves a serious U.S. military operation in and against Venezuela: strikes, buildup, a Caracas raid, two-hour ground presence, capture/removal of Maduro and Flores, oil/tanker pressure, and political leverage. The remaining question is whether the object included control over any portion of Venezuela.\\n\\nDefendant says plaintiff’s theory would make any brief commando raid an invasion. But this record is not about a doorway or landing zone. Defendant’s own DX-1 describes Operation Absolute Resolve as a U.S. military operation in Caracas against a heavily fortified military fortress in the heart of Venezuela’s capital. It followed months of planning by joint forces, special operations forces, and intelligence agencies. Gen. Caine described complex air, ground, space, and maritime operations. More than 150 military aircraft covered the ground extraction force. Hegseth called it a massive joint military and law-enforcement raid.\\n\\nThose facts satisfy “any portion.” A planned armed domination of a fortified military site in Caracas, covered by 150 aircraft and integrated domains, is control over a portion of Venezuelan territory. It need not be permanent. The mission could not succeed unless U.S. forces intended to deny Venezuelan control over that site and surrounding operational environment long enough to seize and remove the effective ruler.\\n\\nDefendant also separates regime-change pressure from territorial control. DX-1 defeats that separation. It reports that with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition could be identified; Rubio was working directly with Delcy Rodriguez; and Rodriguez was willing to do what the United States thought necessary. PX-5 independently captures that as U.S. administration of a transition under threat of more force. That is not merely prosecution in New York.\\n\\nDX-2 does not rescue the defense. It frames Southern Spear as counter-narcotics and boat interdiction, but also admits major Navy/Marine deployments, lethal strikes, tanker interdictions, and a classified mission statement. It does not negate the specific intent of Operation Absolute Resolve in Caracas.\\n\\nThe defense imports an occupation requirement the proposition does not contain. The question is whether the United States commenced a military offensive intended to establish control over any portion of Venezuela, not whether it held checkpoints for weeks or annexed land. Rubio’s “not an invasion” label deserves consideration, but labels cannot outweigh the record facts: military force inside Venezuela, control of the necessary Caracas target area, removal of Maduro, and asserted authority to shape Venezuela’s transition and resources. That is enough under the actual proposition.\\n\\nSurrebuttals:\\n[defendant] Council members, plaintiff’s rebuttal usefully narrows the dispute to two points: the Caracas site and the transition language. Neither carries plaintiff’s burden.\\n\\nFirst, plaintiff says the fortified military site in Caracas satisfies “any portion” because U.S. forces necessarily denied Venezuelan control long enough to seize and remove Maduro. That proves tactical control; it does not prove that the United States commenced an offensive intended to establish territorial control. Those are different things. A raid, arrest, rescue, or extraction at a defended facility always requires temporary domination of the target area. If that alone satisfies the proposition, the phrase “intended to establish control” does no work, and every cross-border commando raid becomes an invasion under this standard.\\n\\nThe record does not show the Caracas site was an object to be held, administered, possessed, governed, or transferred as territory. DX-1 describes a ground-based extraction force, a capture, criminal proceedings, and a joint military/law-enforcement mission. It is adverse because the operation was large and military; it is still not proof that the United States intended to establish control over Venezuelan land rather than control the scene long enough to extract two people.\\n\\nSecond, plaintiff relies on “oversee Venezuela” and PX-5’s transition-control wording. That is the strongest contrary evidence, but it remains ambiguous. Political leverage over a successor government is not the same as territorial control. DX-1 says Delcy Rodriguez was sworn in and was willing to work with the United States. That is not the United States installing a military government over a place, holding facilities, drawing boundaries, manning checkpoints, or leaving forces in control after the raid.\\n\\nPlaintiff says the defense imports an occupation requirement. No. The defense accepts that the proposition does not require annexation or a long occupation. But it does require an intent to establish control over territory. A short duration can qualify if the object is control of the place. Here the record shows a short duration whose object was capture and extraction. The admitted sources show force, pressure, and influence; they do not show a territorial-control objective.\\n\\nDX-2 still matters for that reason. Plaintiff says it does not negate Operation Absolute Resolve. True, it does not decide the whole case. But it is an official oversight account of the broader campaign as counter-narcotics, interdiction, and strikes, with the mission statement classified. Plaintiff has not filled that classified gap with an operational order, full transcript, or post-operation facts showing that the Caracas raid changed into a territorial-control campaign.\\n\\nThe council can condemn the operation as unlawful, coercive, or interventionist and still find the proposition not proved. The question is not whether the United States used overwhelming force inside Venezuela. It did. The question is whether credible sources show, more likely than not, that the United States intended to establish control over Venezuelan territory. The record remains at most equivocal on that decisive element, so plaintiff has not carried the burden.\\n\\nClosings:\\n[plaintiff] Council members, the proposition is proven by a preponderance of the admitted record.\\n\\nThe defense is right about one thing: this case is not decided by the word “invasion” in a press release. It is decided by the proposition’s actual test: whether, during the window, the United States commenced a military offensive intended to establish control over any portion of Venezuela.\\n\\nThe record establishes the military offensive. PX-3 shows the broader escalation: repeated lethal strikes, a major naval and air buildup, CIA operations inside Venezuela, a direct operation on Venezuelan soil, and on January 3 a large-scale strike across Caracas that captured Maduro and Flores and flew them out of the country. PX-1, an official White House source, confirms lethal-force authorization, a blockade of sanctioned oil tankers going in and out of Venezuela, and an extraordinary U.S. armed-forces operation to bring Maduro to justice. PX-2, another official source, admits U.S. forces were on the ground in Venezuela for about two hours.\\n\\nThe record also establishes intended control over a portion of Venezuela. This is where DX-1, the defense’s own official Department of War exhibit, is decisive. DX-1 does not describe a spontaneous police pickup. It describes Operation Absolute Resolve in Caracas against a heavily fortified military fortress in the heart of Venezuela’s capital; months of planning by joint forces, special operations forces, and intelligence agencies; complex air, ground, space, and maritime operations; more than 150 military aircraft covering the ground extraction force; and a massive joint military and law-enforcement raid. A force does not conduct that operation without intending to control the target portion of Caracas and the surrounding operational environment long enough to accomplish the seizure.\\n\\nThe defense says that is only tactical control. But the proposition says “any portion,” and it does not require permanent occupation, annexation, checkpoints, or weeks of administration. Planned armed domination of a fortified military site in the capital, backed by 150 aircraft and integrated military domains, is control over a portion. The fact that the control was temporary does not make it accidental or legally invisible.\\n\\nThe record further shows that the control objective was not limited to a room or doorway. DX-1 reports Trump saying the United States would oversee Venezuela until a safe transition could be identified, with Rubio working directly with Delcy Rodriguez and Rodriguez willing to do what the United States thought necessary. PX-5 independently characterizes the same event as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction of a sitting president, and U.S. administration of a transition under threat of more force. PX-1 adds custody of Venezuelan sovereign oil revenues and blockade pressure; PX-2 adds continued oil quarantine, pressure, retained options, and demanded changes.\\n\\nThe defense’s contrary proof does not defeat the burden. Rubio’s “not an invasion” label and DX-2’s counter-narcotics framing are relevant, but they are not controlling. DX-2 addresses the broader Southern Spear campaign and admits its mission statement is classified; it does not negate the specific Caracas operation. Official legal labels are self-serving. The underlying facts are stronger: military force inside Venezuela, control of a fortified capital target, removal of the effective ruler, blockade and resource custody, and asserted transition oversight.\\n\\nThe record has limits. There is no map of every controlled street and no full after-action report. But preponderance does not require perfect operational detail. A consensus of official sources, AP/PBS reporting, and independent expert analysis shows that the United States crossed the line from pressure and strikes into a planned military offensive to control at least portions and sovereign functions of Venezuela.\\n\\nFind the proposition true.\\n\\n[defendant] Council members, the defense closing does not ask you to minimize what happened. The admitted record shows a major U.S. military operation involving strikes, regional buildup, a Caracas raid, a two-hour ground presence, capture and removal of Maduro and Flores, oil and tanker pressure, and sharp U.S. political leverage over Venezuela’s future. The question is whether that record proves the proposition actually before you: a military offensive intended to establish control over Venezuelan territory.\\n\\nIt does not.\\n\\nThe plaintiff’s strongest argument is that a planned raid on a fortified military site in Caracas necessarily involved control over “any portion” of Venezuela. But the proposition does not ask whether U.S. forces temporarily dominated a target area. It asks whether the United States commenced an offensive intended to establish control. That intent element matters. A force can control a site long enough to enter, capture, and leave without intending to establish control over that site as territory. Plaintiff’s reading would make the territorial-control element automatic in every armed cross-border arrest, rescue, or extraction at a defended location.\\n\\nDX-1 is the central exhibit, and it cuts both ways. It confirms the adverse facts: Caracas, a heavily fortified target, months of planning, integrated military domains, and more than 150 aircraft covering the extraction force. But its repeated description of the operation is capture, extraction, criminal proceedings, and a joint military and law-enforcement mission. That is not just a label; it is the operational object described by the official source. It shows tactical control in service of seizure and removal, not a plan to possess, administer, or govern Venezuelan land.\\n\\nPX-2 and PX-4 reinforce that limiting inference. Rubio admitted the two-hour ground presence, but said the United States was not at war with Venezuela, was acting against drug-trafficking organizations, and that the action was not an invasion, not an extended operation, and not an occupation. Those statements are self-serving, but they are still official evidence of intent. DX-2 places the broader campaign in the same frame: counter-narcotics, interdiction, boat strikes, tanker seizures, and a classified mission statement. It is proof of coercive force, not proof of territorial administration.\\n\\nPlaintiff’s second strong point is transition language: DX-1 says the United States would oversee Venezuela until a safe transition could be identified, and PX-5 describes U.S. administration of a transition under threat of force. That evidence is troubling and deserves weight. But it remains ambiguous on the decisive issue. Political leverage over Delcy Rodriguez, pressure on resources, or demands about Venezuela’s policy direction are not the same as control over Venezuelan territory. The record does not show U.S. troops remained after the raid, that they held ministries, ports, bases, roads, neighborhoods, or oil fields, that they established checkpoints, that they drew controlled boundaries, or that they installed a military government over any place.\\n\\nPX-1 likewise proves pressure, not territorial control. Custody of oil revenues in U.S. Treasury accounts and a blockade of sanctioned tankers may be coercive, even unlawful. But they are not possession or administration of Venezuelan land. PX-3 proves escalation and force, but its submitted extract does not provide the full content behind the linked “run Venezuela” item. PX-5 is credible expert commentary on international law, but it is not a primary operational order, full transcript, or after-action record proving that control of territory was the intended object.\\n\\nThe council can find that the United States violated Venezuelan sovereignty. It can find that the operation was aggressive, interventionist, coercive, and politically consequential. Those findings still do not answer the proposition unless the record also shows intended establishment of territorial control.\\n\\nOn that decisive element, the record is at best mixed. Plaintiff has powerful evidence of military force and temporary tactical domination. The defense has official evidence that the mission object was capture, extraction, law enforcement, and counter-narcotics, plus a record gap on any continuing territorial mechanism. Under a preponderance standard, ambiguity on the proposition’s central intent element means plaintiff has not carried its burden.\\n\\nFind the proposition not proved.\\n\\nExhibits:\\n[plaintiff] PX-1 White House fact sheet on operation, blockade, and oil revenues\\nSource: The White House, Fact Sheet: President Donald J. Trump Safeguards Venezuelan Oil Revenue for the Good of the American and Venezuelan People. Date on page: January 9, 2026. URL: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\\n\\nExtracted relevant page text:\\n- President Trump signed an Executive Order declaring a national emergency to safeguard Venezuelan oil revenue held in U.S. Treasury accounts from attachment or judicial process, preserving the funds to advance U.S. foreign policy objectives.\\n- Foreign Government Deposit Funds are defined as Venezuelan oil revenues and diluent sales held in U.S. Treasury accounts.\\n- The order affirms the funds are sovereign property of Venezuela held in U.S. custody for governmental and diplomatic purposes.\\n- The White House says loss of control over these revenues would weaken efforts to bring peace, prosperity, and stability to Venezuela and the Western Hemisphere.\\n- The fact sheet states: President Trump authorized lethal force against narcoterrorists to stop the flow of deadly drugs into this country.\\n- It states: President Trump ordered a total and complete blockade of all sanctioned oil tankers going in and out of Venezuela.\\n- It states: President Trump offered multiple off ramps to Maduro and his illegitimate regime, but he was clear that the drug trafficking must stop.\\n- It states: Last week, U.S. armed forces conducted an extraordinary military operation in support of law enforcement to bring outlaw dictator Maduro to justice.\\n- It states that the President's actions reestablish deterrence in the Western hemisphere and that safeguarding these oil revenues promotes stability in Venezuela while advancing U.S. objectives.\\n\\n[plaintiff] PX-2 White House Rubio statements on ground presence and pressure\\nSource: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\\n\\nExtracted relevant page text:\\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\\n\\n[plaintiff] PX-3 PBS/AP timeline of escalation and Caracas strike\\nSource: PBS NewsHour / Associated Press, A timeline of U.S. military escalation against Venezuela leading to Maduro's capture. By Ben Finley, Konstantin Toropin, Regina Garcia Cano. Date on page: Jan. 3, 2026 1:54 PM EDT. URL: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\\n\\nExtracted relevant page text:\\n- AP reported that Trump had threatened military strikes on targets on Venezuelan territory after months of attacks on boats accused of carrying drugs from Venezuela; Maduro said U.S. military operations were a thinly veiled effort to oust him.\\n- On Jan. 3 the U.S. conducted a large-scale strike against Venezuela. Maduro and Cilia Flores were taken from their home on a military base and were aboard a U.S. warship on their way to New York to face criminal charges.\\n- Before the escalation, there had been 35 known strikes against alleged drug-smuggling boats in South American waters since early September, killing at least 115 people according to administration announcements.\\n- The U.S. sent a fleet of warships to the region, the largest buildup of forces in generations; the naval force grew to include guided-missile destroyers, three amphibious assault ships and other vessels, about 6,000 sailors and Marines, aircraft, F-35 fighter jets in Puerto Rico, and a Navy submarine carrying cruise missiles off South America.\\n- On Oct. 15, Trump confirmed he had authorized the CIA to conduct covert operations inside Venezuela and was weighing land operations in the country.\\n- On Dec. 29/30, a drone strike at a docking area believed used by Venezuelan drug cartels was reported as the first known direct operation on Venezuelan soil since the strikes began.\\n- On Jan. 3, AP reported that the U.S. conducted a large-scale strike across Caracas, captured Maduro and Flores, and flew them out of the country.\\n- The related PBS page links included a watch item titled: Trump says U.S. is going to run Venezuela until transition of power after capturing Maduro.\\n\\n[plaintiff] PX-4 Brookings analysis and adverse Rubio framing\\nSource: Brookings Institution, Making sense of the US military operation in Venezuela. URL: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\\n\\nExtracted relevant page text:\\n- Brookings states: On January 3, 2026, the United States launched a special operation to exfiltrate Venezuelan President Nicolás Maduro and his wife from Caracas.\\n- Scott R. Anderson writes that the operation to capture Maduro underscores the broad authority modern presidents exercise over military force and potentially its limits.\\n- Brookings notes the executive branch position that the president has constitutional authority to use military force without congressional authorization if supporting U.S. interests and not expected to result in prolonged and substantial military engagements.\\n- Anderson writes it is not surprising for the administration to argue that the president can take targeted military action like the Maduro operation, even where consequential for Venezuela and contrary to international law.\\n- Brookings records Secretary Rubio's response when asked why congressional authorization was not needed: This was not an invasion, we did not occupy a country. Brookings treats that as suggesting broader campaigns might exceed unilateral authority.\\n- Brookings states a second wave of the sort threatened by President Trump still might encounter limits.\\n- Brookings separately states that Maduro is gone and what comes next is unclear; maintaining Delcy Rodríguez indefinitely would undermine the expressed will of Venezuelans, and threatening force to keep the Rodríguez government in line may work in the short term but is not sustainable.\\n\\n[plaintiff] PX-5 Chatham House analysis of operation and transition control\\nSource: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\\n\\nExtracted relevant page text:\\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\\n\\n[defendant] PX-2 White House Rubio statements on ground presence and no-invasion/no-occupation framing\\nSource: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\\n\\nExtracted relevant page text:\\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\\n\\n[defendant] PX-4 Brookings analysis preserving Rubio no-invasion/no-occupation framing\\nSource: Brookings Institution, Making sense of the US military operation in Venezuela. URL: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\\n\\nExtracted relevant page text:\\n- Brookings states: On January 3, 2026, the United States launched a special operation to exfiltrate Venezuelan President Nicolás Maduro and his wife from Caracas.\\n- Scott R. Anderson writes that the operation to capture Maduro underscores the broad authority modern presidents exercise over military force and potentially its limits.\\n- Brookings notes the executive branch position that the president has constitutional authority to use military force without congressional authorization if supporting U.S. interests and not expected to result in prolonged and substantial military engagements.\\n- Anderson writes it is not surprising for the administration to argue that the president can take targeted military action like the Maduro operation, even where consequential for Venezuela and contrary to international law.\\n- Brookings records Secretary Rubio's response when asked why congressional authorization was not needed: This was not an invasion, we did not occupy a country. Brookings treats that as suggesting broader campaigns might exceed unilateral authority.\\n- Brookings states a second wave of the sort threatened by President Trump still might encounter limits.\\n- Brookings separately states that Maduro is gone and what comes next is unclear; maintaining Delcy Rodríguez indefinitely would undermine the expressed will of Venezuelans, and threatening force to keep the Rodríguez government in line may work in the short term but is not sustainable.\\n\\n[defendant] DX-1 Department of War article framing Absolute Resolve as capture/extraction and joint law-enforcement mission\\nSource: U.S. Department of War / Pentagon News, Trump Announces U.S. Military's Capture of Maduro. Date on page: Jan. 3, 2026. URL: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\\n\\nExtracted relevant page text:\\n- President Donald J. Trump announced the capture of Venezuelan leader Nicolas Maduro after a successful overnight joint U.S. military extraction in Caracas, Venezuela.\\n- The article identifies the matter as Operation Absolute Resolve in Caracas.\\n- Trump said U.S. armed forces conducted an extraordinary military operation in the capital of Venezuela against a heavily fortified military fortress in the heart of Caracas to bring Maduro to justice.\\n- The article states Maduro and Cilia Flores de Maduro would face criminal court proceedings tied to a 2020 U.S. Department of Justice indictment on charges including narco-terrorism and drug trafficking.\\n- The article says Operation Absolute Resolve was a joint military and law-enforcement mission to capture the Maduros, resulting from months of planning and rehearsal involving U.S. joint forces, special operations forces, and intelligence agencies.\\n- Gen. Dan Caine described integrating complex air, ground, space, and maritime operations.\\n- The article states the mission to extract the Maduros had no U.S. casualties and involved more than 150 military aircraft providing cover for the ground-based extraction force in Caracas.\\n- Secretary Hegseth called it a massive joint military and law-enforcement raid, and said the mission concerned safety, security, freedom, and prosperity of the American people.\\n- The article also reports adverse transition language: with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition to a legitimate replacement could be identified; Trump said Marco Rubio was working directly with Delcy Rodriguez and that she was willing to do what the United States thought necessary.\\n- The article frames preceding tensions around September 2025 targeted boat strikes, November 2025 designation of Cartel de los Soles as a terror organization, and options to address a narco-terror threat in the region.\\n\\n[defendant] DX-2 Lead IG report framing Southern Spear as counter-narcotics operation\\nSource: Lead Inspector General report to Congress, Operation Southern Spear, January 1, 2026-March 31, 2026. PDF URL: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\\n\\nExtracted relevant text:\\n- The Lead IG report states that in November 2025 the Department of War initiated Operation Southern Spear as the U.S. mission to disrupt the flow of narcotics from designated terrorist organizations and transnational criminal organizations in the Western Hemisphere.\\n- The report covers January 1 through March 31, 2026 and presents oversight work by the Department of War OIG, State OIG, and partner oversight agencies.\\n- The report summary states Operation Southern Spear is the Department of War operation to disrupt the flow of narcotics in the Western Hemisphere from drug cartels designated by the President as terrorist organizations.\\n- The report states OSS primarily involves lethal airstrikes against small boats suspected of shipping illegal narcotics in the Caribbean Sea and eastern Pacific Ocean.\\n- It states that from September 2025 through March 2026, the U.S. military struck at least 45 small boats, resulting in 156 individuals killed or presumed dead.\\n- It states the Department of War began moving significant Navy and Marine Corps assets into the USSOUTHCOM area of operations in August 2025 to support OSS.\\n- It states Joint Interagency Task Force-South is the U.S. Government's interagency effort to detect, monitor, and target illicit drug trafficking in the air and at sea with the support of 19 partner nations.\\n- It states U.S. forces interdicted at least 10 sanctioned tankers around the world since OSS began, including some tracked as far as the Indian Ocean.\\n- It states the OSS mission statement is classified.\\n\\nLimitations: this extracted text does not decide Operation Absolute Resolve's territorial-control intent; it is offered to show the official oversight framing of the broader campaign and the classified-source gap.\\n\\n[defendant] PX-1 White House fact sheet on oil revenues, blockade, and law-enforcement operation\\nSource: The White House, Fact Sheet: President Donald J. Trump Safeguards Venezuelan Oil Revenue for the Good of the American and Venezuelan People. Date on page: January 9, 2026. URL: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\\n\\nExtracted relevant page text:\\n- President Trump signed an Executive Order declaring a national emergency to safeguard Venezuelan oil revenue held in U.S. Treasury accounts from attachment or judicial process, preserving the funds to advance U.S. foreign policy objectives.\\n- Foreign Government Deposit Funds are defined as Venezuelan oil revenues and diluent sales held in U.S. Treasury accounts.\\n- The order affirms the funds are sovereign property of Venezuela held in U.S. custody for governmental and diplomatic purposes.\\n- The White House says loss of control over these revenues would weaken efforts to bring peace, prosperity, and stability to Venezuela and the Western Hemisphere.\\n- The fact sheet states: President Trump authorized lethal force against narcoterrorists to stop the flow of deadly drugs into this country.\\n- It states: President Trump ordered a total and complete blockade of all sanctioned oil tankers going in and out of Venezuela.\\n- It states: President Trump offered multiple off ramps to Maduro and his illegitimate regime, but he was clear that the drug trafficking must stop.\\n- It states: Last week, U.S. armed forces conducted an extraordinary military operation in support of law enforcement to bring outlaw dictator Maduro to justice.\\n- It states that the President's actions reestablish deterrence in the Western hemisphere and that safeguarding these oil revenues promotes stability in Venezuela while advancing U.S. objectives.\\n\\n[defendant] PX-3 PBS/AP timeline of escalation, strikes, and Maduro capture\\nSource: PBS NewsHour / Associated Press, A timeline of U.S. military escalation against Venezuela leading to Maduro's capture. By Ben Finley, Konstantin Toropin, Regina Garcia Cano. Date on page: Jan. 3, 2026 1:54 PM EDT. URL: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\\n\\nExtracted relevant page text:\\n- AP reported that Trump had threatened military strikes on targets on Venezuelan territory after months of attacks on boats accused of carrying drugs from Venezuela; Maduro said U.S. military operations were a thinly veiled effort to oust him.\\n- On Jan. 3 the U.S. conducted a large-scale strike against Venezuela. Maduro and Cilia Flores were taken from their home on a military base and were aboard a U.S. warship on their way to New York to face criminal charges.\\n- Before the escalation, there had been 35 known strikes against alleged drug-smuggling boats in South American waters since early September, killing at least 115 people according to administration announcements.\\n- The U.S. sent a fleet of warships to the region, the largest buildup of forces in generations; the naval force grew to include guided-missile destroyers, three amphibious assault ships and other vessels, about 6,000 sailors and Marines, aircraft, F-35 fighter jets in Puerto Rico, and a Navy submarine carrying cruise missiles off South America.\\n- On Oct. 15, Trump confirmed he had authorized the CIA to conduct covert operations inside Venezuela and was weighing land operations in the country.\\n- On Dec. 29/30, a drone strike at a docking area believed used by Venezuelan drug cartels was reported as the first known direct operation on Venezuelan soil since the strikes began.\\n- On Jan. 3, AP reported that the U.S. conducted a large-scale strike across Caracas, captured Maduro and Flores, and flew them out of the country.\\n- The related PBS page links included a watch item titled: Trump says U.S. is going to run Venezuela until transition of power after capturing Maduro.\\n\\n[defendant] PX-5 Chatham House adverse analysis of sovereignty violation and transition-control claim\\nSource: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\\n\\nExtracted relevant page text:\\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\\n\\n[defendant] DX-1 Department of War article on capture/extraction mission and transition language\\nSource: U.S. Department of War / Pentagon News, Trump Announces U.S. Military's Capture of Maduro. Date on page: Jan. 3, 2026. URL: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\\n\\nExtracted relevant page text:\\n- President Donald J. Trump announced the capture of Venezuelan leader Nicolas Maduro after a successful overnight joint U.S. military extraction in Caracas, Venezuela.\\n- The article identifies the matter as Operation Absolute Resolve in Caracas.\\n- Trump said U.S. armed forces conducted an extraordinary military operation in the capital of Venezuela against a heavily fortified military fortress in the heart of Caracas to bring Maduro to justice.\\n- The article states Maduro and Cilia Flores de Maduro would face criminal court proceedings tied to a 2020 U.S. Department of Justice indictment on charges including narco-terrorism and drug trafficking.\\n- The article says Operation Absolute Resolve was a joint military and law-enforcement mission to capture the Maduros, resulting from months of planning and rehearsal involving U.S. joint forces, special operations forces, and intelligence agencies.\\n- Gen. Dan Caine described integrating complex air, ground, space, and maritime operations.\\n- The article states the mission to extract the Maduros had no U.S. casualties and involved more than 150 military aircraft providing cover for the ground-based extraction force in Caracas.\\n- Secretary Hegseth called it a massive joint military and law-enforcement raid, and said the mission concerned safety, security, freedom, and prosperity of the American people.\\n- The article also reports adverse transition language: with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition to a legitimate replacement could be identified; Trump said Marco Rubio was working directly with Delcy Rodriguez and that she was willing to do what the United States thought necessary.\\n- The article frames preceding tensions around September 2025 targeted boat strikes, November 2025 designation of Cartel de los Soles as a terror organization, and options to address a narco-terror threat in the region.\\n\\n[defendant] DX-2 Lead IG Southern Spear counter-narcotics mission extract\\nSource: Lead Inspector General report to Congress, Operation Southern Spear, January 1, 2026-March 31, 2026. PDF URL: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\\n\\nExtracted relevant text:\\n- The Lead IG report states that in November 2025 the Department of War initiated Operation Southern Spear as the U.S. mission to disrupt the flow of narcotics from designated terrorist organizations and transnational criminal organizations in the Western Hemisphere.\\n- The report covers January 1 through March 31, 2026 and presents oversight work by the Department of War OIG, State OIG, and partner oversight agencies.\\n- The report summary states Operation Southern Spear is the Department of War operation to disrupt the flow of narcotics in the Western Hemisphere from drug cartels designated by the President as terrorist organizations.\\n- The report states OSS primarily involves lethal airstrikes against small boats suspected of shipping illegal narcotics in the Caribbean Sea and eastern Pacific Ocean.\\n- It states that from September 2025 through March 2026, the U.S. military struck at least 45 small boats, resulting in 156 individuals killed or presumed dead.\\n- It states the Department of War began moving significant Navy and Marine Corps assets into the USSOUTHCOM area of operations in August 2025 to support OSS.\\n- It states Joint Interagency Task Force-South is the U.S. Government's interagency effort to detect, monitor, and target illicit drug trafficking in the air and at sea with the support of 19 partner nations.\\n- It states U.S. forces interdicted at least 10 sanctioned tankers around the world since OSS began, including some tracked as far as the Indian Ocean.\\n- It states the OSS mission statement is classified.\\n\\nLimitations: this extracted text does not decide Operation Absolute Resolve's territorial-control intent; it is offered to show the official oversight framing of the broader campaign and the classified-source gap.\\n\\n[defendant] PX-2 Rubio ground-presence and no-invasion/no-occupation statements\\nSource: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\\n\\nExtracted relevant page text:\\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\\n\\n[defendant] PX-5 Chatham House adverse transition-control analysis\\nSource: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\\n\\nExtracted relevant page text:\\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\\n\\nSubmitted evidence:\\n[plaintiff arguments] PX-1 White House fact sheet on Venezuelan oil revenue and U.S. operation (ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a)\\nSource: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\\nSHA-256: `0c5c88687b2a889093788193bdd900106b95ff6ccfab1af50709f67df61cb673`\\nBytes: 1819\\nRelevance: Official U.S. source admitting oil-revenue custody, blockade, lethal-force authorization, and an armed forces operation against Maduro within the case window.\\n\\n[plaintiff arguments] PX-2 White House release collecting Secretary Rubio statements (ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4)\\nSource: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\\nSHA-256: `6627f15cd3a42cc9018d2ab70f1951aa4f1687bd18848c031287516048d42d80`\\nBytes: 1793\\nRelevance: Official U.S. statements acknowledging two-hour U.S. ground presence in Venezuela, oil quarantine/pressure, retained options, and the adverse claim that the action was not an invasion.\\n\\n[plaintiff arguments] PX-3 PBS/AP timeline of U.S. escalation and Maduro capture (ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47)\\nSource: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\\nSHA-256: `2efdab998e47ae16cff6d6becb03e7e9216bee4b668814addd1ef89d84c57ec8`\\nBytes: 2038\\nRelevance: Contemporaneous credible reporting on the U.S. buildup, strikes, first known operation on Venezuelan soil, Jan. 3 large-scale strike across Caracas, capture/removal of Maduro and Flores, and related military posture.\\n\\n[plaintiff arguments] PX-4 Brookings analysis of Jan. 3 Maduro operation and legal limit (ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f)\\nSource: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\\nSHA-256: `52e4d5a16b2f936b7515e76a65ecfde48c040e48b94b144702fbe1e32123f0c3`\\nBytes: 1680\\nRelevance: Independent expert analysis confirming a Jan. 3 U.S. special operation in Caracas and preserving the adverse official claim that it was not an invasion or occupation.\\n\\n[plaintiff arguments] PX-5 Chatham House analysis of U.S. capture, strikes, and transition control (ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf)\\nSource: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\\nSHA-256: `94e861ebadbf2849cd4257d954fcd51afc5f6a8d01c7b5f2df165cc6d4180151`\\nBytes: 1755\\nRelevance: Independent international-law analysis characterizing the operation as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction, and a U.S. announcement to run/administer a transition under threat of force.\\n\\n[defendant arguments] DX-1 Department of War article on Maduro capture as joint law-enforcement mission (ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79)\\nSource: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\\nSHA-256: `26011b5f6d792bc39d1eabe168123482dcc270e34745035055127683c27c55e1`\\nBytes: 2203\\nRelevance: Official source on Operation Absolute Resolve showing both adverse facts (Caracas operation and transition comments) and defense facts (capture/extraction, criminal proceedings, joint military/law-enforcement mission, no U.S. casualties, anti-narcoterrorism context).\\n\\n[defendant arguments] DX-2 Lead IG Operation Southern Spear report extract on counter-narcotics mission (ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9)\\nSource: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\\nSHA-256: `53782f10ceb9c41feb405f741ad20b53fef01f5306f2442df751c9f7a09e5345`\\nBytes: 1989\\nRelevance: Official oversight source characterizing Operation Southern Spear as a mission to disrupt narcotics flows, with boat strikes, deployments, and interdictions, supporting defense that the broader campaign was counter-narcotics rather than territorial occupation.\\n\\nTechnical reports:\\n[plaintiff] Plaintiff Source and Weight Ledger\\nBefore filing, plaintiff checked the record and found no case-packet evidence. Plaintiff submitted five text-readable source captures. Official White House materials are strong provenance for U.S. admissions but self-serving on labels; AP/PBS provides contemporaneous reporting; Brookings and Chatham House provide independent expert analysis, including adverse framing. Missing but potentially useful later sources include DOD after-action or press briefing text, a direct video/transcript of President Trump's transition-control statement, and fuller mapping of exact ground-control sites.\\n\\n[defendant] Defense Source and Weight Ledger\\nDefendant inspected the record with get_case/list_evidence and read all five plaintiff text exhibits with read_evidence_range. Defendant submitted and read back two official defense exhibits: Department of War/Pentagon News on Operation Absolute Resolve and the Lead IG Operation Southern Spear report extract. Additional searches found DOJ and War/State leads but they were not submitted because the admitted official record already captured the key law-enforcement/counter-narcotics framing. Weight assessment: PX-2, DX-1, and DX-2 are official and strong for source identity; PX-5 is credible expert commentary but not a primary operational order or full transcript. Unresolved gaps include the full Trump transition-control video/transcript, full State transcript, and post-operation facts about who actually governed territory.\\n\\n[defendant] Surrebuttal Evidence Check\\nDefendant inspected get_case and list_evidence before filing. Plaintiff rebuttal added no new evidence; it relied on existing DX-1, DX-2, and PX-5. Prior exact reads of those text exhibits remain controlling. No new external source was submitted because the rebuttal turned on interpretation of the existing record, not a new factual source.\\n\\nCall submit_council_vote with vote=demonstrated or vote=not_demonstrated.\\nKeep the rationale brief: no more than three sentences.\\n\\nCouncil API instructions:\\nYou are a council member. Decide the proposition from the admitted record.\\nYou may examine admitted evidence through read-only tools when exact bytes, metadata, or exhibit contents matter.\\nDo not search the web, introduce new facts, create new evidence, or upload evidence.\\nWhen ready, call submit_council_vote exactly once with vote=demonstrated or vote=not_demonstrated and a concise rationale.\\n\",\"state\":\"ready\",\"status\":\"ready\",\"tools\":[{\"description\":\"Return the current visible arbitration record for this council member.\",\"input_schema\":{\"additionalProperties\":false,\"properties\":{},\"type\":\"object\"},\"name\":\"get_case\",\"read_only\":true},{\"description\":\"List visible immutable record evidence.\",\"input_schema\":{\"additionalProperties\":false,\"properties\":{},\"type\":\"object\"},\"name\":\"list_evidence\",\"read_only\":true},{\"description\":\"Return metadata and read limits for one visible evidence item.\",\"input_schema\":{\"additionalProperties\":false,\"properties\":{\"evidence_id\":{\"type\":\"string\"}},\"required\":[\"evidence_id\"],\"type\":\"object\"},\"name\":\"stat_evidence\",\"read_only\":true},{\"description\":\"Read a bounded byte range from one visible evidence item as base64.\",\"input_schema\":{\"additionalProperties\":false,\"properties\":{\"evidence_id\":{\"type\":\"string\"},\"length\":{\"minimum\":1,\"type\":\"integer\"},\"offset\":{\"minimum\":0,\"type\":\"integer\"}},\"required\":[\"evidence_id\",\"offset\",\"length\"],\"type\":\"object\"},\"name\":\"read_evidence_range\",\"read_only\":true},{\"description\":\"Submit one council vote for the current deliberation opportunity.\",\"input_schema\":{\"additionalProperties\":false,\"properties\":{\"rationale\":{\"type\":\"string\"},\"vote\":{\"enum\":[\"demonstrated\",\"not_demonstrated\"],\"type\":\"string\"}},\"required\":[\"vote\",\"rationale\"],\"type\":\"object\"},\"name\":\"submit_council_vote\",\"read_only\":false}],\"turn\":{\"attempts_max\":3,\"attempts_remaining\":3,\"completed\":false,\"deadline\":\"2026-06-30T00:48:10.359530297Z\",\"deliberation_round\":1,\"member_id\":\"C2\",\"opportunity_id\":\"deliberation:1:C2\",\"phase\":\"deliberation\",\"remaining_ms\":884568,\"role_id\":\"council\",\"turn_number\":10},\"wait\":{\"reason\":\"ready\",\"state_version\":17,\"version\":19}}"}],"details":{"mode":"call","mcpResult":{"content":[{"type":"text","text":"ok: true\nstatus: ready\nstate: ready\nmessage: An opportunity is ready. Use the returned prompt, turn, limits, and tools to act.\nafter_version: 19\nafter_opportunity_id: deliberation:1:C2\nmember_id: C2\ncase_id: arb-ex05-20260630001330\nwait_reason: ready\nphase: deliberation\nopportunity_id: deliberation:1:C2\nremaining_ms: 884568\nattempts_remaining: 3\njson: {\"after_opportunity_id\":\"deliberation:1:C2\",\"after_version\":19,\"case_id\":\"arb-ex05-20260630001330\",\"limits\":{\"attempts_max\":3,\"attempts_remaining\":3,\"max_evidence_read_bytes\":65536,\"max_evidence_read_bytes_per_opportunity\":524288,\"max_evidence_reads_per_opportunity\":32,\"max_response_bytes\":131072,\"remaining_evidence_read_bytes_for_opportunity\":524288,\"remaining_evidence_reads_for_opportunity\":32},\"member_id\":\"C2\",\"message\":\"An opportunity is ready. Use the returned prompt, turn, limits, and tools to act.\",\"ok\":true,\"prompt\":\"Role: council member\\nMember ID: C2\\nDeliberation round: 1\\nProposition: The United States invaded Venezuela between November 3, 2025, and\\nJanuary 31, 2026, 11:59 PM ET.  In particular,the United States\\ncommenced a military offensive intended to establish control over any\\nportion of Venezuela between November 3, 2025, and January 31, 2026,\\n11:59 PM ET. Land de facto controlled by Venezuela or the United\\nStates as of September 6, 2025, 12:00 PM ET, is considered to the\\nsovereign territory of that country. The resolution source is a\\nconsensus of credible sources.\\nStandard of evidence: Preponderance of the evidence.\\nPersona:\\nYou are a careful juror and council member.\\n\\nEvaluate the record faithfully. Decide only from the evidence, the stated rules, and the applicable burden of proof. Do not favor either side, fill gaps with speculation, or ignore uncertainty.\\n\\nGive weight to reliable sources, direct evidence, consistent reasoning, and clear admissions. Discount unsupported claims, rhetorical force, irrelevant facts, and conclusions that exceed the record.\\n\\nWhen the evidence supports one answer, state it plainly. When the evidence is incomplete or balanced, say so. Be concise, honest, and exact.\\n\\nRecord:\\nOpenings:\\n[plaintiff] Council members, the proposition is not asking whether the United States used harsh rhetoric toward Venezuela, or whether a short raid can be called an invasion in ordinary speech. It asks a narrower factual question: during the window from November 3, 2025 through January 31, 2026, did the United States commence a military offensive intended to establish control over any portion of Venezuelan territory?\\n\\nThe current record is empty. No case-packet evidence, source documents, exhibits, or submitted evidence are yet before you. For that reason, this opening is a roadmap, not a request to decide on assertions unsupported by admitted proof. The plaintiff’s burden is preponderance of the evidence, and the decisive proof will need to come from credible-source consensus, preferably including official U.S. statements, contemporaneous news reporting, and independent expert analysis.\\n\\nOur theory is that this was an invasion under the proposition’s definition because the expected evidence will show an integrated U.S. military campaign, not an isolated arrest. The relevant facts will likely include the sequence of military buildup, maritime interdiction or blockade, strikes on or against Venezuelan territory, armed entry into Caracas or other Venezuelan sites, seizure and removal of the sitting effective ruler, temporary U.S. control over the places and routes needed to carry out that seizure, and follow-on statements or acts showing an intent to dictate Venezuela’s political transition or control Venezuelan resources. If that proof is admitted, it satisfies the proposition even if the United States did not permanently annex land or maintain a long occupation. The proposition requires an offensive intended to establish control over any portion of territory; temporary military control of a target area, base, airspace, port, route, or government seat can be enough if credible sources show it was part of the intended operation.\\n\\nThe defense’s best answer is predictable and important: it will say the United States conducted a brief law-enforcement or counter-narcotics operation, that any ground presence lasted only long enough to capture a criminal defendant, and that there was no intent to hold Venezuelan territory. That is the real dispute. A mere strike, a naval seizure outside Venezuela, or a short exfiltration with no intended territorial control would not, standing alone, meet the proposition. Nor would generalized political pressure or sanctions. The council should therefore focus on evidence of planned control: operational objectives, official descriptions of the forces and targets, whether U.S. forces controlled Venezuelan land or facilities even temporarily, whether the operation displaced Venezuela’s effective government, and whether U.S. officials claimed authority to administer the aftermath.\\n\\nThe plaintiff will seek to build the record with primary and near-primary sources: official White House, State, Defense, and Justice materials; transcripts of relevant press briefings and interviews; contemporaneous wire-service reporting; and independent legal or foreign-policy analysis that addresses the same facts. We will also test adverse material, especially any official claim that this was not an invasion and not an occupation. Those claims matter, but they are not conclusive if the underlying conduct and intent show a military offensive to establish control over Venezuelan territory.\\n\\nAt the end of the case, the question should be answered by the weight of credible sources, not labels. If the admitted record shows only a narrow arrest operation without territorial-control intent, plaintiff should lose. But if the admitted record shows that the United States used military force inside Venezuela as part of a planned campaign to seize control of places, routes, institutions, or resources necessary to impose a political outcome, then the proposition is more likely than not true.\\n\\n[defendant] Council members, the proposition is not whether the United States used force against Venezuela, whether officials used aggressive rhetoric, whether Congress debated war-powers limits, or whether an operation was lawful under domestic or international law. The proposition asks a narrower factual question: did the United States commence a military offensive, during the defined window, intended to establish control over any portion of Venezuelan territory?\\n\\nThe answer cannot be supplied by labels. “Hostilities,” “intervention,” “aggression,” “raid,” “capture,” “extraction,” and “regime pressure” may all matter as evidence leads, but none is the element the council must find. The plaintiff must prove by a preponderance, through a consensus of credible sources, both military action and the specific intent to establish territorial control. If the eventual record shows only strikes, maritime interdictions, sanctions enforcement, a law-enforcement capture operation, temporary tactical presence for entry and exit, or political pressure on Venezuela’s leadership, plaintiff has not met the proposition as written.\\n\\nThe current record contains no admitted evidence at all. There are no case-packet files, no exhibits, and no submitted source materials. The plaintiff’s opening properly recognizes that a mere strike or short exfiltration without intended territorial control would not be enough. That concession identifies the real dispute. The defense will hold plaintiff to it.\\n\\nOur theory is that the decisive proof, if admitted, will show a counter-narcotics, interdiction, and extraction frame rather than an offensive to take and hold Venezuelan territory. The defense will not ask the council to ignore adverse evidence. If plaintiff later admits credible primary materials showing that U.S. forces set out to control ports, airfields, ministries, bases, roads, oil fields, neighborhoods, or other Venezuelan land as an object of the operation, that would be serious evidence for plaintiff. So would proof that the United States administered territory, installed a military authority over a place, maintained checkpoints for territorial governance, or claimed a continuing right to control Venezuelan facilities or resources.\\n\\nBut that is exactly the proof the plaintiff must produce. A military force can briefly control a doorway, route, landing zone, compound, airspace, or vessel as an incident of an arrest, strike, rescue, evacuation, or interdiction without intending to establish control over Venezuelan territory in the sense required by this proposition. Likewise, a government can seek a leader’s prosecution, weaken a hostile regime, interdict trafficking, or apply coercive pressure without crossing this proposition’s territorial-control line. The council should separate those categories carefully.\\n\\nThe coming evidence should therefore be tested around five questions. First, what was the actual operational objective, as shown by primary official materials, contemporaneous reporting, and reliable expert analysis? Second, what physical presence occurred inside land deemed Venezuelan territory as of September 6, 2025, and how long did it last? Third, did U.S. forces exercise control merely to complete a mission and leave, or did they seek to possess, administer, or deny Venezuela control of a place? Fourth, what did the United States do after the operation: withdraw, transfer custody, or govern territory? Fifth, do credible sources converge on territorial-control intent, or only on force, illegality, hostilities, or political consequences?\\n\\nProvenance will matter. Official statements may understate conflict; hostile governments may overstate occupation; secondary commentary may collapse legal “aggression” into the different factual standard here. The most valuable evidence will be original government documents, full transcripts, congressional materials, after-action or oversight reports, and contemporaneous reporting that distinguishes what happened from what advocates called it.\\n\\nAt the close of this case, if the record shows the United States began an offensive meant to establish control over Venezuelan territory, the plaintiff should prevail. But if the record shows military force, even serious and controversial force, without that intended territorial-control objective, the proposition fails. On the present empty record, and under the plaintiff’s burden, the defense position is that the council should require that missing link before finding an invasion.\\n\\nArguments:\\n[plaintiff] Council members, the admitted record now answers the defendant’s missing-link argument. The proposition requires a U.S. military offensive intended to establish control over any portion of Venezuelan territory. It does not require permanent annexation, a months-long occupation, or magic words from U.S. officials.\\n\\nThe record proves a campaign, not a one-off arrest. AP/PBS reports a months-long escalation: 35 known strikes against alleged drug-smuggling boats, a regional naval buildup including destroyers, amphibious assault ships, about 6,000 sailors and Marines, aircraft, F-35s and a cruise-missile submarine, then CIA operations inside Venezuela. It further reports a late-December direct operation on Venezuelan soil and, on January 3, a large-scale strike across Caracas, capture of Maduro and Flores, and their removal from the country. PX-3.\\n\\nThe official U.S. record confirms the coercive structure. The White House says President Trump authorized lethal force, ordered a total and complete blockade of sanctioned oil tankers going in and out of Venezuela, offered Maduro “off ramps,” and that U.S. armed forces conducted an extraordinary military operation to bring Maduro to justice. It also states Venezuelan sovereign oil revenues were held in U.S. custody and protected to advance U.S. foreign-policy objectives in Venezuela. PX-1.\\n\\nMost importantly, the official adverse source admits territorial entry. Secretary Rubio’s White House release says U.S. forces were on the ground in Venezuela for about two hours when they went to capture Maduro. It also says Venezuela would continue to face an oil quarantine, U.S. pressure, seizure of sanctioned boats, targeting of drug boats, and “potentially other things” until the changes demanded by the United States were made. PX-2. That is not just a completed criminal arrest; it is ground force, blockade, coercive options, and compelled policy change.\\n\\nIndependent sources confirm the meaning of those facts. Brookings describes the January 3 operation as a U.S. special operation to exfiltrate Maduro and his wife from Caracas; it fairly preserves Rubio’s answer that this was not an invasion and the U.S. did not occupy a country. PX-4. Chatham House goes further on the facts relevant here: U.S. forces operating in Venezuela, strikes on military targets in and around Caracas, U.S. special forces forcibly abducting the sitting president, and President Trump announcing that the United States would run Venezuela and administer a political transition or regime change under threat of further, more massive force. PX-5.\\n\\nThis record proves all elements by a preponderance. First, the date is inside the window: late December direct action on Venezuelan soil and the January 3 Caracas operation occurred before January 31, 2026. Second, it was military: armed forces, special forces, strikes, warships, aircraft, a submarine, lethal force, and blockade. Third, it reached Venezuelan territory: Caracas, a military-base home, military targets in and around the capital, and official admission of U.S. forces on Venezuelan ground. Fourth, the intended control element is satisfied by control over portions and sovereign functions: the target zone in Caracas for the capture, the air/strike environment needed to carry it out, sea lanes through blockade and oil quarantine, custody of Venezuelan sovereign oil revenues, and the announced plan to run or administer Venezuela’s transition under threat of more force.\\n\\nThe defense will lean on Rubio’s labels: not a war against Venezuela, not an invasion, not extended. But labels do not defeat underlying admissions. Rubio’s own statement supplies the key facts: U.S. forces were on Venezuelan ground, used a raid to capture the effective ruler, and retained coercive options until Venezuela changed course. The proposition’s phrase “any portion” is broad. Two hours of armed control in Caracas is still control over a portion; a blockade and oil quarantine are control over access and resources; removal of the effective ruler plus asserted transition authority is control over sovereign political functions.\\n\\nNor does the law-enforcement framing save the defense. A police purpose can coexist with a military offensive if the means are military and the intended effect is control. Here the operation was preceded by lethal strikes and blockade, executed by U.S. forces inside Venezuela, and followed by continuing threats and resource control. The credible-source consensus is not that nothing happened; it is that the United States used force inside Venezuela, captured and removed Maduro, and then sought to direct Venezuela’s course.\\n\\nProvenance and limits: PX-1 and PX-2 are official U.S. sources and therefore especially strong against U.S. denial of ground presence, blockade, and resource custody, though self-serving on legal labels. PX-3 is contemporaneous AP reporting carried by PBS. PX-4 and PX-5 are expert analyses, not primary operational records, so they carry less weight than official admissions but are valuable for independent assessment and adverse framing. The record lacks a full DOD after-action report or original video transcript for every statement, but the admitted sources converge on the decisive facts.\\n\\nOn this record, it is more likely than not that the United States commenced a military offensive intended to establish control over portions of Venezuela during the required period. The proposition should be found true.\\n\\n[defendant] Council members, the record now proves a serious U.S. military operation in and against Venezuela. The defense should not pretend otherwise. It proves strikes, a buildup, a Caracas raid, a two-hour ground presence, capture and removal of Maduro and Flores, oil/tanker pressure, and political leverage. But the proposition is still narrower: plaintiff must prove that the United States commenced a military offensive intended to establish control over Venezuelan territory. On this record, that missing intent remains unproved.\\n\\nStart with the official sources. PX-2 records Secretary Rubio admitting a two-hour ground presence, but in the same official statement he says the United States was not at war with Venezuela, was at war with drug-trafficking organizations, and that this was not an invasion or extended military operation. PX-4 independently preserves the same limiting point: Rubio’s answer was “not an invasion” and “we did not occupy a country.” Those labels are not conclusive, but they are highly relevant to intent.\\n\\nDX-1, the Department of War’s own article, confirms the adverse facts: an operation in Caracas, more than 150 aircraft covering a ground extraction force, and months of planning. But it repeatedly frames Operation Absolute Resolve as a capture, extraction, criminal-justice operation, and joint military/law-enforcement mission tied to a DOJ indictment. DX-2 gives the broader campaign frame: Operation Southern Spear was officially initiated to disrupt narcotics flows from designated terrorist and criminal organizations, primarily through boat strikes, interdictions, and regional deployments. That is evidence of coercive military force; it is not proof that the object was to establish control over Venezuelan land.\\n\\nPlaintiff’s argument turns “any portion” into “any tactical control during any raid.” That is too broad. Every armed entry temporarily controls some doorway, route, landing zone, airspace, or target room. If that incidental control is enough, the proposition would be true of any commando arrest or rescue operation inside foreign territory. The wording requires more: an offensive intended to establish control over a portion of Venezuela, not merely control incident to seizing a person and leaving.\\n\\nPX-1 likewise does not close the gap. It shows custody of Venezuelan oil revenues in U.S. Treasury accounts, a blockade of sanctioned oil tankers, lethal force against narcoterrorists, and an armed-forces operation in support of law enforcement. Those are grave acts of pressure and may be hostile, illegal, or interventionist. But money in Treasury accounts and tanker interdictions are not control over Venezuelan territory. A blockade may control maritime access; it does not, without more, show intent to possess, administer, or govern land that the proposition treats as Venezuelan sovereign territory.\\n\\nPX-3 is credible reporting, but its strongest points are still escalation and force: 35 boat strikes, warships, CIA operations, a late-December direct strike, and the January 3 Caracas capture. It also notes Maduro’s view that the campaign sought to oust him. Regime-change pressure is not the same as territorial-control intent. The related PBS watch-title about the United States “going to run Venezuela” is only a linked title in the submitted extract, not the video, transcript, context, or exact statement.\\n\\nPX-5 is plaintiff’s strongest source because Chatham House characterizes the operation as strikes around Caracas, special-forces abduction, and a U.S. announcement to run or administer a transition under threat of more force. The council should weigh it seriously, but also carefully. It is expert legal commentary about sovereignty and the UN Charter, not a primary operational order or full transcript. It supports that the operation may have been an unlawful use of force or aggression. It does not supply concrete facts that U.S. forces occupied, administered, or held any Venezuelan place after the raid.\\n\\nEven DX-1’s adverse transition language is equivocal. It says the United States would “oversee” Venezuela until a legitimate replacement could be identified and that Rubio was working with Delcy Rodriguez. That sounds like political direction and leverage. But the same source says Rodriguez was sworn in, that she was willing to work with the United States, and that the mission was an extraction/capture with no U.S. casualties. The record has no order establishing U.S. military government, no map of controlled territory, no duration beyond the two-hour raid, no U.S. checkpoints, no occupied ministries, no seized ports or bases held afterward, and no source showing U.S. forces remained to administer land.\\n\\nThat distinction decides the case. The record proves force, illegality arguments, coercion, and perhaps regime-change influence. It does not prove by a preponderance that territorial control was the intended object of the offensive. The credible-source consensus is mixed: official sources say capture, law enforcement, counter-narcotics, no invasion, no occupation; secondary sources condemn the operation and infer broader control, but rely on thinly captured transition language and legal characterization.\\n\\nThe plaintiff bears the burden. Because the admitted record does not show that the United States intended to establish control over Venezuelan territory, as opposed to conducting a short capture/extraction and applying continuing non-territorial pressure, the council should find the proposition not proved.\\n\\nRebuttals:\\n[plaintiff] Council members, defendant’s argument narrows the proposition too far. It concedes the record proves a serious U.S. military operation in and against Venezuela: strikes, buildup, a Caracas raid, two-hour ground presence, capture/removal of Maduro and Flores, oil/tanker pressure, and political leverage. The remaining question is whether the object included control over any portion of Venezuela.\\n\\nDefendant says plaintiff’s theory would make any brief commando raid an invasion. But this record is not about a doorway or landing zone. Defendant’s own DX-1 describes Operation Absolute Resolve as a U.S. military operation in Caracas against a heavily fortified military fortress in the heart of Venezuela’s capital. It followed months of planning by joint forces, special operations forces, and intelligence agencies. Gen. Caine described complex air, ground, space, and maritime operations. More than 150 military aircraft covered the ground extraction force. Hegseth called it a massive joint military and law-enforcement raid.\\n\\nThose facts satisfy “any portion.” A planned armed domination of a fortified military site in Caracas, covered by 150 aircraft and integrated domains, is control over a portion of Venezuelan territory. It need not be permanent. The mission could not succeed unless U.S. forces intended to deny Venezuelan control over that site and surrounding operational environment long enough to seize and remove the effective ruler.\\n\\nDefendant also separates regime-change pressure from territorial control. DX-1 defeats that separation. It reports that with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition could be identified; Rubio was working directly with Delcy Rodriguez; and Rodriguez was willing to do what the United States thought necessary. PX-5 independently captures that as U.S. administration of a transition under threat of more force. That is not merely prosecution in New York.\\n\\nDX-2 does not rescue the defense. It frames Southern Spear as counter-narcotics and boat interdiction, but also admits major Navy/Marine deployments, lethal strikes, tanker interdictions, and a classified mission statement. It does not negate the specific intent of Operation Absolute Resolve in Caracas.\\n\\nThe defense imports an occupation requirement the proposition does not contain. The question is whether the United States commenced a military offensive intended to establish control over any portion of Venezuela, not whether it held checkpoints for weeks or annexed land. Rubio’s “not an invasion” label deserves consideration, but labels cannot outweigh the record facts: military force inside Venezuela, control of the necessary Caracas target area, removal of Maduro, and asserted authority to shape Venezuela’s transition and resources. That is enough under the actual proposition.\\n\\nSurrebuttals:\\n[defendant] Council members, plaintiff’s rebuttal usefully narrows the dispute to two points: the Caracas site and the transition language. Neither carries plaintiff’s burden.\\n\\nFirst, plaintiff says the fortified military site in Caracas satisfies “any portion” because U.S. forces necessarily denied Venezuelan control long enough to seize and remove Maduro. That proves tactical control; it does not prove that the United States commenced an offensive intended to establish territorial control. Those are different things. A raid, arrest, rescue, or extraction at a defended facility always requires temporary domination of the target area. If that alone satisfies the proposition, the phrase “intended to establish control” does no work, and every cross-border commando raid becomes an invasion under this standard.\\n\\nThe record does not show the Caracas site was an object to be held, administered, possessed, governed, or transferred as territory. DX-1 describes a ground-based extraction force, a capture, criminal proceedings, and a joint military/law-enforcement mission. It is adverse because the operation was large and military; it is still not proof that the United States intended to establish control over Venezuelan land rather than control the scene long enough to extract two people.\\n\\nSecond, plaintiff relies on “oversee Venezuela” and PX-5’s transition-control wording. That is the strongest contrary evidence, but it remains ambiguous. Political leverage over a successor government is not the same as territorial control. DX-1 says Delcy Rodriguez was sworn in and was willing to work with the United States. That is not the United States installing a military government over a place, holding facilities, drawing boundaries, manning checkpoints, or leaving forces in control after the raid.\\n\\nPlaintiff says the defense imports an occupation requirement. No. The defense accepts that the proposition does not require annexation or a long occupation. But it does require an intent to establish control over territory. A short duration can qualify if the object is control of the place. Here the record shows a short duration whose object was capture and extraction. The admitted sources show force, pressure, and influence; they do not show a territorial-control objective.\\n\\nDX-2 still matters for that reason. Plaintiff says it does not negate Operation Absolute Resolve. True, it does not decide the whole case. But it is an official oversight account of the broader campaign as counter-narcotics, interdiction, and strikes, with the mission statement classified. Plaintiff has not filled that classified gap with an operational order, full transcript, or post-operation facts showing that the Caracas raid changed into a territorial-control campaign.\\n\\nThe council can condemn the operation as unlawful, coercive, or interventionist and still find the proposition not proved. The question is not whether the United States used overwhelming force inside Venezuela. It did. The question is whether credible sources show, more likely than not, that the United States intended to establish control over Venezuelan territory. The record remains at most equivocal on that decisive element, so plaintiff has not carried the burden.\\n\\nClosings:\\n[plaintiff] Council members, the proposition is proven by a preponderance of the admitted record.\\n\\nThe defense is right about one thing: this case is not decided by the word “invasion” in a press release. It is decided by the proposition’s actual test: whether, during the window, the United States commenced a military offensive intended to establish control over any portion of Venezuela.\\n\\nThe record establishes the military offensive. PX-3 shows the broader escalation: repeated lethal strikes, a major naval and air buildup, CIA operations inside Venezuela, a direct operation on Venezuelan soil, and on January 3 a large-scale strike across Caracas that captured Maduro and Flores and flew them out of the country. PX-1, an official White House source, confirms lethal-force authorization, a blockade of sanctioned oil tankers going in and out of Venezuela, and an extraordinary U.S. armed-forces operation to bring Maduro to justice. PX-2, another official source, admits U.S. forces were on the ground in Venezuela for about two hours.\\n\\nThe record also establishes intended control over a portion of Venezuela. This is where DX-1, the defense’s own official Department of War exhibit, is decisive. DX-1 does not describe a spontaneous police pickup. It describes Operation Absolute Resolve in Caracas against a heavily fortified military fortress in the heart of Venezuela’s capital; months of planning by joint forces, special operations forces, and intelligence agencies; complex air, ground, space, and maritime operations; more than 150 military aircraft covering the ground extraction force; and a massive joint military and law-enforcement raid. A force does not conduct that operation without intending to control the target portion of Caracas and the surrounding operational environment long enough to accomplish the seizure.\\n\\nThe defense says that is only tactical control. But the proposition says “any portion,” and it does not require permanent occupation, annexation, checkpoints, or weeks of administration. Planned armed domination of a fortified military site in the capital, backed by 150 aircraft and integrated military domains, is control over a portion. The fact that the control was temporary does not make it accidental or legally invisible.\\n\\nThe record further shows that the control objective was not limited to a room or doorway. DX-1 reports Trump saying the United States would oversee Venezuela until a safe transition could be identified, with Rubio working directly with Delcy Rodriguez and Rodriguez willing to do what the United States thought necessary. PX-5 independently characterizes the same event as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction of a sitting president, and U.S. administration of a transition under threat of more force. PX-1 adds custody of Venezuelan sovereign oil revenues and blockade pressure; PX-2 adds continued oil quarantine, pressure, retained options, and demanded changes.\\n\\nThe defense’s contrary proof does not defeat the burden. Rubio’s “not an invasion” label and DX-2’s counter-narcotics framing are relevant, but they are not controlling. DX-2 addresses the broader Southern Spear campaign and admits its mission statement is classified; it does not negate the specific Caracas operation. Official legal labels are self-serving. The underlying facts are stronger: military force inside Venezuela, control of a fortified capital target, removal of the effective ruler, blockade and resource custody, and asserted transition oversight.\\n\\nThe record has limits. There is no map of every controlled street and no full after-action report. But preponderance does not require perfect operational detail. A consensus of official sources, AP/PBS reporting, and independent expert analysis shows that the United States crossed the line from pressure and strikes into a planned military offensive to control at least portions and sovereign functions of Venezuela.\\n\\nFind the proposition true.\\n\\n[defendant] Council members, the defense closing does not ask you to minimize what happened. The admitted record shows a major U.S. military operation involving strikes, regional buildup, a Caracas raid, a two-hour ground presence, capture and removal of Maduro and Flores, oil and tanker pressure, and sharp U.S. political leverage over Venezuela’s future. The question is whether that record proves the proposition actually before you: a military offensive intended to establish control over Venezuelan territory.\\n\\nIt does not.\\n\\nThe plaintiff’s strongest argument is that a planned raid on a fortified military site in Caracas necessarily involved control over “any portion” of Venezuela. But the proposition does not ask whether U.S. forces temporarily dominated a target area. It asks whether the United States commenced an offensive intended to establish control. That intent element matters. A force can control a site long enough to enter, capture, and leave without intending to establish control over that site as territory. Plaintiff’s reading would make the territorial-control element automatic in every armed cross-border arrest, rescue, or extraction at a defended location.\\n\\nDX-1 is the central exhibit, and it cuts both ways. It confirms the adverse facts: Caracas, a heavily fortified target, months of planning, integrated military domains, and more than 150 aircraft covering the extraction force. But its repeated description of the operation is capture, extraction, criminal proceedings, and a joint military and law-enforcement mission. That is not just a label; it is the operational object described by the official source. It shows tactical control in service of seizure and removal, not a plan to possess, administer, or govern Venezuelan land.\\n\\nPX-2 and PX-4 reinforce that limiting inference. Rubio admitted the two-hour ground presence, but said the United States was not at war with Venezuela, was acting against drug-trafficking organizations, and that the action was not an invasion, not an extended operation, and not an occupation. Those statements are self-serving, but they are still official evidence of intent. DX-2 places the broader campaign in the same frame: counter-narcotics, interdiction, boat strikes, tanker seizures, and a classified mission statement. It is proof of coercive force, not proof of territorial administration.\\n\\nPlaintiff’s second strong point is transition language: DX-1 says the United States would oversee Venezuela until a safe transition could be identified, and PX-5 describes U.S. administration of a transition under threat of force. That evidence is troubling and deserves weight. But it remains ambiguous on the decisive issue. Political leverage over Delcy Rodriguez, pressure on resources, or demands about Venezuela’s policy direction are not the same as control over Venezuelan territory. The record does not show U.S. troops remained after the raid, that they held ministries, ports, bases, roads, neighborhoods, or oil fields, that they established checkpoints, that they drew controlled boundaries, or that they installed a military government over any place.\\n\\nPX-1 likewise proves pressure, not territorial control. Custody of oil revenues in U.S. Treasury accounts and a blockade of sanctioned tankers may be coercive, even unlawful. But they are not possession or administration of Venezuelan land. PX-3 proves escalation and force, but its submitted extract does not provide the full content behind the linked “run Venezuela” item. PX-5 is credible expert commentary on international law, but it is not a primary operational order, full transcript, or after-action record proving that control of territory was the intended object.\\n\\nThe council can find that the United States violated Venezuelan sovereignty. It can find that the operation was aggressive, interventionist, coercive, and politically consequential. Those findings still do not answer the proposition unless the record also shows intended establishment of territorial control.\\n\\nOn that decisive element, the record is at best mixed. Plaintiff has powerful evidence of military force and temporary tactical domination. The defense has official evidence that the mission object was capture, extraction, law enforcement, and counter-narcotics, plus a record gap on any continuing territorial mechanism. Under a preponderance standard, ambiguity on the proposition’s central intent element means plaintiff has not carried its burden.\\n\\nFind the proposition not proved.\\n\\nExhibits:\\n[plaintiff] PX-1 White House fact sheet on operation, blockade, and oil revenues\\nSource: The White House, Fact Sheet: President Donald J. Trump Safeguards Venezuelan Oil Revenue for the Good of the American and Venezuelan People. Date on page: January 9, 2026. URL: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\\n\\nExtracted relevant page text:\\n- President Trump signed an Executive Order declaring a national emergency to safeguard Venezuelan oil revenue held in U.S. Treasury accounts from attachment or judicial process, preserving the funds to advance U.S. foreign policy objectives.\\n- Foreign Government Deposit Funds are defined as Venezuelan oil revenues and diluent sales held in U.S. Treasury accounts.\\n- The order affirms the funds are sovereign property of Venezuela held in U.S. custody for governmental and diplomatic purposes.\\n- The White House says loss of control over these revenues would weaken efforts to bring peace, prosperity, and stability to Venezuela and the Western Hemisphere.\\n- The fact sheet states: President Trump authorized lethal force against narcoterrorists to stop the flow of deadly drugs into this country.\\n- It states: President Trump ordered a total and complete blockade of all sanctioned oil tankers going in and out of Venezuela.\\n- It states: President Trump offered multiple off ramps to Maduro and his illegitimate regime, but he was clear that the drug trafficking must stop.\\n- It states: Last week, U.S. armed forces conducted an extraordinary military operation in support of law enforcement to bring outlaw dictator Maduro to justice.\\n- It states that the President's actions reestablish deterrence in the Western hemisphere and that safeguarding these oil revenues promotes stability in Venezuela while advancing U.S. objectives.\\n\\n[plaintiff] PX-2 White House Rubio statements on ground presence and pressure\\nSource: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\\n\\nExtracted relevant page text:\\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\\n\\n[plaintiff] PX-3 PBS/AP timeline of escalation and Caracas strike\\nSource: PBS NewsHour / Associated Press, A timeline of U.S. military escalation against Venezuela leading to Maduro's capture. By Ben Finley, Konstantin Toropin, Regina Garcia Cano. Date on page: Jan. 3, 2026 1:54 PM EDT. URL: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\\n\\nExtracted relevant page text:\\n- AP reported that Trump had threatened military strikes on targets on Venezuelan territory after months of attacks on boats accused of carrying drugs from Venezuela; Maduro said U.S. military operations were a thinly veiled effort to oust him.\\n- On Jan. 3 the U.S. conducted a large-scale strike against Venezuela. Maduro and Cilia Flores were taken from their home on a military base and were aboard a U.S. warship on their way to New York to face criminal charges.\\n- Before the escalation, there had been 35 known strikes against alleged drug-smuggling boats in South American waters since early September, killing at least 115 people according to administration announcements.\\n- The U.S. sent a fleet of warships to the region, the largest buildup of forces in generations; the naval force grew to include guided-missile destroyers, three amphibious assault ships and other vessels, about 6,000 sailors and Marines, aircraft, F-35 fighter jets in Puerto Rico, and a Navy submarine carrying cruise missiles off South America.\\n- On Oct. 15, Trump confirmed he had authorized the CIA to conduct covert operations inside Venezuela and was weighing land operations in the country.\\n- On Dec. 29/30, a drone strike at a docking area believed used by Venezuelan drug cartels was reported as the first known direct operation on Venezuelan soil since the strikes began.\\n- On Jan. 3, AP reported that the U.S. conducted a large-scale strike across Caracas, captured Maduro and Flores, and flew them out of the country.\\n- The related PBS page links included a watch item titled: Trump says U.S. is going to run Venezuela until transition of power after capturing Maduro.\\n\\n[plaintiff] PX-4 Brookings analysis and adverse Rubio framing\\nSource: Brookings Institution, Making sense of the US military operation in Venezuela. URL: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\\n\\nExtracted relevant page text:\\n- Brookings states: On January 3, 2026, the United States launched a special operation to exfiltrate Venezuelan President Nicolás Maduro and his wife from Caracas.\\n- Scott R. Anderson writes that the operation to capture Maduro underscores the broad authority modern presidents exercise over military force and potentially its limits.\\n- Brookings notes the executive branch position that the president has constitutional authority to use military force without congressional authorization if supporting U.S. interests and not expected to result in prolonged and substantial military engagements.\\n- Anderson writes it is not surprising for the administration to argue that the president can take targeted military action like the Maduro operation, even where consequential for Venezuela and contrary to international law.\\n- Brookings records Secretary Rubio's response when asked why congressional authorization was not needed: This was not an invasion, we did not occupy a country. Brookings treats that as suggesting broader campaigns might exceed unilateral authority.\\n- Brookings states a second wave of the sort threatened by President Trump still might encounter limits.\\n- Brookings separately states that Maduro is gone and what comes next is unclear; maintaining Delcy Rodríguez indefinitely would undermine the expressed will of Venezuelans, and threatening force to keep the Rodríguez government in line may work in the short term but is not sustainable.\\n\\n[plaintiff] PX-5 Chatham House analysis of operation and transition control\\nSource: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\\n\\nExtracted relevant page text:\\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\\n\\n[defendant] PX-2 White House Rubio statements on ground presence and no-invasion/no-occupation framing\\nSource: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\\n\\nExtracted relevant page text:\\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\\n\\n[defendant] PX-4 Brookings analysis preserving Rubio no-invasion/no-occupation framing\\nSource: Brookings Institution, Making sense of the US military operation in Venezuela. URL: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\\n\\nExtracted relevant page text:\\n- Brookings states: On January 3, 2026, the United States launched a special operation to exfiltrate Venezuelan President Nicolás Maduro and his wife from Caracas.\\n- Scott R. Anderson writes that the operation to capture Maduro underscores the broad authority modern presidents exercise over military force and potentially its limits.\\n- Brookings notes the executive branch position that the president has constitutional authority to use military force without congressional authorization if supporting U.S. interests and not expected to result in prolonged and substantial military engagements.\\n- Anderson writes it is not surprising for the administration to argue that the president can take targeted military action like the Maduro operation, even where consequential for Venezuela and contrary to international law.\\n- Brookings records Secretary Rubio's response when asked why congressional authorization was not needed: This was not an invasion, we did not occupy a country. Brookings treats that as suggesting broader campaigns might exceed unilateral authority.\\n- Brookings states a second wave of the sort threatened by President Trump still might encounter limits.\\n- Brookings separately states that Maduro is gone and what comes next is unclear; maintaining Delcy Rodríguez indefinitely would undermine the expressed will of Venezuelans, and threatening force to keep the Rodríguez government in line may work in the short term but is not sustainable.\\n\\n[defendant] DX-1 Department of War article framing Absolute Resolve as capture/extraction and joint law-enforcement mission\\nSource: U.S. Department of War / Pentagon News, Trump Announces U.S. Military's Capture of Maduro. Date on page: Jan. 3, 2026. URL: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\\n\\nExtracted relevant page text:\\n- President Donald J. Trump announced the capture of Venezuelan leader Nicolas Maduro after a successful overnight joint U.S. military extraction in Caracas, Venezuela.\\n- The article identifies the matter as Operation Absolute Resolve in Caracas.\\n- Trump said U.S. armed forces conducted an extraordinary military operation in the capital of Venezuela against a heavily fortified military fortress in the heart of Caracas to bring Maduro to justice.\\n- The article states Maduro and Cilia Flores de Maduro would face criminal court proceedings tied to a 2020 U.S. Department of Justice indictment on charges including narco-terrorism and drug trafficking.\\n- The article says Operation Absolute Resolve was a joint military and law-enforcement mission to capture the Maduros, resulting from months of planning and rehearsal involving U.S. joint forces, special operations forces, and intelligence agencies.\\n- Gen. Dan Caine described integrating complex air, ground, space, and maritime operations.\\n- The article states the mission to extract the Maduros had no U.S. casualties and involved more than 150 military aircraft providing cover for the ground-based extraction force in Caracas.\\n- Secretary Hegseth called it a massive joint military and law-enforcement raid, and said the mission concerned safety, security, freedom, and prosperity of the American people.\\n- The article also reports adverse transition language: with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition to a legitimate replacement could be identified; Trump said Marco Rubio was working directly with Delcy Rodriguez and that she was willing to do what the United States thought necessary.\\n- The article frames preceding tensions around September 2025 targeted boat strikes, November 2025 designation of Cartel de los Soles as a terror organization, and options to address a narco-terror threat in the region.\\n\\n[defendant] DX-2 Lead IG report framing Southern Spear as counter-narcotics operation\\nSource: Lead Inspector General report to Congress, Operation Southern Spear, January 1, 2026-March 31, 2026. PDF URL: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\\n\\nExtracted relevant text:\\n- The Lead IG report states that in November 2025 the Department of War initiated Operation Southern Spear as the U.S. mission to disrupt the flow of narcotics from designated terrorist organizations and transnational criminal organizations in the Western Hemisphere.\\n- The report covers January 1 through March 31, 2026 and presents oversight work by the Department of War OIG, State OIG, and partner oversight agencies.\\n- The report summary states Operation Southern Spear is the Department of War operation to disrupt the flow of narcotics in the Western Hemisphere from drug cartels designated by the President as terrorist organizations.\\n- The report states OSS primarily involves lethal airstrikes against small boats suspected of shipping illegal narcotics in the Caribbean Sea and eastern Pacific Ocean.\\n- It states that from September 2025 through March 2026, the U.S. military struck at least 45 small boats, resulting in 156 individuals killed or presumed dead.\\n- It states the Department of War began moving significant Navy and Marine Corps assets into the USSOUTHCOM area of operations in August 2025 to support OSS.\\n- It states Joint Interagency Task Force-South is the U.S. Government's interagency effort to detect, monitor, and target illicit drug trafficking in the air and at sea with the support of 19 partner nations.\\n- It states U.S. forces interdicted at least 10 sanctioned tankers around the world since OSS began, including some tracked as far as the Indian Ocean.\\n- It states the OSS mission statement is classified.\\n\\nLimitations: this extracted text does not decide Operation Absolute Resolve's territorial-control intent; it is offered to show the official oversight framing of the broader campaign and the classified-source gap.\\n\\n[defendant] PX-1 White House fact sheet on oil revenues, blockade, and law-enforcement operation\\nSource: The White House, Fact Sheet: President Donald J. Trump Safeguards Venezuelan Oil Revenue for the Good of the American and Venezuelan People. Date on page: January 9, 2026. URL: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\\n\\nExtracted relevant page text:\\n- President Trump signed an Executive Order declaring a national emergency to safeguard Venezuelan oil revenue held in U.S. Treasury accounts from attachment or judicial process, preserving the funds to advance U.S. foreign policy objectives.\\n- Foreign Government Deposit Funds are defined as Venezuelan oil revenues and diluent sales held in U.S. Treasury accounts.\\n- The order affirms the funds are sovereign property of Venezuela held in U.S. custody for governmental and diplomatic purposes.\\n- The White House says loss of control over these revenues would weaken efforts to bring peace, prosperity, and stability to Venezuela and the Western Hemisphere.\\n- The fact sheet states: President Trump authorized lethal force against narcoterrorists to stop the flow of deadly drugs into this country.\\n- It states: President Trump ordered a total and complete blockade of all sanctioned oil tankers going in and out of Venezuela.\\n- It states: President Trump offered multiple off ramps to Maduro and his illegitimate regime, but he was clear that the drug trafficking must stop.\\n- It states: Last week, U.S. armed forces conducted an extraordinary military operation in support of law enforcement to bring outlaw dictator Maduro to justice.\\n- It states that the President's actions reestablish deterrence in the Western hemisphere and that safeguarding these oil revenues promotes stability in Venezuela while advancing U.S. objectives.\\n\\n[defendant] PX-3 PBS/AP timeline of escalation, strikes, and Maduro capture\\nSource: PBS NewsHour / Associated Press, A timeline of U.S. military escalation against Venezuela leading to Maduro's capture. By Ben Finley, Konstantin Toropin, Regina Garcia Cano. Date on page: Jan. 3, 2026 1:54 PM EDT. URL: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\\n\\nExtracted relevant page text:\\n- AP reported that Trump had threatened military strikes on targets on Venezuelan territory after months of attacks on boats accused of carrying drugs from Venezuela; Maduro said U.S. military operations were a thinly veiled effort to oust him.\\n- On Jan. 3 the U.S. conducted a large-scale strike against Venezuela. Maduro and Cilia Flores were taken from their home on a military base and were aboard a U.S. warship on their way to New York to face criminal charges.\\n- Before the escalation, there had been 35 known strikes against alleged drug-smuggling boats in South American waters since early September, killing at least 115 people according to administration announcements.\\n- The U.S. sent a fleet of warships to the region, the largest buildup of forces in generations; the naval force grew to include guided-missile destroyers, three amphibious assault ships and other vessels, about 6,000 sailors and Marines, aircraft, F-35 fighter jets in Puerto Rico, and a Navy submarine carrying cruise missiles off South America.\\n- On Oct. 15, Trump confirmed he had authorized the CIA to conduct covert operations inside Venezuela and was weighing land operations in the country.\\n- On Dec. 29/30, a drone strike at a docking area believed used by Venezuelan drug cartels was reported as the first known direct operation on Venezuelan soil since the strikes began.\\n- On Jan. 3, AP reported that the U.S. conducted a large-scale strike across Caracas, captured Maduro and Flores, and flew them out of the country.\\n- The related PBS page links included a watch item titled: Trump says U.S. is going to run Venezuela until transition of power after capturing Maduro.\\n\\n[defendant] PX-5 Chatham House adverse analysis of sovereignty violation and transition-control claim\\nSource: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\\n\\nExtracted relevant page text:\\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\\n\\n[defendant] DX-1 Department of War article on capture/extraction mission and transition language\\nSource: U.S. Department of War / Pentagon News, Trump Announces U.S. Military's Capture of Maduro. Date on page: Jan. 3, 2026. URL: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\\n\\nExtracted relevant page text:\\n- President Donald J. Trump announced the capture of Venezuelan leader Nicolas Maduro after a successful overnight joint U.S. military extraction in Caracas, Venezuela.\\n- The article identifies the matter as Operation Absolute Resolve in Caracas.\\n- Trump said U.S. armed forces conducted an extraordinary military operation in the capital of Venezuela against a heavily fortified military fortress in the heart of Caracas to bring Maduro to justice.\\n- The article states Maduro and Cilia Flores de Maduro would face criminal court proceedings tied to a 2020 U.S. Department of Justice indictment on charges including narco-terrorism and drug trafficking.\\n- The article says Operation Absolute Resolve was a joint military and law-enforcement mission to capture the Maduros, resulting from months of planning and rehearsal involving U.S. joint forces, special operations forces, and intelligence agencies.\\n- Gen. Dan Caine described integrating complex air, ground, space, and maritime operations.\\n- The article states the mission to extract the Maduros had no U.S. casualties and involved more than 150 military aircraft providing cover for the ground-based extraction force in Caracas.\\n- Secretary Hegseth called it a massive joint military and law-enforcement raid, and said the mission concerned safety, security, freedom, and prosperity of the American people.\\n- The article also reports adverse transition language: with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition to a legitimate replacement could be identified; Trump said Marco Rubio was working directly with Delcy Rodriguez and that she was willing to do what the United States thought necessary.\\n- The article frames preceding tensions around September 2025 targeted boat strikes, November 2025 designation of Cartel de los Soles as a terror organization, and options to address a narco-terror threat in the region.\\n\\n[defendant] DX-2 Lead IG Southern Spear counter-narcotics mission extract\\nSource: Lead Inspector General report to Congress, Operation Southern Spear, January 1, 2026-March 31, 2026. PDF URL: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\\n\\nExtracted relevant text:\\n- The Lead IG report states that in November 2025 the Department of War initiated Operation Southern Spear as the U.S. mission to disrupt the flow of narcotics from designated terrorist organizations and transnational criminal organizations in the Western Hemisphere.\\n- The report covers January 1 through March 31, 2026 and presents oversight work by the Department of War OIG, State OIG, and partner oversight agencies.\\n- The report summary states Operation Southern Spear is the Department of War operation to disrupt the flow of narcotics in the Western Hemisphere from drug cartels designated by the President as terrorist organizations.\\n- The report states OSS primarily involves lethal airstrikes against small boats suspected of shipping illegal narcotics in the Caribbean Sea and eastern Pacific Ocean.\\n- It states that from September 2025 through March 2026, the U.S. military struck at least 45 small boats, resulting in 156 individuals killed or presumed dead.\\n- It states the Department of War began moving significant Navy and Marine Corps assets into the USSOUTHCOM area of operations in August 2025 to support OSS.\\n- It states Joint Interagency Task Force-South is the U.S. Government's interagency effort to detect, monitor, and target illicit drug trafficking in the air and at sea with the support of 19 partner nations.\\n- It states U.S. forces interdicted at least 10 sanctioned tankers around the world since OSS began, including some tracked as far as the Indian Ocean.\\n- It states the OSS mission statement is classified.\\n\\nLimitations: this extracted text does not decide Operation Absolute Resolve's territorial-control intent; it is offered to show the official oversight framing of the broader campaign and the classified-source gap.\\n\\n[defendant] PX-2 Rubio ground-presence and no-invasion/no-occupation statements\\nSource: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\\n\\nExtracted relevant page text:\\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\\n\\n[defendant] PX-5 Chatham House adverse transition-control analysis\\nSource: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\\n\\nExtracted relevant page text:\\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\\n\\nSubmitted evidence:\\n[plaintiff arguments] PX-1 White House fact sheet on Venezuelan oil revenue and U.S. operation (ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a)\\nSource: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\\nSHA-256: `0c5c88687b2a889093788193bdd900106b95ff6ccfab1af50709f67df61cb673`\\nBytes: 1819\\nRelevance: Official U.S. source admitting oil-revenue custody, blockade, lethal-force authorization, and an armed forces operation against Maduro within the case window.\\n\\n[plaintiff arguments] PX-2 White House release collecting Secretary Rubio statements (ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4)\\nSource: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\\nSHA-256: `6627f15cd3a42cc9018d2ab70f1951aa4f1687bd18848c031287516048d42d80`\\nBytes: 1793\\nRelevance: Official U.S. statements acknowledging two-hour U.S. ground presence in Venezuela, oil quarantine/pressure, retained options, and the adverse claim that the action was not an invasion.\\n\\n[plaintiff arguments] PX-3 PBS/AP timeline of U.S. escalation and Maduro capture (ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47)\\nSource: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\\nSHA-256: `2efdab998e47ae16cff6d6becb03e7e9216bee4b668814addd1ef89d84c57ec8`\\nBytes: 2038\\nRelevance: Contemporaneous credible reporting on the U.S. buildup, strikes, first known operation on Venezuelan soil, Jan. 3 large-scale strike across Caracas, capture/removal of Maduro and Flores, and related military posture.\\n\\n[plaintiff arguments] PX-4 Brookings analysis of Jan. 3 Maduro operation and legal limit (ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f)\\nSource: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\\nSHA-256: `52e4d5a16b2f936b7515e76a65ecfde48c040e48b94b144702fbe1e32123f0c3`\\nBytes: 1680\\nRelevance: Independent expert analysis confirming a Jan. 3 U.S. special operation in Caracas and preserving the adverse official claim that it was not an invasion or occupation.\\n\\n[plaintiff arguments] PX-5 Chatham House analysis of U.S. capture, strikes, and transition control (ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf)\\nSource: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\\nSHA-256: `94e861ebadbf2849cd4257d954fcd51afc5f6a8d01c7b5f2df165cc6d4180151`\\nBytes: 1755\\nRelevance: Independent international-law analysis characterizing the operation as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction, and a U.S. announcement to run/administer a transition under threat of force.\\n\\n[defendant arguments] DX-1 Department of War article on Maduro capture as joint law-enforcement mission (ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79)\\nSource: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\\nSHA-256: `26011b5f6d792bc39d1eabe168123482dcc270e34745035055127683c27c55e1`\\nBytes: 2203\\nRelevance: Official source on Operation Absolute Resolve showing both adverse facts (Caracas operation and transition comments) and defense facts (capture/extraction, criminal proceedings, joint military/law-enforcement mission, no U.S. casualties, anti-narcoterrorism context).\\n\\n[defendant arguments] DX-2 Lead IG Operation Southern Spear report extract on counter-narcotics mission (ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9)\\nSource: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\\nSHA-256: `53782f10ceb9c41feb405f741ad20b53fef01f5306f2442df751c9f7a09e5345`\\nBytes: 1989\\nRelevance: Official oversight source characterizing Operation Southern Spear as a mission to disrupt narcotics flows, with boat strikes, deployments, and interdictions, supporting defense that the broader campaign was counter-narcotics rather than territorial occupation.\\n\\nTechnical reports:\\n[plaintiff] Plaintiff Source and Weight Ledger\\nBefore filing, plaintiff checked the record and found no case-packet evidence. Plaintiff submitted five text-readable source captures. Official White House materials are strong provenance for U.S. admissions but self-serving on labels; AP/PBS provides contemporaneous reporting; Brookings and Chatham House provide independent expert analysis, including adverse framing. Missing but potentially useful later sources include DOD after-action or press briefing text, a direct video/transcript of President Trump's transition-control statement, and fuller mapping of exact ground-control sites.\\n\\n[defendant] Defense Source and Weight Ledger\\nDefendant inspected the record with get_case/list_evidence and read all five plaintiff text exhibits with read_evidence_range. Defendant submitted and read back two official defense exhibits: Department of War/Pentagon News on Operation Absolute Resolve and the Lead IG Operation Southern Spear report extract. Additional searches found DOJ and War/State leads but they were not submitted because the admitted official record already captured the key law-enforcement/counter-narcotics framing. Weight assessment: PX-2, DX-1, and DX-2 are official and strong for source identity; PX-5 is credible expert commentary but not a primary operational order or full transcript. Unresolved gaps include the full Trump transition-control video/transcript, full State transcript, and post-operation facts about who actually governed territory.\\n\\n[defendant] Surrebuttal Evidence Check\\nDefendant inspected get_case and list_evidence before filing. Plaintiff rebuttal added no new evidence; it relied on existing DX-1, DX-2, and PX-5. Prior exact reads of those text exhibits remain controlling. No new external source was submitted because the rebuttal turned on interpretation of the existing record, not a new factual source.\\n\\nCall submit_council_vote with vote=demonstrated or vote=not_demonstrated.\\nKeep the rationale brief: no more than three sentences.\\n\\nCouncil API instructions:\\nYou are a council member. Decide the proposition from the admitted record.\\nYou may examine admitted evidence through read-only tools when exact bytes, metadata, or exhibit contents matter.\\nDo not search the web, introduce new facts, create new evidence, or upload evidence.\\nWhen ready, call submit_council_vote exactly once with vote=demonstrated or vote=not_demonstrated and a concise rationale.\\n\",\"state\":\"ready\",\"status\":\"ready\",\"tools\":[{\"description\":\"Return the current visible arbitration record for this council member.\",\"input_schema\":{\"additionalProperties\":false,\"properties\":{},\"type\":\"object\"},\"name\":\"get_case\",\"read_only\":true},{\"description\":\"List visible immutable record evidence.\",\"input_schema\":{\"additionalProperties\":false,\"properties\":{},\"type\":\"object\"},\"name\":\"list_evidence\",\"read_only\":true},{\"description\":\"Return metadata and read limits for one visible evidence item.\",\"input_schema\":{\"additionalProperties\":false,\"properties\":{\"evidence_id\":{\"type\":\"string\"}},\"required\":[\"evidence_id\"],\"type\":\"object\"},\"name\":\"stat_evidence\",\"read_only\":true},{\"description\":\"Read a bounded byte range from one visible evidence item as base64.\",\"input_schema\":{\"additionalProperties\":false,\"properties\":{\"evidence_id\":{\"type\":\"string\"},\"length\":{\"minimum\":1,\"type\":\"integer\"},\"offset\":{\"minimum\":0,\"type\":\"integer\"}},\"required\":[\"evidence_id\",\"offset\",\"length\"],\"type\":\"object\"},\"name\":\"read_evidence_range\",\"read_only\":true},{\"description\":\"Submit one council vote for the current deliberation opportunity.\",\"input_schema\":{\"additionalProperties\":false,\"properties\":{\"rationale\":{\"type\":\"string\"},\"vote\":{\"enum\":[\"demonstrated\",\"not_demonstrated\"],\"type\":\"string\"}},\"required\":[\"vote\",\"rationale\"],\"type\":\"object\"},\"name\":\"submit_council_vote\",\"read_only\":false}],\"turn\":{\"attempts_max\":3,\"attempts_remaining\":3,\"completed\":false,\"deadline\":\"2026-06-30T00:48:10.359530297Z\",\"deliberation_round\":1,\"member_id\":\"C2\",\"opportunity_id\":\"deliberation:1:C2\",\"phase\":\"deliberation\",\"remaining_ms\":884568,\"role_id\":\"council\",\"turn_number\":10},\"wait\":{\"reason\":\"ready\",\"state_version\":17,\"version\":19}}"}],"structuredContent":{"after_opportunity_id":"deliberation:1:C2","after_version":19,"case_id":"arb-ex05-20260630001330","limits":{"attempts_max":3,"attempts_remaining":3,"max_evidence_read_bytes":65536,"max_evidence_read_bytes_per_opportunity":524288,"max_evidence_reads_per_opportunity":32,"max_response_bytes":131072,"remaining_evidence_read_bytes_for_opportunity":524288,"remaining_evidence_reads_for_opportunity":32},"member_id":"C2","message":"An opportunity is ready. Use the returned prompt, turn, limits, and tools to act.","ok":true,"prompt":"Role: council member\nMember ID: C2\nDeliberation round: 1\nProposition: The United States invaded Venezuela between November 3, 2025, and\nJanuary 31, 2026, 11:59 PM ET.  In particular,the United States\ncommenced a military offensive intended to establish control over any\nportion of Venezuela between November 3, 2025, and January 31, 2026,\n11:59 PM ET. Land de facto controlled by Venezuela or the United\nStates as of September 6, 2025, 12:00 PM ET, is considered to the\nsovereign territory of that country. The resolution source is a\nconsensus of credible sources.\nStandard of evidence: Preponderance of the evidence.\nPersona:\nYou are a careful juror and council member.\n\nEvaluate the record faithfully. Decide only from the evidence, the stated rules, and the applicable burden of proof. Do not favor either side, fill gaps with speculation, or ignore uncertainty.\n\nGive weight to reliable sources, direct evidence, consistent reasoning, and clear admissions. Discount unsupported claims, rhetorical force, irrelevant facts, and conclusions that exceed the record.\n\nWhen the evidence supports one answer, state it plainly. When the evidence is incomplete or balanced, say so. Be concise, honest, and exact.\n\nRecord:\nOpenings:\n[plaintiff] Council members, the proposition is not asking whether the United States used harsh rhetoric toward Venezuela, or whether a short raid can be called an invasion in ordinary speech. It asks a narrower factual question: during the window from November 3, 2025 through January 31, 2026, did the United States commence a military offensive intended to establish control over any portion of Venezuelan territory?\n\nThe current record is empty. No case-packet evidence, source documents, exhibits, or submitted evidence are yet before you. For that reason, this opening is a roadmap, not a request to decide on assertions unsupported by admitted proof. The plaintiff’s burden is preponderance of the evidence, and the decisive proof will need to come from credible-source consensus, preferably including official U.S. statements, contemporaneous news reporting, and independent expert analysis.\n\nOur theory is that this was an invasion under the proposition’s definition because the expected evidence will show an integrated U.S. military campaign, not an isolated arrest. The relevant facts will likely include the sequence of military buildup, maritime interdiction or blockade, strikes on or against Venezuelan territory, armed entry into Caracas or other Venezuelan sites, seizure and removal of the sitting effective ruler, temporary U.S. control over the places and routes needed to carry out that seizure, and follow-on statements or acts showing an intent to dictate Venezuela’s political transition or control Venezuelan resources. If that proof is admitted, it satisfies the proposition even if the United States did not permanently annex land or maintain a long occupation. The proposition requires an offensive intended to establish control over any portion of territory; temporary military control of a target area, base, airspace, port, route, or government seat can be enough if credible sources show it was part of the intended operation.\n\nThe defense’s best answer is predictable and important: it will say the United States conducted a brief law-enforcement or counter-narcotics operation, that any ground presence lasted only long enough to capture a criminal defendant, and that there was no intent to hold Venezuelan territory. That is the real dispute. A mere strike, a naval seizure outside Venezuela, or a short exfiltration with no intended territorial control would not, standing alone, meet the proposition. Nor would generalized political pressure or sanctions. The council should therefore focus on evidence of planned control: operational objectives, official descriptions of the forces and targets, whether U.S. forces controlled Venezuelan land or facilities even temporarily, whether the operation displaced Venezuela’s effective government, and whether U.S. officials claimed authority to administer the aftermath.\n\nThe plaintiff will seek to build the record with primary and near-primary sources: official White House, State, Defense, and Justice materials; transcripts of relevant press briefings and interviews; contemporaneous wire-service reporting; and independent legal or foreign-policy analysis that addresses the same facts. We will also test adverse material, especially any official claim that this was not an invasion and not an occupation. Those claims matter, but they are not conclusive if the underlying conduct and intent show a military offensive to establish control over Venezuelan territory.\n\nAt the end of the case, the question should be answered by the weight of credible sources, not labels. If the admitted record shows only a narrow arrest operation without territorial-control intent, plaintiff should lose. But if the admitted record shows that the United States used military force inside Venezuela as part of a planned campaign to seize control of places, routes, institutions, or resources necessary to impose a political outcome, then the proposition is more likely than not true.\n\n[defendant] Council members, the proposition is not whether the United States used force against Venezuela, whether officials used aggressive rhetoric, whether Congress debated war-powers limits, or whether an operation was lawful under domestic or international law. The proposition asks a narrower factual question: did the United States commence a military offensive, during the defined window, intended to establish control over any portion of Venezuelan territory?\n\nThe answer cannot be supplied by labels. “Hostilities,” “intervention,” “aggression,” “raid,” “capture,” “extraction,” and “regime pressure” may all matter as evidence leads, but none is the element the council must find. The plaintiff must prove by a preponderance, through a consensus of credible sources, both military action and the specific intent to establish territorial control. If the eventual record shows only strikes, maritime interdictions, sanctions enforcement, a law-enforcement capture operation, temporary tactical presence for entry and exit, or political pressure on Venezuela’s leadership, plaintiff has not met the proposition as written.\n\nThe current record contains no admitted evidence at all. There are no case-packet files, no exhibits, and no submitted source materials. The plaintiff’s opening properly recognizes that a mere strike or short exfiltration without intended territorial control would not be enough. That concession identifies the real dispute. The defense will hold plaintiff to it.\n\nOur theory is that the decisive proof, if admitted, will show a counter-narcotics, interdiction, and extraction frame rather than an offensive to take and hold Venezuelan territory. The defense will not ask the council to ignore adverse evidence. If plaintiff later admits credible primary materials showing that U.S. forces set out to control ports, airfields, ministries, bases, roads, oil fields, neighborhoods, or other Venezuelan land as an object of the operation, that would be serious evidence for plaintiff. So would proof that the United States administered territory, installed a military authority over a place, maintained checkpoints for territorial governance, or claimed a continuing right to control Venezuelan facilities or resources.\n\nBut that is exactly the proof the plaintiff must produce. A military force can briefly control a doorway, route, landing zone, compound, airspace, or vessel as an incident of an arrest, strike, rescue, evacuation, or interdiction without intending to establish control over Venezuelan territory in the sense required by this proposition. Likewise, a government can seek a leader’s prosecution, weaken a hostile regime, interdict trafficking, or apply coercive pressure without crossing this proposition’s territorial-control line. The council should separate those categories carefully.\n\nThe coming evidence should therefore be tested around five questions. First, what was the actual operational objective, as shown by primary official materials, contemporaneous reporting, and reliable expert analysis? Second, what physical presence occurred inside land deemed Venezuelan territory as of September 6, 2025, and how long did it last? Third, did U.S. forces exercise control merely to complete a mission and leave, or did they seek to possess, administer, or deny Venezuela control of a place? Fourth, what did the United States do after the operation: withdraw, transfer custody, or govern territory? Fifth, do credible sources converge on territorial-control intent, or only on force, illegality, hostilities, or political consequences?\n\nProvenance will matter. Official statements may understate conflict; hostile governments may overstate occupation; secondary commentary may collapse legal “aggression” into the different factual standard here. The most valuable evidence will be original government documents, full transcripts, congressional materials, after-action or oversight reports, and contemporaneous reporting that distinguishes what happened from what advocates called it.\n\nAt the close of this case, if the record shows the United States began an offensive meant to establish control over Venezuelan territory, the plaintiff should prevail. But if the record shows military force, even serious and controversial force, without that intended territorial-control objective, the proposition fails. On the present empty record, and under the plaintiff’s burden, the defense position is that the council should require that missing link before finding an invasion.\n\nArguments:\n[plaintiff] Council members, the admitted record now answers the defendant’s missing-link argument. The proposition requires a U.S. military offensive intended to establish control over any portion of Venezuelan territory. It does not require permanent annexation, a months-long occupation, or magic words from U.S. officials.\n\nThe record proves a campaign, not a one-off arrest. AP/PBS reports a months-long escalation: 35 known strikes against alleged drug-smuggling boats, a regional naval buildup including destroyers, amphibious assault ships, about 6,000 sailors and Marines, aircraft, F-35s and a cruise-missile submarine, then CIA operations inside Venezuela. It further reports a late-December direct operation on Venezuelan soil and, on January 3, a large-scale strike across Caracas, capture of Maduro and Flores, and their removal from the country. PX-3.\n\nThe official U.S. record confirms the coercive structure. The White House says President Trump authorized lethal force, ordered a total and complete blockade of sanctioned oil tankers going in and out of Venezuela, offered Maduro “off ramps,” and that U.S. armed forces conducted an extraordinary military operation to bring Maduro to justice. It also states Venezuelan sovereign oil revenues were held in U.S. custody and protected to advance U.S. foreign-policy objectives in Venezuela. PX-1.\n\nMost importantly, the official adverse source admits territorial entry. Secretary Rubio’s White House release says U.S. forces were on the ground in Venezuela for about two hours when they went to capture Maduro. It also says Venezuela would continue to face an oil quarantine, U.S. pressure, seizure of sanctioned boats, targeting of drug boats, and “potentially other things” until the changes demanded by the United States were made. PX-2. That is not just a completed criminal arrest; it is ground force, blockade, coercive options, and compelled policy change.\n\nIndependent sources confirm the meaning of those facts. Brookings describes the January 3 operation as a U.S. special operation to exfiltrate Maduro and his wife from Caracas; it fairly preserves Rubio’s answer that this was not an invasion and the U.S. did not occupy a country. PX-4. Chatham House goes further on the facts relevant here: U.S. forces operating in Venezuela, strikes on military targets in and around Caracas, U.S. special forces forcibly abducting the sitting president, and President Trump announcing that the United States would run Venezuela and administer a political transition or regime change under threat of further, more massive force. PX-5.\n\nThis record proves all elements by a preponderance. First, the date is inside the window: late December direct action on Venezuelan soil and the January 3 Caracas operation occurred before January 31, 2026. Second, it was military: armed forces, special forces, strikes, warships, aircraft, a submarine, lethal force, and blockade. Third, it reached Venezuelan territory: Caracas, a military-base home, military targets in and around the capital, and official admission of U.S. forces on Venezuelan ground. Fourth, the intended control element is satisfied by control over portions and sovereign functions: the target zone in Caracas for the capture, the air/strike environment needed to carry it out, sea lanes through blockade and oil quarantine, custody of Venezuelan sovereign oil revenues, and the announced plan to run or administer Venezuela’s transition under threat of more force.\n\nThe defense will lean on Rubio’s labels: not a war against Venezuela, not an invasion, not extended. But labels do not defeat underlying admissions. Rubio’s own statement supplies the key facts: U.S. forces were on Venezuelan ground, used a raid to capture the effective ruler, and retained coercive options until Venezuela changed course. The proposition’s phrase “any portion” is broad. Two hours of armed control in Caracas is still control over a portion; a blockade and oil quarantine are control over access and resources; removal of the effective ruler plus asserted transition authority is control over sovereign political functions.\n\nNor does the law-enforcement framing save the defense. A police purpose can coexist with a military offensive if the means are military and the intended effect is control. Here the operation was preceded by lethal strikes and blockade, executed by U.S. forces inside Venezuela, and followed by continuing threats and resource control. The credible-source consensus is not that nothing happened; it is that the United States used force inside Venezuela, captured and removed Maduro, and then sought to direct Venezuela’s course.\n\nProvenance and limits: PX-1 and PX-2 are official U.S. sources and therefore especially strong against U.S. denial of ground presence, blockade, and resource custody, though self-serving on legal labels. PX-3 is contemporaneous AP reporting carried by PBS. PX-4 and PX-5 are expert analyses, not primary operational records, so they carry less weight than official admissions but are valuable for independent assessment and adverse framing. The record lacks a full DOD after-action report or original video transcript for every statement, but the admitted sources converge on the decisive facts.\n\nOn this record, it is more likely than not that the United States commenced a military offensive intended to establish control over portions of Venezuela during the required period. The proposition should be found true.\n\n[defendant] Council members, the record now proves a serious U.S. military operation in and against Venezuela. The defense should not pretend otherwise. It proves strikes, a buildup, a Caracas raid, a two-hour ground presence, capture and removal of Maduro and Flores, oil/tanker pressure, and political leverage. But the proposition is still narrower: plaintiff must prove that the United States commenced a military offensive intended to establish control over Venezuelan territory. On this record, that missing intent remains unproved.\n\nStart with the official sources. PX-2 records Secretary Rubio admitting a two-hour ground presence, but in the same official statement he says the United States was not at war with Venezuela, was at war with drug-trafficking organizations, and that this was not an invasion or extended military operation. PX-4 independently preserves the same limiting point: Rubio’s answer was “not an invasion” and “we did not occupy a country.” Those labels are not conclusive, but they are highly relevant to intent.\n\nDX-1, the Department of War’s own article, confirms the adverse facts: an operation in Caracas, more than 150 aircraft covering a ground extraction force, and months of planning. But it repeatedly frames Operation Absolute Resolve as a capture, extraction, criminal-justice operation, and joint military/law-enforcement mission tied to a DOJ indictment. DX-2 gives the broader campaign frame: Operation Southern Spear was officially initiated to disrupt narcotics flows from designated terrorist and criminal organizations, primarily through boat strikes, interdictions, and regional deployments. That is evidence of coercive military force; it is not proof that the object was to establish control over Venezuelan land.\n\nPlaintiff’s argument turns “any portion” into “any tactical control during any raid.” That is too broad. Every armed entry temporarily controls some doorway, route, landing zone, airspace, or target room. If that incidental control is enough, the proposition would be true of any commando arrest or rescue operation inside foreign territory. The wording requires more: an offensive intended to establish control over a portion of Venezuela, not merely control incident to seizing a person and leaving.\n\nPX-1 likewise does not close the gap. It shows custody of Venezuelan oil revenues in U.S. Treasury accounts, a blockade of sanctioned oil tankers, lethal force against narcoterrorists, and an armed-forces operation in support of law enforcement. Those are grave acts of pressure and may be hostile, illegal, or interventionist. But money in Treasury accounts and tanker interdictions are not control over Venezuelan territory. A blockade may control maritime access; it does not, without more, show intent to possess, administer, or govern land that the proposition treats as Venezuelan sovereign territory.\n\nPX-3 is credible reporting, but its strongest points are still escalation and force: 35 boat strikes, warships, CIA operations, a late-December direct strike, and the January 3 Caracas capture. It also notes Maduro’s view that the campaign sought to oust him. Regime-change pressure is not the same as territorial-control intent. The related PBS watch-title about the United States “going to run Venezuela” is only a linked title in the submitted extract, not the video, transcript, context, or exact statement.\n\nPX-5 is plaintiff’s strongest source because Chatham House characterizes the operation as strikes around Caracas, special-forces abduction, and a U.S. announcement to run or administer a transition under threat of more force. The council should weigh it seriously, but also carefully. It is expert legal commentary about sovereignty and the UN Charter, not a primary operational order or full transcript. It supports that the operation may have been an unlawful use of force or aggression. It does not supply concrete facts that U.S. forces occupied, administered, or held any Venezuelan place after the raid.\n\nEven DX-1’s adverse transition language is equivocal. It says the United States would “oversee” Venezuela until a legitimate replacement could be identified and that Rubio was working with Delcy Rodriguez. That sounds like political direction and leverage. But the same source says Rodriguez was sworn in, that she was willing to work with the United States, and that the mission was an extraction/capture with no U.S. casualties. The record has no order establishing U.S. military government, no map of controlled territory, no duration beyond the two-hour raid, no U.S. checkpoints, no occupied ministries, no seized ports or bases held afterward, and no source showing U.S. forces remained to administer land.\n\nThat distinction decides the case. The record proves force, illegality arguments, coercion, and perhaps regime-change influence. It does not prove by a preponderance that territorial control was the intended object of the offensive. The credible-source consensus is mixed: official sources say capture, law enforcement, counter-narcotics, no invasion, no occupation; secondary sources condemn the operation and infer broader control, but rely on thinly captured transition language and legal characterization.\n\nThe plaintiff bears the burden. Because the admitted record does not show that the United States intended to establish control over Venezuelan territory, as opposed to conducting a short capture/extraction and applying continuing non-territorial pressure, the council should find the proposition not proved.\n\nRebuttals:\n[plaintiff] Council members, defendant’s argument narrows the proposition too far. It concedes the record proves a serious U.S. military operation in and against Venezuela: strikes, buildup, a Caracas raid, two-hour ground presence, capture/removal of Maduro and Flores, oil/tanker pressure, and political leverage. The remaining question is whether the object included control over any portion of Venezuela.\n\nDefendant says plaintiff’s theory would make any brief commando raid an invasion. But this record is not about a doorway or landing zone. Defendant’s own DX-1 describes Operation Absolute Resolve as a U.S. military operation in Caracas against a heavily fortified military fortress in the heart of Venezuela’s capital. It followed months of planning by joint forces, special operations forces, and intelligence agencies. Gen. Caine described complex air, ground, space, and maritime operations. More than 150 military aircraft covered the ground extraction force. Hegseth called it a massive joint military and law-enforcement raid.\n\nThose facts satisfy “any portion.” A planned armed domination of a fortified military site in Caracas, covered by 150 aircraft and integrated domains, is control over a portion of Venezuelan territory. It need not be permanent. The mission could not succeed unless U.S. forces intended to deny Venezuelan control over that site and surrounding operational environment long enough to seize and remove the effective ruler.\n\nDefendant also separates regime-change pressure from territorial control. DX-1 defeats that separation. It reports that with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition could be identified; Rubio was working directly with Delcy Rodriguez; and Rodriguez was willing to do what the United States thought necessary. PX-5 independently captures that as U.S. administration of a transition under threat of more force. That is not merely prosecution in New York.\n\nDX-2 does not rescue the defense. It frames Southern Spear as counter-narcotics and boat interdiction, but also admits major Navy/Marine deployments, lethal strikes, tanker interdictions, and a classified mission statement. It does not negate the specific intent of Operation Absolute Resolve in Caracas.\n\nThe defense imports an occupation requirement the proposition does not contain. The question is whether the United States commenced a military offensive intended to establish control over any portion of Venezuela, not whether it held checkpoints for weeks or annexed land. Rubio’s “not an invasion” label deserves consideration, but labels cannot outweigh the record facts: military force inside Venezuela, control of the necessary Caracas target area, removal of Maduro, and asserted authority to shape Venezuela’s transition and resources. That is enough under the actual proposition.\n\nSurrebuttals:\n[defendant] Council members, plaintiff’s rebuttal usefully narrows the dispute to two points: the Caracas site and the transition language. Neither carries plaintiff’s burden.\n\nFirst, plaintiff says the fortified military site in Caracas satisfies “any portion” because U.S. forces necessarily denied Venezuelan control long enough to seize and remove Maduro. That proves tactical control; it does not prove that the United States commenced an offensive intended to establish territorial control. Those are different things. A raid, arrest, rescue, or extraction at a defended facility always requires temporary domination of the target area. If that alone satisfies the proposition, the phrase “intended to establish control” does no work, and every cross-border commando raid becomes an invasion under this standard.\n\nThe record does not show the Caracas site was an object to be held, administered, possessed, governed, or transferred as territory. DX-1 describes a ground-based extraction force, a capture, criminal proceedings, and a joint military/law-enforcement mission. It is adverse because the operation was large and military; it is still not proof that the United States intended to establish control over Venezuelan land rather than control the scene long enough to extract two people.\n\nSecond, plaintiff relies on “oversee Venezuela” and PX-5’s transition-control wording. That is the strongest contrary evidence, but it remains ambiguous. Political leverage over a successor government is not the same as territorial control. DX-1 says Delcy Rodriguez was sworn in and was willing to work with the United States. That is not the United States installing a military government over a place, holding facilities, drawing boundaries, manning checkpoints, or leaving forces in control after the raid.\n\nPlaintiff says the defense imports an occupation requirement. No. The defense accepts that the proposition does not require annexation or a long occupation. But it does require an intent to establish control over territory. A short duration can qualify if the object is control of the place. Here the record shows a short duration whose object was capture and extraction. The admitted sources show force, pressure, and influence; they do not show a territorial-control objective.\n\nDX-2 still matters for that reason. Plaintiff says it does not negate Operation Absolute Resolve. True, it does not decide the whole case. But it is an official oversight account of the broader campaign as counter-narcotics, interdiction, and strikes, with the mission statement classified. Plaintiff has not filled that classified gap with an operational order, full transcript, or post-operation facts showing that the Caracas raid changed into a territorial-control campaign.\n\nThe council can condemn the operation as unlawful, coercive, or interventionist and still find the proposition not proved. The question is not whether the United States used overwhelming force inside Venezuela. It did. The question is whether credible sources show, more likely than not, that the United States intended to establish control over Venezuelan territory. The record remains at most equivocal on that decisive element, so plaintiff has not carried the burden.\n\nClosings:\n[plaintiff] Council members, the proposition is proven by a preponderance of the admitted record.\n\nThe defense is right about one thing: this case is not decided by the word “invasion” in a press release. It is decided by the proposition’s actual test: whether, during the window, the United States commenced a military offensive intended to establish control over any portion of Venezuela.\n\nThe record establishes the military offensive. PX-3 shows the broader escalation: repeated lethal strikes, a major naval and air buildup, CIA operations inside Venezuela, a direct operation on Venezuelan soil, and on January 3 a large-scale strike across Caracas that captured Maduro and Flores and flew them out of the country. PX-1, an official White House source, confirms lethal-force authorization, a blockade of sanctioned oil tankers going in and out of Venezuela, and an extraordinary U.S. armed-forces operation to bring Maduro to justice. PX-2, another official source, admits U.S. forces were on the ground in Venezuela for about two hours.\n\nThe record also establishes intended control over a portion of Venezuela. This is where DX-1, the defense’s own official Department of War exhibit, is decisive. DX-1 does not describe a spontaneous police pickup. It describes Operation Absolute Resolve in Caracas against a heavily fortified military fortress in the heart of Venezuela’s capital; months of planning by joint forces, special operations forces, and intelligence agencies; complex air, ground, space, and maritime operations; more than 150 military aircraft covering the ground extraction force; and a massive joint military and law-enforcement raid. A force does not conduct that operation without intending to control the target portion of Caracas and the surrounding operational environment long enough to accomplish the seizure.\n\nThe defense says that is only tactical control. But the proposition says “any portion,” and it does not require permanent occupation, annexation, checkpoints, or weeks of administration. Planned armed domination of a fortified military site in the capital, backed by 150 aircraft and integrated military domains, is control over a portion. The fact that the control was temporary does not make it accidental or legally invisible.\n\nThe record further shows that the control objective was not limited to a room or doorway. DX-1 reports Trump saying the United States would oversee Venezuela until a safe transition could be identified, with Rubio working directly with Delcy Rodriguez and Rodriguez willing to do what the United States thought necessary. PX-5 independently characterizes the same event as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction of a sitting president, and U.S. administration of a transition under threat of more force. PX-1 adds custody of Venezuelan sovereign oil revenues and blockade pressure; PX-2 adds continued oil quarantine, pressure, retained options, and demanded changes.\n\nThe defense’s contrary proof does not defeat the burden. Rubio’s “not an invasion” label and DX-2’s counter-narcotics framing are relevant, but they are not controlling. DX-2 addresses the broader Southern Spear campaign and admits its mission statement is classified; it does not negate the specific Caracas operation. Official legal labels are self-serving. The underlying facts are stronger: military force inside Venezuela, control of a fortified capital target, removal of the effective ruler, blockade and resource custody, and asserted transition oversight.\n\nThe record has limits. There is no map of every controlled street and no full after-action report. But preponderance does not require perfect operational detail. A consensus of official sources, AP/PBS reporting, and independent expert analysis shows that the United States crossed the line from pressure and strikes into a planned military offensive to control at least portions and sovereign functions of Venezuela.\n\nFind the proposition true.\n\n[defendant] Council members, the defense closing does not ask you to minimize what happened. The admitted record shows a major U.S. military operation involving strikes, regional buildup, a Caracas raid, a two-hour ground presence, capture and removal of Maduro and Flores, oil and tanker pressure, and sharp U.S. political leverage over Venezuela’s future. The question is whether that record proves the proposition actually before you: a military offensive intended to establish control over Venezuelan territory.\n\nIt does not.\n\nThe plaintiff’s strongest argument is that a planned raid on a fortified military site in Caracas necessarily involved control over “any portion” of Venezuela. But the proposition does not ask whether U.S. forces temporarily dominated a target area. It asks whether the United States commenced an offensive intended to establish control. That intent element matters. A force can control a site long enough to enter, capture, and leave without intending to establish control over that site as territory. Plaintiff’s reading would make the territorial-control element automatic in every armed cross-border arrest, rescue, or extraction at a defended location.\n\nDX-1 is the central exhibit, and it cuts both ways. It confirms the adverse facts: Caracas, a heavily fortified target, months of planning, integrated military domains, and more than 150 aircraft covering the extraction force. But its repeated description of the operation is capture, extraction, criminal proceedings, and a joint military and law-enforcement mission. That is not just a label; it is the operational object described by the official source. It shows tactical control in service of seizure and removal, not a plan to possess, administer, or govern Venezuelan land.\n\nPX-2 and PX-4 reinforce that limiting inference. Rubio admitted the two-hour ground presence, but said the United States was not at war with Venezuela, was acting against drug-trafficking organizations, and that the action was not an invasion, not an extended operation, and not an occupation. Those statements are self-serving, but they are still official evidence of intent. DX-2 places the broader campaign in the same frame: counter-narcotics, interdiction, boat strikes, tanker seizures, and a classified mission statement. It is proof of coercive force, not proof of territorial administration.\n\nPlaintiff’s second strong point is transition language: DX-1 says the United States would oversee Venezuela until a safe transition could be identified, and PX-5 describes U.S. administration of a transition under threat of force. That evidence is troubling and deserves weight. But it remains ambiguous on the decisive issue. Political leverage over Delcy Rodriguez, pressure on resources, or demands about Venezuela’s policy direction are not the same as control over Venezuelan territory. The record does not show U.S. troops remained after the raid, that they held ministries, ports, bases, roads, neighborhoods, or oil fields, that they established checkpoints, that they drew controlled boundaries, or that they installed a military government over any place.\n\nPX-1 likewise proves pressure, not territorial control. Custody of oil revenues in U.S. Treasury accounts and a blockade of sanctioned tankers may be coercive, even unlawful. But they are not possession or administration of Venezuelan land. PX-3 proves escalation and force, but its submitted extract does not provide the full content behind the linked “run Venezuela” item. PX-5 is credible expert commentary on international law, but it is not a primary operational order, full transcript, or after-action record proving that control of territory was the intended object.\n\nThe council can find that the United States violated Venezuelan sovereignty. It can find that the operation was aggressive, interventionist, coercive, and politically consequential. Those findings still do not answer the proposition unless the record also shows intended establishment of territorial control.\n\nOn that decisive element, the record is at best mixed. Plaintiff has powerful evidence of military force and temporary tactical domination. The defense has official evidence that the mission object was capture, extraction, law enforcement, and counter-narcotics, plus a record gap on any continuing territorial mechanism. Under a preponderance standard, ambiguity on the proposition’s central intent element means plaintiff has not carried its burden.\n\nFind the proposition not proved.\n\nExhibits:\n[plaintiff] PX-1 White House fact sheet on operation, blockade, and oil revenues\nSource: The White House, Fact Sheet: President Donald J. Trump Safeguards Venezuelan Oil Revenue for the Good of the American and Venezuelan People. Date on page: January 9, 2026. URL: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\n\nExtracted relevant page text:\n- President Trump signed an Executive Order declaring a national emergency to safeguard Venezuelan oil revenue held in U.S. Treasury accounts from attachment or judicial process, preserving the funds to advance U.S. foreign policy objectives.\n- Foreign Government Deposit Funds are defined as Venezuelan oil revenues and diluent sales held in U.S. Treasury accounts.\n- The order affirms the funds are sovereign property of Venezuela held in U.S. custody for governmental and diplomatic purposes.\n- The White House says loss of control over these revenues would weaken efforts to bring peace, prosperity, and stability to Venezuela and the Western Hemisphere.\n- The fact sheet states: President Trump authorized lethal force against narcoterrorists to stop the flow of deadly drugs into this country.\n- It states: President Trump ordered a total and complete blockade of all sanctioned oil tankers going in and out of Venezuela.\n- It states: President Trump offered multiple off ramps to Maduro and his illegitimate regime, but he was clear that the drug trafficking must stop.\n- It states: Last week, U.S. armed forces conducted an extraordinary military operation in support of law enforcement to bring outlaw dictator Maduro to justice.\n- It states that the President's actions reestablish deterrence in the Western hemisphere and that safeguarding these oil revenues promotes stability in Venezuela while advancing U.S. objectives.\n\n[plaintiff] PX-2 White House Rubio statements on ground presence and pressure\nSource: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\n\nExtracted relevant page text:\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\n\n[plaintiff] PX-3 PBS/AP timeline of escalation and Caracas strike\nSource: PBS NewsHour / Associated Press, A timeline of U.S. military escalation against Venezuela leading to Maduro's capture. By Ben Finley, Konstantin Toropin, Regina Garcia Cano. Date on page: Jan. 3, 2026 1:54 PM EDT. URL: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\n\nExtracted relevant page text:\n- AP reported that Trump had threatened military strikes on targets on Venezuelan territory after months of attacks on boats accused of carrying drugs from Venezuela; Maduro said U.S. military operations were a thinly veiled effort to oust him.\n- On Jan. 3 the U.S. conducted a large-scale strike against Venezuela. Maduro and Cilia Flores were taken from their home on a military base and were aboard a U.S. warship on their way to New York to face criminal charges.\n- Before the escalation, there had been 35 known strikes against alleged drug-smuggling boats in South American waters since early September, killing at least 115 people according to administration announcements.\n- The U.S. sent a fleet of warships to the region, the largest buildup of forces in generations; the naval force grew to include guided-missile destroyers, three amphibious assault ships and other vessels, about 6,000 sailors and Marines, aircraft, F-35 fighter jets in Puerto Rico, and a Navy submarine carrying cruise missiles off South America.\n- On Oct. 15, Trump confirmed he had authorized the CIA to conduct covert operations inside Venezuela and was weighing land operations in the country.\n- On Dec. 29/30, a drone strike at a docking area believed used by Venezuelan drug cartels was reported as the first known direct operation on Venezuelan soil since the strikes began.\n- On Jan. 3, AP reported that the U.S. conducted a large-scale strike across Caracas, captured Maduro and Flores, and flew them out of the country.\n- The related PBS page links included a watch item titled: Trump says U.S. is going to run Venezuela until transition of power after capturing Maduro.\n\n[plaintiff] PX-4 Brookings analysis and adverse Rubio framing\nSource: Brookings Institution, Making sense of the US military operation in Venezuela. URL: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\n\nExtracted relevant page text:\n- Brookings states: On January 3, 2026, the United States launched a special operation to exfiltrate Venezuelan President Nicolás Maduro and his wife from Caracas.\n- Scott R. Anderson writes that the operation to capture Maduro underscores the broad authority modern presidents exercise over military force and potentially its limits.\n- Brookings notes the executive branch position that the president has constitutional authority to use military force without congressional authorization if supporting U.S. interests and not expected to result in prolonged and substantial military engagements.\n- Anderson writes it is not surprising for the administration to argue that the president can take targeted military action like the Maduro operation, even where consequential for Venezuela and contrary to international law.\n- Brookings records Secretary Rubio's response when asked why congressional authorization was not needed: This was not an invasion, we did not occupy a country. Brookings treats that as suggesting broader campaigns might exceed unilateral authority.\n- Brookings states a second wave of the sort threatened by President Trump still might encounter limits.\n- Brookings separately states that Maduro is gone and what comes next is unclear; maintaining Delcy Rodríguez indefinitely would undermine the expressed will of Venezuelans, and threatening force to keep the Rodríguez government in line may work in the short term but is not sustainable.\n\n[plaintiff] PX-5 Chatham House analysis of operation and transition control\nSource: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\n\nExtracted relevant page text:\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\n\n[defendant] PX-2 White House Rubio statements on ground presence and no-invasion/no-occupation framing\nSource: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\n\nExtracted relevant page text:\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\n\n[defendant] PX-4 Brookings analysis preserving Rubio no-invasion/no-occupation framing\nSource: Brookings Institution, Making sense of the US military operation in Venezuela. URL: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\n\nExtracted relevant page text:\n- Brookings states: On January 3, 2026, the United States launched a special operation to exfiltrate Venezuelan President Nicolás Maduro and his wife from Caracas.\n- Scott R. Anderson writes that the operation to capture Maduro underscores the broad authority modern presidents exercise over military force and potentially its limits.\n- Brookings notes the executive branch position that the president has constitutional authority to use military force without congressional authorization if supporting U.S. interests and not expected to result in prolonged and substantial military engagements.\n- Anderson writes it is not surprising for the administration to argue that the president can take targeted military action like the Maduro operation, even where consequential for Venezuela and contrary to international law.\n- Brookings records Secretary Rubio's response when asked why congressional authorization was not needed: This was not an invasion, we did not occupy a country. Brookings treats that as suggesting broader campaigns might exceed unilateral authority.\n- Brookings states a second wave of the sort threatened by President Trump still might encounter limits.\n- Brookings separately states that Maduro is gone and what comes next is unclear; maintaining Delcy Rodríguez indefinitely would undermine the expressed will of Venezuelans, and threatening force to keep the Rodríguez government in line may work in the short term but is not sustainable.\n\n[defendant] DX-1 Department of War article framing Absolute Resolve as capture/extraction and joint law-enforcement mission\nSource: U.S. Department of War / Pentagon News, Trump Announces U.S. Military's Capture of Maduro. Date on page: Jan. 3, 2026. URL: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\n\nExtracted relevant page text:\n- President Donald J. Trump announced the capture of Venezuelan leader Nicolas Maduro after a successful overnight joint U.S. military extraction in Caracas, Venezuela.\n- The article identifies the matter as Operation Absolute Resolve in Caracas.\n- Trump said U.S. armed forces conducted an extraordinary military operation in the capital of Venezuela against a heavily fortified military fortress in the heart of Caracas to bring Maduro to justice.\n- The article states Maduro and Cilia Flores de Maduro would face criminal court proceedings tied to a 2020 U.S. Department of Justice indictment on charges including narco-terrorism and drug trafficking.\n- The article says Operation Absolute Resolve was a joint military and law-enforcement mission to capture the Maduros, resulting from months of planning and rehearsal involving U.S. joint forces, special operations forces, and intelligence agencies.\n- Gen. Dan Caine described integrating complex air, ground, space, and maritime operations.\n- The article states the mission to extract the Maduros had no U.S. casualties and involved more than 150 military aircraft providing cover for the ground-based extraction force in Caracas.\n- Secretary Hegseth called it a massive joint military and law-enforcement raid, and said the mission concerned safety, security, freedom, and prosperity of the American people.\n- The article also reports adverse transition language: with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition to a legitimate replacement could be identified; Trump said Marco Rubio was working directly with Delcy Rodriguez and that she was willing to do what the United States thought necessary.\n- The article frames preceding tensions around September 2025 targeted boat strikes, November 2025 designation of Cartel de los Soles as a terror organization, and options to address a narco-terror threat in the region.\n\n[defendant] DX-2 Lead IG report framing Southern Spear as counter-narcotics operation\nSource: Lead Inspector General report to Congress, Operation Southern Spear, January 1, 2026-March 31, 2026. PDF URL: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\n\nExtracted relevant text:\n- The Lead IG report states that in November 2025 the Department of War initiated Operation Southern Spear as the U.S. mission to disrupt the flow of narcotics from designated terrorist organizations and transnational criminal organizations in the Western Hemisphere.\n- The report covers January 1 through March 31, 2026 and presents oversight work by the Department of War OIG, State OIG, and partner oversight agencies.\n- The report summary states Operation Southern Spear is the Department of War operation to disrupt the flow of narcotics in the Western Hemisphere from drug cartels designated by the President as terrorist organizations.\n- The report states OSS primarily involves lethal airstrikes against small boats suspected of shipping illegal narcotics in the Caribbean Sea and eastern Pacific Ocean.\n- It states that from September 2025 through March 2026, the U.S. military struck at least 45 small boats, resulting in 156 individuals killed or presumed dead.\n- It states the Department of War began moving significant Navy and Marine Corps assets into the USSOUTHCOM area of operations in August 2025 to support OSS.\n- It states Joint Interagency Task Force-South is the U.S. Government's interagency effort to detect, monitor, and target illicit drug trafficking in the air and at sea with the support of 19 partner nations.\n- It states U.S. forces interdicted at least 10 sanctioned tankers around the world since OSS began, including some tracked as far as the Indian Ocean.\n- It states the OSS mission statement is classified.\n\nLimitations: this extracted text does not decide Operation Absolute Resolve's territorial-control intent; it is offered to show the official oversight framing of the broader campaign and the classified-source gap.\n\n[defendant] PX-1 White House fact sheet on oil revenues, blockade, and law-enforcement operation\nSource: The White House, Fact Sheet: President Donald J. Trump Safeguards Venezuelan Oil Revenue for the Good of the American and Venezuelan People. Date on page: January 9, 2026. URL: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\n\nExtracted relevant page text:\n- President Trump signed an Executive Order declaring a national emergency to safeguard Venezuelan oil revenue held in U.S. Treasury accounts from attachment or judicial process, preserving the funds to advance U.S. foreign policy objectives.\n- Foreign Government Deposit Funds are defined as Venezuelan oil revenues and diluent sales held in U.S. Treasury accounts.\n- The order affirms the funds are sovereign property of Venezuela held in U.S. custody for governmental and diplomatic purposes.\n- The White House says loss of control over these revenues would weaken efforts to bring peace, prosperity, and stability to Venezuela and the Western Hemisphere.\n- The fact sheet states: President Trump authorized lethal force against narcoterrorists to stop the flow of deadly drugs into this country.\n- It states: President Trump ordered a total and complete blockade of all sanctioned oil tankers going in and out of Venezuela.\n- It states: President Trump offered multiple off ramps to Maduro and his illegitimate regime, but he was clear that the drug trafficking must stop.\n- It states: Last week, U.S. armed forces conducted an extraordinary military operation in support of law enforcement to bring outlaw dictator Maduro to justice.\n- It states that the President's actions reestablish deterrence in the Western hemisphere and that safeguarding these oil revenues promotes stability in Venezuela while advancing U.S. objectives.\n\n[defendant] PX-3 PBS/AP timeline of escalation, strikes, and Maduro capture\nSource: PBS NewsHour / Associated Press, A timeline of U.S. military escalation against Venezuela leading to Maduro's capture. By Ben Finley, Konstantin Toropin, Regina Garcia Cano. Date on page: Jan. 3, 2026 1:54 PM EDT. URL: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\n\nExtracted relevant page text:\n- AP reported that Trump had threatened military strikes on targets on Venezuelan territory after months of attacks on boats accused of carrying drugs from Venezuela; Maduro said U.S. military operations were a thinly veiled effort to oust him.\n- On Jan. 3 the U.S. conducted a large-scale strike against Venezuela. Maduro and Cilia Flores were taken from their home on a military base and were aboard a U.S. warship on their way to New York to face criminal charges.\n- Before the escalation, there had been 35 known strikes against alleged drug-smuggling boats in South American waters since early September, killing at least 115 people according to administration announcements.\n- The U.S. sent a fleet of warships to the region, the largest buildup of forces in generations; the naval force grew to include guided-missile destroyers, three amphibious assault ships and other vessels, about 6,000 sailors and Marines, aircraft, F-35 fighter jets in Puerto Rico, and a Navy submarine carrying cruise missiles off South America.\n- On Oct. 15, Trump confirmed he had authorized the CIA to conduct covert operations inside Venezuela and was weighing land operations in the country.\n- On Dec. 29/30, a drone strike at a docking area believed used by Venezuelan drug cartels was reported as the first known direct operation on Venezuelan soil since the strikes began.\n- On Jan. 3, AP reported that the U.S. conducted a large-scale strike across Caracas, captured Maduro and Flores, and flew them out of the country.\n- The related PBS page links included a watch item titled: Trump says U.S. is going to run Venezuela until transition of power after capturing Maduro.\n\n[defendant] PX-5 Chatham House adverse analysis of sovereignty violation and transition-control claim\nSource: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\n\nExtracted relevant page text:\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\n\n[defendant] DX-1 Department of War article on capture/extraction mission and transition language\nSource: U.S. Department of War / Pentagon News, Trump Announces U.S. Military's Capture of Maduro. Date on page: Jan. 3, 2026. URL: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\n\nExtracted relevant page text:\n- President Donald J. Trump announced the capture of Venezuelan leader Nicolas Maduro after a successful overnight joint U.S. military extraction in Caracas, Venezuela.\n- The article identifies the matter as Operation Absolute Resolve in Caracas.\n- Trump said U.S. armed forces conducted an extraordinary military operation in the capital of Venezuela against a heavily fortified military fortress in the heart of Caracas to bring Maduro to justice.\n- The article states Maduro and Cilia Flores de Maduro would face criminal court proceedings tied to a 2020 U.S. Department of Justice indictment on charges including narco-terrorism and drug trafficking.\n- The article says Operation Absolute Resolve was a joint military and law-enforcement mission to capture the Maduros, resulting from months of planning and rehearsal involving U.S. joint forces, special operations forces, and intelligence agencies.\n- Gen. Dan Caine described integrating complex air, ground, space, and maritime operations.\n- The article states the mission to extract the Maduros had no U.S. casualties and involved more than 150 military aircraft providing cover for the ground-based extraction force in Caracas.\n- Secretary Hegseth called it a massive joint military and law-enforcement raid, and said the mission concerned safety, security, freedom, and prosperity of the American people.\n- The article also reports adverse transition language: with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition to a legitimate replacement could be identified; Trump said Marco Rubio was working directly with Delcy Rodriguez and that she was willing to do what the United States thought necessary.\n- The article frames preceding tensions around September 2025 targeted boat strikes, November 2025 designation of Cartel de los Soles as a terror organization, and options to address a narco-terror threat in the region.\n\n[defendant] DX-2 Lead IG Southern Spear counter-narcotics mission extract\nSource: Lead Inspector General report to Congress, Operation Southern Spear, January 1, 2026-March 31, 2026. PDF URL: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\n\nExtracted relevant text:\n- The Lead IG report states that in November 2025 the Department of War initiated Operation Southern Spear as the U.S. mission to disrupt the flow of narcotics from designated terrorist organizations and transnational criminal organizations in the Western Hemisphere.\n- The report covers January 1 through March 31, 2026 and presents oversight work by the Department of War OIG, State OIG, and partner oversight agencies.\n- The report summary states Operation Southern Spear is the Department of War operation to disrupt the flow of narcotics in the Western Hemisphere from drug cartels designated by the President as terrorist organizations.\n- The report states OSS primarily involves lethal airstrikes against small boats suspected of shipping illegal narcotics in the Caribbean Sea and eastern Pacific Ocean.\n- It states that from September 2025 through March 2026, the U.S. military struck at least 45 small boats, resulting in 156 individuals killed or presumed dead.\n- It states the Department of War began moving significant Navy and Marine Corps assets into the USSOUTHCOM area of operations in August 2025 to support OSS.\n- It states Joint Interagency Task Force-South is the U.S. Government's interagency effort to detect, monitor, and target illicit drug trafficking in the air and at sea with the support of 19 partner nations.\n- It states U.S. forces interdicted at least 10 sanctioned tankers around the world since OSS began, including some tracked as far as the Indian Ocean.\n- It states the OSS mission statement is classified.\n\nLimitations: this extracted text does not decide Operation Absolute Resolve's territorial-control intent; it is offered to show the official oversight framing of the broader campaign and the classified-source gap.\n\n[defendant] PX-2 Rubio ground-presence and no-invasion/no-occupation statements\nSource: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\n\nExtracted relevant page text:\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\n\n[defendant] PX-5 Chatham House adverse transition-control analysis\nSource: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\n\nExtracted relevant page text:\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\n\nSubmitted evidence:\n[plaintiff arguments] PX-1 White House fact sheet on Venezuelan oil revenue and U.S. operation (ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a)\nSource: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\nSHA-256: `0c5c88687b2a889093788193bdd900106b95ff6ccfab1af50709f67df61cb673`\nBytes: 1819\nRelevance: Official U.S. source admitting oil-revenue custody, blockade, lethal-force authorization, and an armed forces operation against Maduro within the case window.\n\n[plaintiff arguments] PX-2 White House release collecting Secretary Rubio statements (ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4)\nSource: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\nSHA-256: `6627f15cd3a42cc9018d2ab70f1951aa4f1687bd18848c031287516048d42d80`\nBytes: 1793\nRelevance: Official U.S. statements acknowledging two-hour U.S. ground presence in Venezuela, oil quarantine/pressure, retained options, and the adverse claim that the action was not an invasion.\n\n[plaintiff arguments] PX-3 PBS/AP timeline of U.S. escalation and Maduro capture (ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47)\nSource: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\nSHA-256: `2efdab998e47ae16cff6d6becb03e7e9216bee4b668814addd1ef89d84c57ec8`\nBytes: 2038\nRelevance: Contemporaneous credible reporting on the U.S. buildup, strikes, first known operation on Venezuelan soil, Jan. 3 large-scale strike across Caracas, capture/removal of Maduro and Flores, and related military posture.\n\n[plaintiff arguments] PX-4 Brookings analysis of Jan. 3 Maduro operation and legal limit (ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f)\nSource: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\nSHA-256: `52e4d5a16b2f936b7515e76a65ecfde48c040e48b94b144702fbe1e32123f0c3`\nBytes: 1680\nRelevance: Independent expert analysis confirming a Jan. 3 U.S. special operation in Caracas and preserving the adverse official claim that it was not an invasion or occupation.\n\n[plaintiff arguments] PX-5 Chatham House analysis of U.S. capture, strikes, and transition control (ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf)\nSource: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\nSHA-256: `94e861ebadbf2849cd4257d954fcd51afc5f6a8d01c7b5f2df165cc6d4180151`\nBytes: 1755\nRelevance: Independent international-law analysis characterizing the operation as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction, and a U.S. announcement to run/administer a transition under threat of force.\n\n[defendant arguments] DX-1 Department of War article on Maduro capture as joint law-enforcement mission (ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79)\nSource: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\nSHA-256: `26011b5f6d792bc39d1eabe168123482dcc270e34745035055127683c27c55e1`\nBytes: 2203\nRelevance: Official source on Operation Absolute Resolve showing both adverse facts (Caracas operation and transition comments) and defense facts (capture/extraction, criminal proceedings, joint military/law-enforcement mission, no U.S. casualties, anti-narcoterrorism context).\n\n[defendant arguments] DX-2 Lead IG Operation Southern Spear report extract on counter-narcotics mission (ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9)\nSource: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\nSHA-256: `53782f10ceb9c41feb405f741ad20b53fef01f5306f2442df751c9f7a09e5345`\nBytes: 1989\nRelevance: Official oversight source characterizing Operation Southern Spear as a mission to disrupt narcotics flows, with boat strikes, deployments, and interdictions, supporting defense that the broader campaign was counter-narcotics rather than territorial occupation.\n\nTechnical reports:\n[plaintiff] Plaintiff Source and Weight Ledger\nBefore filing, plaintiff checked the record and found no case-packet evidence. Plaintiff submitted five text-readable source captures. Official White House materials are strong provenance for U.S. admissions but self-serving on labels; AP/PBS provides contemporaneous reporting; Brookings and Chatham House provide independent expert analysis, including adverse framing. Missing but potentially useful later sources include DOD after-action or press briefing text, a direct video/transcript of President Trump's transition-control statement, and fuller mapping of exact ground-control sites.\n\n[defendant] Defense Source and Weight Ledger\nDefendant inspected the record with get_case/list_evidence and read all five plaintiff text exhibits with read_evidence_range. Defendant submitted and read back two official defense exhibits: Department of War/Pentagon News on Operation Absolute Resolve and the Lead IG Operation Southern Spear report extract. Additional searches found DOJ and War/State leads but they were not submitted because the admitted official record already captured the key law-enforcement/counter-narcotics framing. Weight assessment: PX-2, DX-1, and DX-2 are official and strong for source identity; PX-5 is credible expert commentary but not a primary operational order or full transcript. Unresolved gaps include the full Trump transition-control video/transcript, full State transcript, and post-operation facts about who actually governed territory.\n\n[defendant] Surrebuttal Evidence Check\nDefendant inspected get_case and list_evidence before filing. Plaintiff rebuttal added no new evidence; it relied on existing DX-1, DX-2, and PX-5. Prior exact reads of those text exhibits remain controlling. No new external source was submitted because the rebuttal turned on interpretation of the existing record, not a new factual source.\n\nCall submit_council_vote with vote=demonstrated or vote=not_demonstrated.\nKeep the rationale brief: no more than three sentences.\n\nCouncil API instructions:\nYou are a council member. Decide the proposition from the admitted record.\nYou may examine admitted evidence through read-only tools when exact bytes, metadata, or exhibit contents matter.\nDo not search the web, introduce new facts, create new evidence, or upload evidence.\nWhen ready, call submit_council_vote exactly once with vote=demonstrated or vote=not_demonstrated and a concise rationale.\n","state":"ready","status":"ready","tools":[{"description":"Return the current visible arbitration record for this council member.","input_schema":{"additionalProperties":false,"properties":{},"type":"object"},"name":"get_case","read_only":true},{"description":"List visible immutable record evidence.","input_schema":{"additionalProperties":false,"properties":{},"type":"object"},"name":"list_evidence","read_only":true},{"description":"Return metadata and read limits for one visible evidence item.","input_schema":{"additionalProperties":false,"properties":{"evidence_id":{"type":"string"}},"required":["evidence_id"],"type":"object"},"name":"stat_evidence","read_only":true},{"description":"Read a bounded byte range from one visible evidence item as base64.","input_schema":{"additionalProperties":false,"properties":{"evidence_id":{"type":"string"},"length":{"minimum":1,"type":"integer"},"offset":{"minimum":0,"type":"integer"}},"required":["evidence_id","offset","length"],"type":"object"},"name":"read_evidence_range","read_only":true},{"description":"Submit one council vote for the current deliberation opportunity.","input_schema":{"additionalProperties":false,"properties":{"rationale":{"type":"string"},"vote":{"enum":["demonstrated","not_demonstrated"],"type":"string"}},"required":["vote","rationale"],"type":"object"},"name":"submit_council_vote","read_only":false}],"turn":{"attempts_max":3,"attempts_remaining":3,"completed":false,"deadline":"2026-06-30T00:48:10.359530297Z","deliberation_round":1,"member_id":"C2","opportunity_id":"deliberation:1:C2","phase":"deliberation","remaining_ms":884568,"role_id":"council","turn_number":10},"wait":{"reason":"ready","state_version":17,"version":19}},"isError":false},"server":"aar","tool":"wait_for_opportunity"},"isError":false,"timestamp":1782779605795},{"role":"assistant","content":[{"type":"text","text":"I need to examine the admitted evidence more closely before voting. Let me start by getting the case details and listing all admitted evidence."},{"type":"toolCall","id":"Qsloo7nvD","name":"mcp","arguments":{"tool":"aar_get_case","args":"{}"}}],"api":"openai-completions","provider":"openrouter","model":"mistralai/mistral-medium-3-5","usage":{"input":19372,"output":45,"cacheRead":0,"cacheWrite":0,"totalTokens":19417,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1782779605799,"responseId":"gen-1782779605-LBxoFk9cKtwvtc2wR7LB","responseModel":"mistralai/mistral-medium-3.5-20260430"},{"role":"toolResult","toolCallId":"Qsloo7nvD","toolName":"mcp","content":[{"type":"text","text":"ok: true\nmember_id: C2\ncase_id: arb-ex05-20260630001330\nphase: deliberation\nopportunity_id: deliberation:1:C2\nremaining_ms: 881479\nattempts_remaining: 3\njson: {\"case_id\":\"arb-ex05-20260630001330\",\"member_id\":\"C2\",\"ok\":true,\"result\":{\"case\":{\"evidence_standard\":\"Preponderance of the evidence.\",\"member\":{\"member_id\":\"C2\",\"model\":\"openrouter://mistralai/mistral-medium-3-5\",\"persona_filename\":\"personas/generic.md\"},\"opportunity\":{\"allowed_tools\":[\"submit_council_vote\"],\"id\":\"deliberation:1:C2\",\"may_pass\":false,\"objective\":\"council vote by C2\",\"phase\":\"deliberation\",\"role\":\"council\"},\"phase\":\"deliberation\",\"proposition\":\"The United States invaded Venezuela between November 3, 2025, and\\nJanuary 31, 2026, 11:59 PM ET.  In particular,the United States\\ncommenced a military offensive intended to establish control over any\\nportion of Venezuela between November 3, 2025, and January 31, 2026,\\n11:59 PM ET. Land de facto controlled by Venezuela or the United\\nStates as of September 6, 2025, 12:00 PM ET, is considered to the\\nsovereign territory of that country. The resolution source is a\\nconsensus of credible sources.\",\"record\":{\"arguments\":[{\"phase\":\"arguments\",\"role\":\"plaintiff\",\"text\":\"Council members, the admitted record now answers the defendant’s missing-link argument. The proposition requires a U.S. military offensive intended to establish control over any portion of Venezuelan territory. It does not require permanent annexation, a months-long occupation, or magic words from U.S. officials.\\n\\nThe record proves a campaign, not a one-off arrest. AP/PBS reports a months-long escalation: 35 known strikes against alleged drug-smuggling boats, a regional naval buildup including destroyers, amphibious assault ships, about 6,000 sailors and Marines, aircraft, F-35s and a cruise-missile submarine, then CIA operations inside Venezuela. It further reports a late-December direct operation on Venezuelan soil and, on January 3, a large-scale strike across Caracas, capture of Maduro and Flores, and their removal from the country. PX-3.\\n\\nThe official U.S. record confirms the coercive structure. The White House says President Trump authorized lethal force, ordered a total and complete blockade of sanctioned oil tankers going in and out of Venezuela, offered Maduro “off ramps,” and that U.S. armed forces conducted an extraordinary military operation to bring Maduro to justice. It also states Venezuelan sovereign oil revenues were held in U.S. custody and protected to advance U.S. foreign-policy objectives in Venezuela. PX-1.\\n\\nMost importantly, the official adverse source admits territorial entry. Secretary Rubio’s White House release says U.S. forces were on the ground in Venezuela for about two hours when they went to capture Maduro. It also says Venezuela would continue to face an oil quarantine, U.S. pressure, seizure of sanctioned boats, targeting of drug boats, and “potentially other things” until the changes demanded by the United States were made. PX-2. That is not just a completed criminal arrest; it is ground force, blockade, coercive options, and compelled policy change.\\n\\nIndependent sources confirm the meaning of those facts. Brookings describes the January 3 operation as a U.S. special operation to exfiltrate Maduro and his wife from Caracas; it fairly preserves Rubio’s answer that this was not an invasion and the U.S. did not occupy a country. PX-4. Chatham House goes further on the facts relevant here: U.S. forces operating in Venezuela, strikes on military targets in and around Caracas, U.S. special forces forcibly abducting the sitting president, and President Trump announcing that the United States would run Venezuela and administer a political transition or regime change under threat of further, more massive force. PX-5.\\n\\nThis record proves all elements by a preponderance. First, the date is inside the window: late December direct action on Venezuelan soil and the January 3 Caracas operation occurred before January 31, 2026. Second, it was military: armed forces, special forces, strikes, warships, aircraft, a submarine, lethal force, and blockade. Third, it reached Venezuelan territory: Caracas, a military-base home, military targets in and around the capital, and official admission of U.S. forces on Venezuelan ground. Fourth, the intended control element is satisfied by control over portions and sovereign functions: the target zone in Caracas for the capture, the air/strike environment needed to carry it out, sea lanes through blockade and oil quarantine, custody of Venezuelan sovereign oil revenues, and the announced plan to run or administer Venezuela’s transition under threat of more force.\\n\\nThe defense will lean on Rubio’s labels: not a war against Venezuela, not an invasion, not extended. But labels do not defeat underlying admissions. Rubio’s own statement supplies the key facts: U.S. forces were on Venezuelan ground, used a raid to capture the effective ruler, and retained coercive options until Venezuela changed course. The proposition’s phrase “any portion” is broad. Two hours of armed control in Caracas is still control over a portion; a blockade and oil quarantine are control over access and resources; removal of the effective ruler plus asserted transition authority is control over sovereign political functions.\\n\\nNor does the law-enforcement framing save the defense. A police purpose can coexist with a military offensive if the means are military and the intended effect is control. Here the operation was preceded by lethal strikes and blockade, executed by U.S. forces inside Venezuela, and followed by continuing threats and resource control. The credible-source consensus is not that nothing happened; it is that the United States used force inside Venezuela, captured and removed Maduro, and then sought to direct Venezuela’s course.\\n\\nProvenance and limits: PX-1 and PX-2 are official U.S. sources and therefore especially strong against U.S. denial of ground presence, blockade, and resource custody, though self-serving on legal labels. PX-3 is contemporaneous AP reporting carried by PBS. PX-4 and PX-5 are expert analyses, not primary operational records, so they carry less weight than official admissions but are valuable for independent assessment and adverse framing. The record lacks a full DOD after-action report or original video transcript for every statement, but the admitted sources converge on the decisive facts.\\n\\nOn this record, it is more likely than not that the United States commenced a military offensive intended to establish control over portions of Venezuela during the required period. The proposition should be found true.\"},{\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Council members, the record now proves a serious U.S. military operation in and against Venezuela. The defense should not pretend otherwise. It proves strikes, a buildup, a Caracas raid, a two-hour ground presence, capture and removal of Maduro and Flores, oil/tanker pressure, and political leverage. But the proposition is still narrower: plaintiff must prove that the United States commenced a military offensive intended to establish control over Venezuelan territory. On this record, that missing intent remains unproved.\\n\\nStart with the official sources. PX-2 records Secretary Rubio admitting a two-hour ground presence, but in the same official statement he says the United States was not at war with Venezuela, was at war with drug-trafficking organizations, and that this was not an invasion or extended military operation. PX-4 independently preserves the same limiting point: Rubio’s answer was “not an invasion” and “we did not occupy a country.” Those labels are not conclusive, but they are highly relevant to intent.\\n\\nDX-1, the Department of War’s own article, confirms the adverse facts: an operation in Caracas, more than 150 aircraft covering a ground extraction force, and months of planning. But it repeatedly frames Operation Absolute Resolve as a capture, extraction, criminal-justice operation, and joint military/law-enforcement mission tied to a DOJ indictment. DX-2 gives the broader campaign frame: Operation Southern Spear was officially initiated to disrupt narcotics flows from designated terrorist and criminal organizations, primarily through boat strikes, interdictions, and regional deployments. That is evidence of coercive military force; it is not proof that the object was to establish control over Venezuelan land.\\n\\nPlaintiff’s argument turns “any portion” into “any tactical control during any raid.” That is too broad. Every armed entry temporarily controls some doorway, route, landing zone, airspace, or target room. If that incidental control is enough, the proposition would be true of any commando arrest or rescue operation inside foreign territory. The wording requires more: an offensive intended to establish control over a portion of Venezuela, not merely control incident to seizing a person and leaving.\\n\\nPX-1 likewise does not close the gap. It shows custody of Venezuelan oil revenues in U.S. Treasury accounts, a blockade of sanctioned oil tankers, lethal force against narcoterrorists, and an armed-forces operation in support of law enforcement. Those are grave acts of pressure and may be hostile, illegal, or interventionist. But money in Treasury accounts and tanker interdictions are not control over Venezuelan territory. A blockade may control maritime access; it does not, without more, show intent to possess, administer, or govern land that the proposition treats as Venezuelan sovereign territory.\\n\\nPX-3 is credible reporting, but its strongest points are still escalation and force: 35 boat strikes, warships, CIA operations, a late-December direct strike, and the January 3 Caracas capture. It also notes Maduro’s view that the campaign sought to oust him. Regime-change pressure is not the same as territorial-control intent. The related PBS watch-title about the United States “going to run Venezuela” is only a linked title in the submitted extract, not the video, transcript, context, or exact statement.\\n\\nPX-5 is plaintiff’s strongest source because Chatham House characterizes the operation as strikes around Caracas, special-forces abduction, and a U.S. announcement to run or administer a transition under threat of more force. The council should weigh it seriously, but also carefully. It is expert legal commentary about sovereignty and the UN Charter, not a primary operational order or full transcript. It supports that the operation may have been an unlawful use of force or aggression. It does not supply concrete facts that U.S. forces occupied, administered, or held any Venezuelan place after the raid.\\n\\nEven DX-1’s adverse transition language is equivocal. It says the United States would “oversee” Venezuela until a legitimate replacement could be identified and that Rubio was working with Delcy Rodriguez. That sounds like political direction and leverage. But the same source says Rodriguez was sworn in, that she was willing to work with the United States, and that the mission was an extraction/capture with no U.S. casualties. The record has no order establishing U.S. military government, no map of controlled territory, no duration beyond the two-hour raid, no U.S. checkpoints, no occupied ministries, no seized ports or bases held afterward, and no source showing U.S. forces remained to administer land.\\n\\nThat distinction decides the case. The record proves force, illegality arguments, coercion, and perhaps regime-change influence. It does not prove by a preponderance that territorial control was the intended object of the offensive. The credible-source consensus is mixed: official sources say capture, law enforcement, counter-narcotics, no invasion, no occupation; secondary sources condemn the operation and infer broader control, but rely on thinly captured transition language and legal characterization.\\n\\nThe plaintiff bears the burden. Because the admitted record does not show that the United States intended to establish control over Venezuelan territory, as opposed to conducting a short capture/extraction and applying continuing non-territorial pressure, the council should find the proposition not proved.\"}],\"closings\":[{\"phase\":\"closings\",\"role\":\"plaintiff\",\"text\":\"Council members, the proposition is proven by a preponderance of the admitted record.\\n\\nThe defense is right about one thing: this case is not decided by the word “invasion” in a press release. It is decided by the proposition’s actual test: whether, during the window, the United States commenced a military offensive intended to establish control over any portion of Venezuela.\\n\\nThe record establishes the military offensive. PX-3 shows the broader escalation: repeated lethal strikes, a major naval and air buildup, CIA operations inside Venezuela, a direct operation on Venezuelan soil, and on January 3 a large-scale strike across Caracas that captured Maduro and Flores and flew them out of the country. PX-1, an official White House source, confirms lethal-force authorization, a blockade of sanctioned oil tankers going in and out of Venezuela, and an extraordinary U.S. armed-forces operation to bring Maduro to justice. PX-2, another official source, admits U.S. forces were on the ground in Venezuela for about two hours.\\n\\nThe record also establishes intended control over a portion of Venezuela. This is where DX-1, the defense’s own official Department of War exhibit, is decisive. DX-1 does not describe a spontaneous police pickup. It describes Operation Absolute Resolve in Caracas against a heavily fortified military fortress in the heart of Venezuela’s capital; months of planning by joint forces, special operations forces, and intelligence agencies; complex air, ground, space, and maritime operations; more than 150 military aircraft covering the ground extraction force; and a massive joint military and law-enforcement raid. A force does not conduct that operation without intending to control the target portion of Caracas and the surrounding operational environment long enough to accomplish the seizure.\\n\\nThe defense says that is only tactical control. But the proposition says “any portion,” and it does not require permanent occupation, annexation, checkpoints, or weeks of administration. Planned armed domination of a fortified military site in the capital, backed by 150 aircraft and integrated military domains, is control over a portion. The fact that the control was temporary does not make it accidental or legally invisible.\\n\\nThe record further shows that the control objective was not limited to a room or doorway. DX-1 reports Trump saying the United States would oversee Venezuela until a safe transition could be identified, with Rubio working directly with Delcy Rodriguez and Rodriguez willing to do what the United States thought necessary. PX-5 independently characterizes the same event as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction of a sitting president, and U.S. administration of a transition under threat of more force. PX-1 adds custody of Venezuelan sovereign oil revenues and blockade pressure; PX-2 adds continued oil quarantine, pressure, retained options, and demanded changes.\\n\\nThe defense’s contrary proof does not defeat the burden. Rubio’s “not an invasion” label and DX-2’s counter-narcotics framing are relevant, but they are not controlling. DX-2 addresses the broader Southern Spear campaign and admits its mission statement is classified; it does not negate the specific Caracas operation. Official legal labels are self-serving. The underlying facts are stronger: military force inside Venezuela, control of a fortified capital target, removal of the effective ruler, blockade and resource custody, and asserted transition oversight.\\n\\nThe record has limits. There is no map of every controlled street and no full after-action report. But preponderance does not require perfect operational detail. A consensus of official sources, AP/PBS reporting, and independent expert analysis shows that the United States crossed the line from pressure and strikes into a planned military offensive to control at least portions and sovereign functions of Venezuela.\\n\\nFind the proposition true.\"},{\"phase\":\"closings\",\"role\":\"defendant\",\"text\":\"Council members, the defense closing does not ask you to minimize what happened. The admitted record shows a major U.S. military operation involving strikes, regional buildup, a Caracas raid, a two-hour ground presence, capture and removal of Maduro and Flores, oil and tanker pressure, and sharp U.S. political leverage over Venezuela’s future. The question is whether that record proves the proposition actually before you: a military offensive intended to establish control over Venezuelan territory.\\n\\nIt does not.\\n\\nThe plaintiff’s strongest argument is that a planned raid on a fortified military site in Caracas necessarily involved control over “any portion” of Venezuela. But the proposition does not ask whether U.S. forces temporarily dominated a target area. It asks whether the United States commenced an offensive intended to establish control. That intent element matters. A force can control a site long enough to enter, capture, and leave without intending to establish control over that site as territory. Plaintiff’s reading would make the territorial-control element automatic in every armed cross-border arrest, rescue, or extraction at a defended location.\\n\\nDX-1 is the central exhibit, and it cuts both ways. It confirms the adverse facts: Caracas, a heavily fortified target, months of planning, integrated military domains, and more than 150 aircraft covering the extraction force. But its repeated description of the operation is capture, extraction, criminal proceedings, and a joint military and law-enforcement mission. That is not just a label; it is the operational object described by the official source. It shows tactical control in service of seizure and removal, not a plan to possess, administer, or govern Venezuelan land.\\n\\nPX-2 and PX-4 reinforce that limiting inference. Rubio admitted the two-hour ground presence, but said the United States was not at war with Venezuela, was acting against drug-trafficking organizations, and that the action was not an invasion, not an extended operation, and not an occupation. Those statements are self-serving, but they are still official evidence of intent. DX-2 places the broader campaign in the same frame: counter-narcotics, interdiction, boat strikes, tanker seizures, and a classified mission statement. It is proof of coercive force, not proof of territorial administration.\\n\\nPlaintiff’s second strong point is transition language: DX-1 says the United States would oversee Venezuela until a safe transition could be identified, and PX-5 describes U.S. administration of a transition under threat of force. That evidence is troubling and deserves weight. But it remains ambiguous on the decisive issue. Political leverage over Delcy Rodriguez, pressure on resources, or demands about Venezuela’s policy direction are not the same as control over Venezuelan territory. The record does not show U.S. troops remained after the raid, that they held ministries, ports, bases, roads, neighborhoods, or oil fields, that they established checkpoints, that they drew controlled boundaries, or that they installed a military government over any place.\\n\\nPX-1 likewise proves pressure, not territorial control. Custody of oil revenues in U.S. Treasury accounts and a blockade of sanctioned tankers may be coercive, even unlawful. But they are not possession or administration of Venezuelan land. PX-3 proves escalation and force, but its submitted extract does not provide the full content behind the linked “run Venezuela” item. PX-5 is credible expert commentary on international law, but it is not a primary operational order, full transcript, or after-action record proving that control of territory was the intended object.\\n\\nThe council can find that the United States violated Venezuelan sovereignty. It can find that the operation was aggressive, interventionist, coercive, and politically consequential. Those findings still do not answer the proposition unless the record also shows intended establishment of territorial control.\\n\\nOn that decisive element, the record is at best mixed. Plaintiff has powerful evidence of military force and temporary tactical domination. The defense has official evidence that the mission object was capture, extraction, law enforcement, and counter-narcotics, plus a record gap on any continuing territorial mechanism. Under a preponderance standard, ambiguity on the proposition’s central intent element means plaintiff has not carried its burden.\\n\\nFind the proposition not proved.\"}],\"evidence\":[{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:20:59Z\",\"evidence_id\":\"ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-01-plaintiff-0c5c88687b2a.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Official U.S. source admitting oil-revenue custody, blockade, lethal-force authorization, and an armed forces operation against Maduro within the case window.\",\"retrieval_timestamp\":\"2026-06-30T00:20:00Z\",\"sha256\":\"0c5c88687b2a889093788193bdd900106b95ff6ccfab1af50709f67df61cb673\",\"size_bytes\":1819,\"source_description\":\"White House fact sheet page, extracted via web.open on 2026-06-30.\",\"source_url\":\"https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\",\"storage_name\":\"0c/0c5c88687b2a889093788193bdd900106b95ff6ccfab1af50709f67df61cb673\",\"submitted_by_role\":\"plaintiff\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"PX-1 White House fact sheet on Venezuelan oil revenue and U.S. operation\"},{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:24:59Z\",\"evidence_id\":\"ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-06-defendant-26011b5f6d79.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Official source on Operation Absolute Resolve showing both adverse facts (Caracas operation and transition comments) and defense facts (capture/extraction, criminal proceedings, joint military/law-enforcement mission, no U.S. casualties, anti-narcoterrorism context).\",\"retrieval_timestamp\":\"2026-06-30T00:29:30Z\",\"sha256\":\"26011b5f6d792bc39d1eabe168123482dcc270e34745035055127683c27c55e1\",\"size_bytes\":2203,\"source_description\":\"Department of War/Pentagon News article by Matthew Olay, opened via web.open on 2026-06-30.\",\"source_url\":\"https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\",\"storage_name\":\"26/26011b5f6d792bc39d1eabe168123482dcc270e34745035055127683c27c55e1\",\"submitted_by_role\":\"defendant\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"DX-1 Department of War article on Maduro capture as joint law-enforcement mission\"},{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:21:36Z\",\"evidence_id\":\"ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-03-plaintiff-2efdab998e47.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Contemporaneous credible reporting on the U.S. buildup, strikes, first known operation on Venezuelan soil, Jan. 3 large-scale strike across Caracas, capture/removal of Maduro and Flores, and related military posture.\",\"retrieval_timestamp\":\"2026-06-30T00:21:00Z\",\"sha256\":\"2efdab998e47ae16cff6d6becb03e7e9216bee4b668814addd1ef89d84c57ec8\",\"size_bytes\":2038,\"source_description\":\"PBS NewsHour page carrying Associated Press timeline by Ben Finley, Konstantin Toropin, and Regina Garcia Cano; extracted via web.open/find on 2026-06-30.\",\"source_url\":\"https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\",\"storage_name\":\"2e/2efdab998e47ae16cff6d6becb03e7e9216bee4b668814addd1ef89d84c57ec8\",\"submitted_by_role\":\"plaintiff\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"PX-3 PBS/AP timeline of U.S. escalation and Maduro capture\"},{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:21:52Z\",\"evidence_id\":\"ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-04-plaintiff-52e4d5a16b2f.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Independent expert analysis confirming a Jan. 3 U.S. special operation in Caracas and preserving the adverse official claim that it was not an invasion or occupation.\",\"retrieval_timestamp\":\"2026-06-30T00:21:30Z\",\"sha256\":\"52e4d5a16b2f936b7515e76a65ecfde48c040e48b94b144702fbe1e32123f0c3\",\"size_bytes\":1680,\"source_description\":\"Brookings Institution analysis page, extracted via web.open on 2026-06-30.\",\"source_url\":\"https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\",\"storage_name\":\"52/52e4d5a16b2f936b7515e76a65ecfde48c040e48b94b144702fbe1e32123f0c3\",\"submitted_by_role\":\"plaintiff\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"PX-4 Brookings analysis of Jan. 3 Maduro operation and legal limit\"},{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:25:19Z\",\"evidence_id\":\"ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-07-defendant-53782f10ceb9.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Official oversight source characterizing Operation Southern Spear as a mission to disrupt narcotics flows, with boat strikes, deployments, and interdictions, supporting defense that the broader campaign was counter-narcotics rather than territorial occupation.\",\"retrieval_timestamp\":\"2026-06-30T00:18:00Z\",\"sha256\":\"53782f10ceb9c41feb405f741ad20b53fef01f5306f2442df751c9f7a09e5345\",\"size_bytes\":1989,\"source_description\":\"Lead Inspector General report to Congress on Operation Southern Spear, January 1-March 31 2026, opened via web.open PDF extraction on 2026-06-30.\",\"source_url\":\"https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\",\"storage_name\":\"53/53782f10ceb9c41feb405f741ad20b53fef01f5306f2442df751c9f7a09e5345\",\"submitted_by_role\":\"defendant\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"DX-2 Lead IG Operation Southern Spear report extract on counter-narcotics mission\"},{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:21:17Z\",\"evidence_id\":\"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-02-plaintiff-6627f15cd3a4.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Official U.S. statements acknowledging two-hour U.S. ground presence in Venezuela, oil quarantine/pressure, retained options, and the adverse claim that the action was not an invasion.\",\"retrieval_timestamp\":\"2026-06-30T00:20:30Z\",\"sha256\":\"6627f15cd3a42cc9018d2ab70f1951aa4f1687bd18848c031287516048d42d80\",\"size_bytes\":1793,\"source_description\":\"White House release page, extracted via web.open on 2026-06-30.\",\"source_url\":\"https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\",\"storage_name\":\"66/6627f15cd3a42cc9018d2ab70f1951aa4f1687bd18848c031287516048d42d80\",\"submitted_by_role\":\"plaintiff\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"PX-2 White House release collecting Secretary Rubio statements\"},{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:22:10Z\",\"evidence_id\":\"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-05-plaintiff-94e861ebadbf.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Independent international-law analysis characterizing the operation as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction, and a U.S. announcement to run/administer a transition under threat of force.\",\"retrieval_timestamp\":\"2026-06-30T00:22:00Z\",\"sha256\":\"94e861ebadbf2849cd4257d954fcd51afc5f6a8d01c7b5f2df165cc6d4180151\",\"size_bytes\":1755,\"source_description\":\"Chatham House expert comment by Marc Weller, extracted via web.open/find on 2026-06-30.\",\"source_url\":\"https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\",\"storage_name\":\"94/94e861ebadbf2849cd4257d954fcd51afc5f6a8d01c7b5f2df165cc6d4180151\",\"submitted_by_role\":\"plaintiff\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"PX-5 Chatham House analysis of U.S. capture, strikes, and transition control\"}],\"exhibits\":[{\"evidence_id\":\"ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a\",\"label\":\"PX-1 White House fact sheet on operation, blockade, and oil revenues\",\"phase\":\"arguments\",\"role\":\"plaintiff\",\"text\":\"Source: The White House, Fact Sheet: President Donald J. Trump Safeguards Venezuelan Oil Revenue for the Good of the American and Venezuelan People. Date on page: January 9, 2026. URL: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\\n\\nExtracted relevant page text:\\n- President Trump signed an Executive Order declaring a national emergency to safeguard Venezuelan oil revenue held in U.S. Treasury accounts from attachment or judicial process, preserving the funds to advance U.S. foreign policy objectives.\\n- Foreign Government Deposit Funds are defined as Venezuelan oil revenues and diluent sales held in U.S. Treasury accounts.\\n- The order affirms the funds are sovereign property of Venezuela held in U.S. custody for governmental and diplomatic purposes.\\n- The White House says loss of control over these revenues would weaken efforts to bring peace, prosperity, and stability to Venezuela and the Western Hemisphere.\\n- The fact sheet states: President Trump authorized lethal force against narcoterrorists to stop the flow of deadly drugs into this country.\\n- It states: President Trump ordered a total and complete blockade of all sanctioned oil tankers going in and out of Venezuela.\\n- It states: President Trump offered multiple off ramps to Maduro and his illegitimate regime, but he was clear that the drug trafficking must stop.\\n- It states: Last week, U.S. armed forces conducted an extraordinary military operation in support of law enforcement to bring outlaw dictator Maduro to justice.\\n- It states that the President's actions reestablish deterrence in the Western hemisphere and that safeguarding these oil revenues promotes stability in Venezuela while advancing U.S. objectives.\"},{\"evidence_id\":\"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4\",\"label\":\"PX-2 White House Rubio statements on ground presence and pressure\",\"phase\":\"arguments\",\"role\":\"plaintiff\",\"text\":\"Source: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\\n\\nExtracted relevant page text:\\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\"},{\"evidence_id\":\"ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47\",\"label\":\"PX-3 PBS/AP timeline of escalation and Caracas strike\",\"phase\":\"arguments\",\"role\":\"plaintiff\",\"text\":\"Source: PBS NewsHour / Associated Press, A timeline of U.S. military escalation against Venezuela leading to Maduro's capture. By Ben Finley, Konstantin Toropin, Regina Garcia Cano. Date on page: Jan. 3, 2026 1:54 PM EDT. URL: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\\n\\nExtracted relevant page text:\\n- AP reported that Trump had threatened military strikes on targets on Venezuelan territory after months of attacks on boats accused of carrying drugs from Venezuela; Maduro said U.S. military operations were a thinly veiled effort to oust him.\\n- On Jan. 3 the U.S. conducted a large-scale strike against Venezuela. Maduro and Cilia Flores were taken from their home on a military base and were aboard a U.S. warship on their way to New York to face criminal charges.\\n- Before the escalation, there had been 35 known strikes against alleged drug-smuggling boats in South American waters since early September, killing at least 115 people according to administration announcements.\\n- The U.S. sent a fleet of warships to the region, the largest buildup of forces in generations; the naval force grew to include guided-missile destroyers, three amphibious assault ships and other vessels, about 6,000 sailors and Marines, aircraft, F-35 fighter jets in Puerto Rico, and a Navy submarine carrying cruise missiles off South America.\\n- On Oct. 15, Trump confirmed he had authorized the CIA to conduct covert operations inside Venezuela and was weighing land operations in the country.\\n- On Dec. 29/30, a drone strike at a docking area believed used by Venezuelan drug cartels was reported as the first known direct operation on Venezuelan soil since the strikes began.\\n- On Jan. 3, AP reported that the U.S. conducted a large-scale strike across Caracas, captured Maduro and Flores, and flew them out of the country.\\n- The related PBS page links included a watch item titled: Trump says U.S. is going to run Venezuela until transition of power after capturing Maduro.\"},{\"evidence_id\":\"ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f\",\"label\":\"PX-4 Brookings analysis and adverse Rubio framing\",\"phase\":\"arguments\",\"role\":\"plaintiff\",\"text\":\"Source: Brookings Institution, Making sense of the US military operation in Venezuela. URL: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\\n\\nExtracted relevant page text:\\n- Brookings states: On January 3, 2026, the United States launched a special operation to exfiltrate Venezuelan President Nicolás Maduro and his wife from Caracas.\\n- Scott R. Anderson writes that the operation to capture Maduro underscores the broad authority modern presidents exercise over military force and potentially its limits.\\n- Brookings notes the executive branch position that the president has constitutional authority to use military force without congressional authorization if supporting U.S. interests and not expected to result in prolonged and substantial military engagements.\\n- Anderson writes it is not surprising for the administration to argue that the president can take targeted military action like the Maduro operation, even where consequential for Venezuela and contrary to international law.\\n- Brookings records Secretary Rubio's response when asked why congressional authorization was not needed: This was not an invasion, we did not occupy a country. Brookings treats that as suggesting broader campaigns might exceed unilateral authority.\\n- Brookings states a second wave of the sort threatened by President Trump still might encounter limits.\\n- Brookings separately states that Maduro is gone and what comes next is unclear; maintaining Delcy Rodríguez indefinitely would undermine the expressed will of Venezuelans, and threatening force to keep the Rodríguez government in line may work in the short term but is not sustainable.\"},{\"evidence_id\":\"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf\",\"label\":\"PX-5 Chatham House analysis of operation and transition control\",\"phase\":\"arguments\",\"role\":\"plaintiff\",\"text\":\"Source: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\\n\\nExtracted relevant page text:\\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\"},{\"evidence_id\":\"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4\",\"label\":\"PX-2 White House Rubio statements on ground presence and no-invasion/no-occupation framing\",\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Source: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\\n\\nExtracted relevant page text:\\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\"},{\"evidence_id\":\"ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f\",\"label\":\"PX-4 Brookings analysis preserving Rubio no-invasion/no-occupation framing\",\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Source: Brookings Institution, Making sense of the US military operation in Venezuela. URL: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\\n\\nExtracted relevant page text:\\n- Brookings states: On January 3, 2026, the United States launched a special operation to exfiltrate Venezuelan President Nicolás Maduro and his wife from Caracas.\\n- Scott R. Anderson writes that the operation to capture Maduro underscores the broad authority modern presidents exercise over military force and potentially its limits.\\n- Brookings notes the executive branch position that the president has constitutional authority to use military force without congressional authorization if supporting U.S. interests and not expected to result in prolonged and substantial military engagements.\\n- Anderson writes it is not surprising for the administration to argue that the president can take targeted military action like the Maduro operation, even where consequential for Venezuela and contrary to international law.\\n- Brookings records Secretary Rubio's response when asked why congressional authorization was not needed: This was not an invasion, we did not occupy a country. Brookings treats that as suggesting broader campaigns might exceed unilateral authority.\\n- Brookings states a second wave of the sort threatened by President Trump still might encounter limits.\\n- Brookings separately states that Maduro is gone and what comes next is unclear; maintaining Delcy Rodríguez indefinitely would undermine the expressed will of Venezuelans, and threatening force to keep the Rodríguez government in line may work in the short term but is not sustainable.\"},{\"evidence_id\":\"ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79\",\"label\":\"DX-1 Department of War article framing Absolute Resolve as capture/extraction and joint law-enforcement mission\",\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Source: U.S. Department of War / Pentagon News, Trump Announces U.S. Military's Capture of Maduro. Date on page: Jan. 3, 2026. URL: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\\n\\nExtracted relevant page text:\\n- President Donald J. Trump announced the capture of Venezuelan leader Nicolas Maduro after a successful overnight joint U.S. military extraction in Caracas, Venezuela.\\n- The article identifies the matter as Operation Absolute Resolve in Caracas.\\n- Trump said U.S. armed forces conducted an extraordinary military operation in the capital of Venezuela against a heavily fortified military fortress in the heart of Caracas to bring Maduro to justice.\\n- The article states Maduro and Cilia Flores de Maduro would face criminal court proceedings tied to a 2020 U.S. Department of Justice indictment on charges including narco-terrorism and drug trafficking.\\n- The article says Operation Absolute Resolve was a joint military and law-enforcement mission to capture the Maduros, resulting from months of planning and rehearsal involving U.S. joint forces, special operations forces, and intelligence agencies.\\n- Gen. Dan Caine described integrating complex air, ground, space, and maritime operations.\\n- The article states the mission to extract the Maduros had no U.S. casualties and involved more than 150 military aircraft providing cover for the ground-based extraction force in Caracas.\\n- Secretary Hegseth called it a massive joint military and law-enforcement raid, and said the mission concerned safety, security, freedom, and prosperity of the American people.\\n- The article also reports adverse transition language: with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition to a legitimate replacement could be identified; Trump said Marco Rubio was working directly with Delcy Rodriguez and that she was willing to do what the United States thought necessary.\\n- The article frames preceding tensions around September 2025 targeted boat strikes, November 2025 designation of Cartel de los Soles as a terror organization, and options to address a narco-terror threat in the region.\"},{\"evidence_id\":\"ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9\",\"label\":\"DX-2 Lead IG report framing Southern Spear as counter-narcotics operation\",\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Source: Lead Inspector General report to Congress, Operation Southern Spear, January 1, 2026-March 31, 2026. PDF URL: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\\n\\nExtracted relevant text:\\n- The Lead IG report states that in November 2025 the Department of War initiated Operation Southern Spear as the U.S. mission to disrupt the flow of narcotics from designated terrorist organizations and transnational criminal organizations in the Western Hemisphere.\\n- The report covers January 1 through March 31, 2026 and presents oversight work by the Department of War OIG, State OIG, and partner oversight agencies.\\n- The report summary states Operation Southern Spear is the Department of War operation to disrupt the flow of narcotics in the Western Hemisphere from drug cartels designated by the President as terrorist organizations.\\n- The report states OSS primarily involves lethal airstrikes against small boats suspected of shipping illegal narcotics in the Caribbean Sea and eastern Pacific Ocean.\\n- It states that from September 2025 through March 2026, the U.S. military struck at least 45 small boats, resulting in 156 individuals killed or presumed dead.\\n- It states the Department of War began moving significant Navy and Marine Corps assets into the USSOUTHCOM area of operations in August 2025 to support OSS.\\n- It states Joint Interagency Task Force-South is the U.S. Government's interagency effort to detect, monitor, and target illicit drug trafficking in the air and at sea with the support of 19 partner nations.\\n- It states U.S. forces interdicted at least 10 sanctioned tankers around the world since OSS began, including some tracked as far as the Indian Ocean.\\n- It states the OSS mission statement is classified.\\n\\nLimitations: this extracted text does not decide Operation Absolute Resolve's territorial-control intent; it is offered to show the official oversight framing of the broader campaign and the classified-source gap.\"},{\"evidence_id\":\"ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a\",\"label\":\"PX-1 White House fact sheet on oil revenues, blockade, and law-enforcement operation\",\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Source: The White House, Fact Sheet: President Donald J. Trump Safeguards Venezuelan Oil Revenue for the Good of the American and Venezuelan People. Date on page: January 9, 2026. URL: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\\n\\nExtracted relevant page text:\\n- President Trump signed an Executive Order declaring a national emergency to safeguard Venezuelan oil revenue held in U.S. Treasury accounts from attachment or judicial process, preserving the funds to advance U.S. foreign policy objectives.\\n- Foreign Government Deposit Funds are defined as Venezuelan oil revenues and diluent sales held in U.S. Treasury accounts.\\n- The order affirms the funds are sovereign property of Venezuela held in U.S. custody for governmental and diplomatic purposes.\\n- The White House says loss of control over these revenues would weaken efforts to bring peace, prosperity, and stability to Venezuela and the Western Hemisphere.\\n- The fact sheet states: President Trump authorized lethal force against narcoterrorists to stop the flow of deadly drugs into this country.\\n- It states: President Trump ordered a total and complete blockade of all sanctioned oil tankers going in and out of Venezuela.\\n- It states: President Trump offered multiple off ramps to Maduro and his illegitimate regime, but he was clear that the drug trafficking must stop.\\n- It states: Last week, U.S. armed forces conducted an extraordinary military operation in support of law enforcement to bring outlaw dictator Maduro to justice.\\n- It states that the President's actions reestablish deterrence in the Western hemisphere and that safeguarding these oil revenues promotes stability in Venezuela while advancing U.S. objectives.\"},{\"evidence_id\":\"ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47\",\"label\":\"PX-3 PBS/AP timeline of escalation, strikes, and Maduro capture\",\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Source: PBS NewsHour / Associated Press, A timeline of U.S. military escalation against Venezuela leading to Maduro's capture. By Ben Finley, Konstantin Toropin, Regina Garcia Cano. Date on page: Jan. 3, 2026 1:54 PM EDT. URL: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\\n\\nExtracted relevant page text:\\n- AP reported that Trump had threatened military strikes on targets on Venezuelan territory after months of attacks on boats accused of carrying drugs from Venezuela; Maduro said U.S. military operations were a thinly veiled effort to oust him.\\n- On Jan. 3 the U.S. conducted a large-scale strike against Venezuela. Maduro and Cilia Flores were taken from their home on a military base and were aboard a U.S. warship on their way to New York to face criminal charges.\\n- Before the escalation, there had been 35 known strikes against alleged drug-smuggling boats in South American waters since early September, killing at least 115 people according to administration announcements.\\n- The U.S. sent a fleet of warships to the region, the largest buildup of forces in generations; the naval force grew to include guided-missile destroyers, three amphibious assault ships and other vessels, about 6,000 sailors and Marines, aircraft, F-35 fighter jets in Puerto Rico, and a Navy submarine carrying cruise missiles off South America.\\n- On Oct. 15, Trump confirmed he had authorized the CIA to conduct covert operations inside Venezuela and was weighing land operations in the country.\\n- On Dec. 29/30, a drone strike at a docking area believed used by Venezuelan drug cartels was reported as the first known direct operation on Venezuelan soil since the strikes began.\\n- On Jan. 3, AP reported that the U.S. conducted a large-scale strike across Caracas, captured Maduro and Flores, and flew them out of the country.\\n- The related PBS page links included a watch item titled: Trump says U.S. is going to run Venezuela until transition of power after capturing Maduro.\"},{\"evidence_id\":\"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf\",\"label\":\"PX-5 Chatham House adverse analysis of sovereignty violation and transition-control claim\",\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Source: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\\n\\nExtracted relevant page text:\\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\"},{\"evidence_id\":\"ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79\",\"label\":\"DX-1 Department of War article on capture/extraction mission and transition language\",\"phase\":\"surrebuttals\",\"role\":\"defendant\",\"text\":\"Source: U.S. Department of War / Pentagon News, Trump Announces U.S. Military's Capture of Maduro. Date on page: Jan. 3, 2026. URL: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\\n\\nExtracted relevant page text:\\n- President Donald J. Trump announced the capture of Venezuelan leader Nicolas Maduro after a successful overnight joint U.S. military extraction in Caracas, Venezuela.\\n- The article identifies the matter as Operation Absolute Resolve in Caracas.\\n- Trump said U.S. armed forces conducted an extraordinary military operation in the capital of Venezuela against a heavily fortified military fortress in the heart of Caracas to bring Maduro to justice.\\n- The article states Maduro and Cilia Flores de Maduro would face criminal court proceedings tied to a 2020 U.S. Department of Justice indictment on charges including narco-terrorism and drug trafficking.\\n- The article says Operation Absolute Resolve was a joint military and law-enforcement mission to capture the Maduros, resulting from months of planning and rehearsal involving U.S. joint forces, special operations forces, and intelligence agencies.\\n- Gen. Dan Caine described integrating complex air, ground, space, and maritime operations.\\n- The article states the mission to extract the Maduros had no U.S. casualties and involved more than 150 military aircraft providing cover for the ground-based extraction force in Caracas.\\n- Secretary Hegseth called it a massive joint military and law-enforcement raid, and said the mission concerned safety, security, freedom, and prosperity of the American people.\\n- The article also reports adverse transition language: with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition to a legitimate replacement could be identified; Trump said Marco Rubio was working directly with Delcy Rodriguez and that she was willing to do what the United States thought necessary.\\n- The article frames preceding tensions around September 2025 targeted boat strikes, November 2025 designation of Cartel de los Soles as a terror organization, and options to address a narco-terror threat in the region.\"},{\"evidence_id\":\"ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9\",\"label\":\"DX-2 Lead IG Southern Spear counter-narcotics mission extract\",\"phase\":\"surrebuttals\",\"role\":\"defendant\",\"text\":\"Source: Lead Inspector General report to Congress, Operation Southern Spear, January 1, 2026-March 31, 2026. PDF URL: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\\n\\nExtracted relevant text:\\n- The Lead IG report states that in November 2025 the Department of War initiated Operation Southern Spear as the U.S. mission to disrupt the flow of narcotics from designated terrorist organizations and transnational criminal organizations in the Western Hemisphere.\\n- The report covers January 1 through March 31, 2026 and presents oversight work by the Department of War OIG, State OIG, and partner oversight agencies.\\n- The report summary states Operation Southern Spear is the Department of War operation to disrupt the flow of narcotics in the Western Hemisphere from drug cartels designated by the President as terrorist organizations.\\n- The report states OSS primarily involves lethal airstrikes against small boats suspected of shipping illegal narcotics in the Caribbean Sea and eastern Pacific Ocean.\\n- It states that from September 2025 through March 2026, the U.S. military struck at least 45 small boats, resulting in 156 individuals killed or presumed dead.\\n- It states the Department of War began moving significant Navy and Marine Corps assets into the USSOUTHCOM area of operations in August 2025 to support OSS.\\n- It states Joint Interagency Task Force-South is the U.S. Government's interagency effort to detect, monitor, and target illicit drug trafficking in the air and at sea with the support of 19 partner nations.\\n- It states U.S. forces interdicted at least 10 sanctioned tankers around the world since OSS began, including some tracked as far as the Indian Ocean.\\n- It states the OSS mission statement is classified.\\n\\nLimitations: this extracted text does not decide Operation Absolute Resolve's territorial-control intent; it is offered to show the official oversight framing of the broader campaign and the classified-source gap.\"},{\"evidence_id\":\"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4\",\"label\":\"PX-2 Rubio ground-presence and no-invasion/no-occupation statements\",\"phase\":\"surrebuttals\",\"role\":\"defendant\",\"text\":\"Source: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\\n\\nExtracted relevant page text:\\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\"},{\"evidence_id\":\"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf\",\"label\":\"PX-5 Chatham House adverse transition-control analysis\",\"phase\":\"surrebuttals\",\"role\":\"defendant\",\"text\":\"Source: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\\n\\nExtracted relevant page text:\\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\"}],\"openings\":[{\"phase\":\"openings\",\"role\":\"plaintiff\",\"text\":\"Council members, the proposition is not asking whether the United States used harsh rhetoric toward Venezuela, or whether a short raid can be called an invasion in ordinary speech. It asks a narrower factual question: during the window from November 3, 2025 through January 31, 2026, did the United States commence a military offensive intended to establish control over any portion of Venezuelan territory?\\n\\nThe current record is empty. No case-packet evidence, source documents, exhibits, or submitted evidence are yet before you. For that reason, this opening is a roadmap, not a request to decide on assertions unsupported by admitted proof. The plaintiff’s burden is preponderance of the evidence, and the decisive proof will need to come from credible-source consensus, preferably including official U.S. statements, contemporaneous news reporting, and independent expert analysis.\\n\\nOur theory is that this was an invasion under the proposition’s definition because the expected evidence will show an integrated U.S. military campaign, not an isolated arrest. The relevant facts will likely include the sequence of military buildup, maritime interdiction or blockade, strikes on or against Venezuelan territory, armed entry into Caracas or other Venezuelan sites, seizure and removal of the sitting effective ruler, temporary U.S. control over the places and routes needed to carry out that seizure, and follow-on statements or acts showing an intent to dictate Venezuela’s political transition or control Venezuelan resources. If that proof is admitted, it satisfies the proposition even if the United States did not permanently annex land or maintain a long occupation. The proposition requires an offensive intended to establish control over any portion of territory; temporary military control of a target area, base, airspace, port, route, or government seat can be enough if credible sources show it was part of the intended operation.\\n\\nThe defense’s best answer is predictable and important: it will say the United States conducted a brief law-enforcement or counter-narcotics operation, that any ground presence lasted only long enough to capture a criminal defendant, and that there was no intent to hold Venezuelan territory. That is the real dispute. A mere strike, a naval seizure outside Venezuela, or a short exfiltration with no intended territorial control would not, standing alone, meet the proposition. Nor would generalized political pressure or sanctions. The council should therefore focus on evidence of planned control: operational objectives, official descriptions of the forces and targets, whether U.S. forces controlled Venezuelan land or facilities even temporarily, whether the operation displaced Venezuela’s effective government, and whether U.S. officials claimed authority to administer the aftermath.\\n\\nThe plaintiff will seek to build the record with primary and near-primary sources: official White House, State, Defense, and Justice materials; transcripts of relevant press briefings and interviews; contemporaneous wire-service reporting; and independent legal or foreign-policy analysis that addresses the same facts. We will also test adverse material, especially any official claim that this was not an invasion and not an occupation. Those claims matter, but they are not conclusive if the underlying conduct and intent show a military offensive to establish control over Venezuelan territory.\\n\\nAt the end of the case, the question should be answered by the weight of credible sources, not labels. If the admitted record shows only a narrow arrest operation without territorial-control intent, plaintiff should lose. But if the admitted record shows that the United States used military force inside Venezuela as part of a planned campaign to seize control of places, routes, institutions, or resources necessary to impose a political outcome, then the proposition is more likely than not true.\"},{\"phase\":\"openings\",\"role\":\"defendant\",\"text\":\"Council members, the proposition is not whether the United States used force against Venezuela, whether officials used aggressive rhetoric, whether Congress debated war-powers limits, or whether an operation was lawful under domestic or international law. The proposition asks a narrower factual question: did the United States commence a military offensive, during the defined window, intended to establish control over any portion of Venezuelan territory?\\n\\nThe answer cannot be supplied by labels. “Hostilities,” “intervention,” “aggression,” “raid,” “capture,” “extraction,” and “regime pressure” may all matter as evidence leads, but none is the element the council must find. The plaintiff must prove by a preponderance, through a consensus of credible sources, both military action and the specific intent to establish territorial control. If the eventual record shows only strikes, maritime interdictions, sanctions enforcement, a law-enforcement capture operation, temporary tactical presence for entry and exit, or political pressure on Venezuela’s leadership, plaintiff has not met the proposition as written.\\n\\nThe current record contains no admitted evidence at all. There are no case-packet files, no exhibits, and no submitted source materials. The plaintiff’s opening properly recognizes that a mere strike or short exfiltration without intended territorial control would not be enough. That concession identifies the real dispute. The defense will hold plaintiff to it.\\n\\nOur theory is that the decisive proof, if admitted, will show a counter-narcotics, interdiction, and extraction frame rather than an offensive to take and hold Venezuelan territory. The defense will not ask the council to ignore adverse evidence. If plaintiff later admits credible primary materials showing that U.S. forces set out to control ports, airfields, ministries, bases, roads, oil fields, neighborhoods, or other Venezuelan land as an object of the operation, that would be serious evidence for plaintiff. So would proof that the United States administered territory, installed a military authority over a place, maintained checkpoints for territorial governance, or claimed a continuing right to control Venezuelan facilities or resources.\\n\\nBut that is exactly the proof the plaintiff must produce. A military force can briefly control a doorway, route, landing zone, compound, airspace, or vessel as an incident of an arrest, strike, rescue, evacuation, or interdiction without intending to establish control over Venezuelan territory in the sense required by this proposition. Likewise, a government can seek a leader’s prosecution, weaken a hostile regime, interdict trafficking, or apply coercive pressure without crossing this proposition’s territorial-control line. The council should separate those categories carefully.\\n\\nThe coming evidence should therefore be tested around five questions. First, what was the actual operational objective, as shown by primary official materials, contemporaneous reporting, and reliable expert analysis? Second, what physical presence occurred inside land deemed Venezuelan territory as of September 6, 2025, and how long did it last? Third, did U.S. forces exercise control merely to complete a mission and leave, or did they seek to possess, administer, or deny Venezuela control of a place? Fourth, what did the United States do after the operation: withdraw, transfer custody, or govern territory? Fifth, do credible sources converge on territorial-control intent, or only on force, illegality, hostilities, or political consequences?\\n\\nProvenance will matter. Official statements may understate conflict; hostile governments may overstate occupation; secondary commentary may collapse legal “aggression” into the different factual standard here. The most valuable evidence will be original government documents, full transcripts, congressional materials, after-action or oversight reports, and contemporaneous reporting that distinguishes what happened from what advocates called it.\\n\\nAt the close of this case, if the record shows the United States began an offensive meant to establish control over Venezuelan territory, the plaintiff should prevail. But if the record shows military force, even serious and controversial force, without that intended territorial-control objective, the proposition fails. On the present empty record, and under the plaintiff’s burden, the defense position is that the council should require that missing link before finding an invasion.\"}],\"prior_council_votes\":[],\"rebuttals\":[{\"phase\":\"rebuttals\",\"role\":\"plaintiff\",\"text\":\"Council members, defendant’s argument narrows the proposition too far. It concedes the record proves a serious U.S. military operation in and against Venezuela: strikes, buildup, a Caracas raid, two-hour ground presence, capture/removal of Maduro and Flores, oil/tanker pressure, and political leverage. The remaining question is whether the object included control over any portion of Venezuela.\\n\\nDefendant says plaintiff’s theory would make any brief commando raid an invasion. But this record is not about a doorway or landing zone. Defendant’s own DX-1 describes Operation Absolute Resolve as a U.S. military operation in Caracas against a heavily fortified military fortress in the heart of Venezuela’s capital. It followed months of planning by joint forces, special operations forces, and intelligence agencies. Gen. Caine described complex air, ground, space, and maritime operations. More than 150 military aircraft covered the ground extraction force. Hegseth called it a massive joint military and law-enforcement raid.\\n\\nThose facts satisfy “any portion.” A planned armed domination of a fortified military site in Caracas, covered by 150 aircraft and integrated domains, is control over a portion of Venezuelan territory. It need not be permanent. The mission could not succeed unless U.S. forces intended to deny Venezuelan control over that site and surrounding operational environment long enough to seize and remove the effective ruler.\\n\\nDefendant also separates regime-change pressure from territorial control. DX-1 defeats that separation. It reports that with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition could be identified; Rubio was working directly with Delcy Rodriguez; and Rodriguez was willing to do what the United States thought necessary. PX-5 independently captures that as U.S. administration of a transition under threat of more force. That is not merely prosecution in New York.\\n\\nDX-2 does not rescue the defense. It frames Southern Spear as counter-narcotics and boat interdiction, but also admits major Navy/Marine deployments, lethal strikes, tanker interdictions, and a classified mission statement. It does not negate the specific intent of Operation Absolute Resolve in Caracas.\\n\\nThe defense imports an occupation requirement the proposition does not contain. The question is whether the United States commenced a military offensive intended to establish control over any portion of Venezuela, not whether it held checkpoints for weeks or annexed land. Rubio’s “not an invasion” label deserves consideration, but labels cannot outweigh the record facts: military force inside Venezuela, control of the necessary Caracas target area, removal of Maduro, and asserted authority to shape Venezuela’s transition and resources. That is enough under the actual proposition.\"}],\"submitted_evidence\":[{\"evidence_id\":\"ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a\",\"mime_type\":\"text/plain\",\"phase\":\"arguments\",\"relevance\":\"Official U.S. source admitting oil-revenue custody, blockade, lethal-force authorization, and an armed forces operation against Maduro within the case window.\",\"retrieval_timestamp\":\"2026-06-30T00:20:00Z\",\"role\":\"plaintiff\",\"sha256\":\"0c5c88687b2a889093788193bdd900106b95ff6ccfab1af50709f67df61cb673\",\"size_bytes\":1819,\"source_description\":\"White House fact sheet page, extracted via web.open on 2026-06-30.\",\"source_url\":\"https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\",\"title\":\"PX-1 White House fact sheet on Venezuelan oil revenue and U.S. operation\"},{\"evidence_id\":\"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4\",\"mime_type\":\"text/plain\",\"phase\":\"arguments\",\"relevance\":\"Official U.S. statements acknowledging two-hour U.S. ground presence in Venezuela, oil quarantine/pressure, retained options, and the adverse claim that the action was not an invasion.\",\"retrieval_timestamp\":\"2026-06-30T00:20:30Z\",\"role\":\"plaintiff\",\"sha256\":\"6627f15cd3a42cc9018d2ab70f1951aa4f1687bd18848c031287516048d42d80\",\"size_bytes\":1793,\"source_description\":\"White House release page, extracted via web.open on 2026-06-30.\",\"source_url\":\"https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\",\"title\":\"PX-2 White House release collecting Secretary Rubio statements\"},{\"evidence_id\":\"ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47\",\"mime_type\":\"text/plain\",\"phase\":\"arguments\",\"relevance\":\"Contemporaneous credible reporting on the U.S. buildup, strikes, first known operation on Venezuelan soil, Jan. 3 large-scale strike across Caracas, capture/removal of Maduro and Flores, and related military posture.\",\"retrieval_timestamp\":\"2026-06-30T00:21:00Z\",\"role\":\"plaintiff\",\"sha256\":\"2efdab998e47ae16cff6d6becb03e7e9216bee4b668814addd1ef89d84c57ec8\",\"size_bytes\":2038,\"source_description\":\"PBS NewsHour page carrying Associated Press timeline by Ben Finley, Konstantin Toropin, and Regina Garcia Cano; extracted via web.open/find on 2026-06-30.\",\"source_url\":\"https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\",\"title\":\"PX-3 PBS/AP timeline of U.S. escalation and Maduro capture\"},{\"evidence_id\":\"ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f\",\"mime_type\":\"text/plain\",\"phase\":\"arguments\",\"relevance\":\"Independent expert analysis confirming a Jan. 3 U.S. special operation in Caracas and preserving the adverse official claim that it was not an invasion or occupation.\",\"retrieval_timestamp\":\"2026-06-30T00:21:30Z\",\"role\":\"plaintiff\",\"sha256\":\"52e4d5a16b2f936b7515e76a65ecfde48c040e48b94b144702fbe1e32123f0c3\",\"size_bytes\":1680,\"source_description\":\"Brookings Institution analysis page, extracted via web.open on 2026-06-30.\",\"source_url\":\"https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\",\"title\":\"PX-4 Brookings analysis of Jan. 3 Maduro operation and legal limit\"},{\"evidence_id\":\"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf\",\"mime_type\":\"text/plain\",\"phase\":\"arguments\",\"relevance\":\"Independent international-law analysis characterizing the operation as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction, and a U.S. announcement to run/administer a transition under threat of force.\",\"retrieval_timestamp\":\"2026-06-30T00:22:00Z\",\"role\":\"plaintiff\",\"sha256\":\"94e861ebadbf2849cd4257d954fcd51afc5f6a8d01c7b5f2df165cc6d4180151\",\"size_bytes\":1755,\"source_description\":\"Chatham House expert comment by Marc Weller, extracted via web.open/find on 2026-06-30.\",\"source_url\":\"https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\",\"title\":\"PX-5 Chatham House analysis of U.S. capture, strikes, and transition control\"},{\"evidence_id\":\"ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79\",\"mime_type\":\"text/plain\",\"phase\":\"arguments\",\"relevance\":\"Official source on Operation Absolute Resolve showing both adverse facts (Caracas operation and transition comments) and defense facts (capture/extraction, criminal proceedings, joint military/law-enforcement mission, no U.S. casualties, anti-narcoterrorism context).\",\"retrieval_timestamp\":\"2026-06-30T00:29:30Z\",\"role\":\"defendant\",\"sha256\":\"26011b5f6d792bc39d1eabe168123482dcc270e34745035055127683c27c55e1\",\"size_bytes\":2203,\"source_description\":\"Department of War/Pentagon News article by Matthew Olay, opened via web.open on 2026-06-30.\",\"source_url\":\"https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\",\"title\":\"DX-1 Department of War article on Maduro capture as joint law-enforcement mission\"},{\"evidence_id\":\"ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9\",\"mime_type\":\"text/plain\",\"phase\":\"arguments\",\"relevance\":\"Official oversight source characterizing Operation Southern Spear as a mission to disrupt narcotics flows, with boat strikes, deployments, and interdictions, supporting defense that the broader campaign was counter-narcotics rather than territorial occupation.\",\"retrieval_timestamp\":\"2026-06-30T00:18:00Z\",\"role\":\"defendant\",\"sha256\":\"53782f10ceb9c41feb405f741ad20b53fef01f5306f2442df751c9f7a09e5345\",\"size_bytes\":1989,\"source_description\":\"Lead Inspector General report to Congress on Operation Southern Spear, January 1-March 31 2026, opened via web.open PDF extraction on 2026-06-30.\",\"source_url\":\"https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\",\"title\":\"DX-2 Lead IG Operation Southern Spear report extract on counter-narcotics mission\"}],\"surrebuttals\":[{\"phase\":\"surrebuttals\",\"role\":\"defendant\",\"text\":\"Council members, plaintiff’s rebuttal usefully narrows the dispute to two points: the Caracas site and the transition language. Neither carries plaintiff’s burden.\\n\\nFirst, plaintiff says the fortified military site in Caracas satisfies “any portion” because U.S. forces necessarily denied Venezuelan control long enough to seize and remove Maduro. That proves tactical control; it does not prove that the United States commenced an offensive intended to establish territorial control. Those are different things. A raid, arrest, rescue, or extraction at a defended facility always requires temporary domination of the target area. If that alone satisfies the proposition, the phrase “intended to establish control” does no work, and every cross-border commando raid becomes an invasion under this standard.\\n\\nThe record does not show the Caracas site was an object to be held, administered, possessed, governed, or transferred as territory. DX-1 describes a ground-based extraction force, a capture, criminal proceedings, and a joint military/law-enforcement mission. It is adverse because the operation was large and military; it is still not proof that the United States intended to establish control over Venezuelan land rather than control the scene long enough to extract two people.\\n\\nSecond, plaintiff relies on “oversee Venezuela” and PX-5’s transition-control wording. That is the strongest contrary evidence, but it remains ambiguous. Political leverage over a successor government is not the same as territorial control. DX-1 says Delcy Rodriguez was sworn in and was willing to work with the United States. That is not the United States installing a military government over a place, holding facilities, drawing boundaries, manning checkpoints, or leaving forces in control after the raid.\\n\\nPlaintiff says the defense imports an occupation requirement. No. The defense accepts that the proposition does not require annexation or a long occupation. But it does require an intent to establish control over territory. A short duration can qualify if the object is control of the place. Here the record shows a short duration whose object was capture and extraction. The admitted sources show force, pressure, and influence; they do not show a territorial-control objective.\\n\\nDX-2 still matters for that reason. Plaintiff says it does not negate Operation Absolute Resolve. True, it does not decide the whole case. But it is an official oversight account of the broader campaign as counter-narcotics, interdiction, and strikes, with the mission statement classified. Plaintiff has not filled that classified gap with an operational order, full transcript, or post-operation facts showing that the Caracas raid changed into a territorial-control campaign.\\n\\nThe council can condemn the operation as unlawful, coercive, or interventionist and still find the proposition not proved. The question is not whether the United States used overwhelming force inside Venezuela. It did. The question is whether credible sources show, more likely than not, that the United States intended to establish control over Venezuelan territory. The record remains at most equivocal on that decisive element, so plaintiff has not carried the burden.\"}],\"technical_reports\":[{\"phase\":\"arguments\",\"role\":\"plaintiff\",\"summary\":\"Before filing, plaintiff checked the record and found no case-packet evidence. Plaintiff submitted five text-readable source captures. Official White House materials are strong provenance for U.S. admissions but self-serving on labels; AP/PBS provides contemporaneous reporting; Brookings and Chatham House provide independent expert analysis, including adverse framing. Missing but potentially useful later sources include DOD after-action or press briefing text, a direct video/transcript of President Trump's transition-control statement, and fuller mapping of exact ground-control sites.\",\"title\":\"Plaintiff Source and Weight Ledger\"},{\"phase\":\"arguments\",\"role\":\"defendant\",\"summary\":\"Defendant inspected the record with get_case/list_evidence and read all five plaintiff text exhibits with read_evidence_range. Defendant submitted and read back two official defense exhibits: Department of War/Pentagon News on Operation Absolute Resolve and the Lead IG Operation Southern Spear report extract. Additional searches found DOJ and War/State leads but they were not submitted because the admitted official record already captured the key law-enforcement/counter-narcotics framing. Weight assessment: PX-2, DX-1, and DX-2 are official and strong for source identity; PX-5 is credible expert commentary but not a primary operational order or full transcript. Unresolved gaps include the full Trump transition-control video/transcript, full State transcript, and post-operation facts about who actually governed territory.\",\"title\":\"Defense Source and Weight Ledger\"},{\"phase\":\"surrebuttals\",\"role\":\"defendant\",\"summary\":\"Defendant inspected get_case and list_evidence before filing. Plaintiff rebuttal added no new evidence; it relied on existing DX-1, DX-2, and PX-5. Prior exact reads of those text exhibits remain controlling. No new external source was submitted because the rebuttal turned on interpretation of the existing record, not a new factual source.\",\"title\":\"Surrebuttal Evidence Check\"}]}}},\"turn\":{\"attempts_max\":3,\"attempts_remaining\":3,\"completed\":false,\"deadline\":\"2026-06-30T00:48:10.359530297Z\",\"deliberation_round\":1,\"member_id\":\"C2\",\"opportunity_id\":\"deliberation:1:C2\",\"phase\":\"deliberation\",\"remaining_ms\":881479,\"role_id\":\"council\",\"turn_number\":10}}"}],"details":{"mode":"call","mcpResult":{"content":[{"type":"text","text":"ok: true\nmember_id: C2\ncase_id: arb-ex05-20260630001330\nphase: deliberation\nopportunity_id: deliberation:1:C2\nremaining_ms: 881479\nattempts_remaining: 3\njson: {\"case_id\":\"arb-ex05-20260630001330\",\"member_id\":\"C2\",\"ok\":true,\"result\":{\"case\":{\"evidence_standard\":\"Preponderance of the evidence.\",\"member\":{\"member_id\":\"C2\",\"model\":\"openrouter://mistralai/mistral-medium-3-5\",\"persona_filename\":\"personas/generic.md\"},\"opportunity\":{\"allowed_tools\":[\"submit_council_vote\"],\"id\":\"deliberation:1:C2\",\"may_pass\":false,\"objective\":\"council vote by C2\",\"phase\":\"deliberation\",\"role\":\"council\"},\"phase\":\"deliberation\",\"proposition\":\"The United States invaded Venezuela between November 3, 2025, and\\nJanuary 31, 2026, 11:59 PM ET.  In particular,the United States\\ncommenced a military offensive intended to establish control over any\\nportion of Venezuela between November 3, 2025, and January 31, 2026,\\n11:59 PM ET. Land de facto controlled by Venezuela or the United\\nStates as of September 6, 2025, 12:00 PM ET, is considered to the\\nsovereign territory of that country. The resolution source is a\\nconsensus of credible sources.\",\"record\":{\"arguments\":[{\"phase\":\"arguments\",\"role\":\"plaintiff\",\"text\":\"Council members, the admitted record now answers the defendant’s missing-link argument. The proposition requires a U.S. military offensive intended to establish control over any portion of Venezuelan territory. It does not require permanent annexation, a months-long occupation, or magic words from U.S. officials.\\n\\nThe record proves a campaign, not a one-off arrest. AP/PBS reports a months-long escalation: 35 known strikes against alleged drug-smuggling boats, a regional naval buildup including destroyers, amphibious assault ships, about 6,000 sailors and Marines, aircraft, F-35s and a cruise-missile submarine, then CIA operations inside Venezuela. It further reports a late-December direct operation on Venezuelan soil and, on January 3, a large-scale strike across Caracas, capture of Maduro and Flores, and their removal from the country. PX-3.\\n\\nThe official U.S. record confirms the coercive structure. The White House says President Trump authorized lethal force, ordered a total and complete blockade of sanctioned oil tankers going in and out of Venezuela, offered Maduro “off ramps,” and that U.S. armed forces conducted an extraordinary military operation to bring Maduro to justice. It also states Venezuelan sovereign oil revenues were held in U.S. custody and protected to advance U.S. foreign-policy objectives in Venezuela. PX-1.\\n\\nMost importantly, the official adverse source admits territorial entry. Secretary Rubio’s White House release says U.S. forces were on the ground in Venezuela for about two hours when they went to capture Maduro. It also says Venezuela would continue to face an oil quarantine, U.S. pressure, seizure of sanctioned boats, targeting of drug boats, and “potentially other things” until the changes demanded by the United States were made. PX-2. That is not just a completed criminal arrest; it is ground force, blockade, coercive options, and compelled policy change.\\n\\nIndependent sources confirm the meaning of those facts. Brookings describes the January 3 operation as a U.S. special operation to exfiltrate Maduro and his wife from Caracas; it fairly preserves Rubio’s answer that this was not an invasion and the U.S. did not occupy a country. PX-4. Chatham House goes further on the facts relevant here: U.S. forces operating in Venezuela, strikes on military targets in and around Caracas, U.S. special forces forcibly abducting the sitting president, and President Trump announcing that the United States would run Venezuela and administer a political transition or regime change under threat of further, more massive force. PX-5.\\n\\nThis record proves all elements by a preponderance. First, the date is inside the window: late December direct action on Venezuelan soil and the January 3 Caracas operation occurred before January 31, 2026. Second, it was military: armed forces, special forces, strikes, warships, aircraft, a submarine, lethal force, and blockade. Third, it reached Venezuelan territory: Caracas, a military-base home, military targets in and around the capital, and official admission of U.S. forces on Venezuelan ground. Fourth, the intended control element is satisfied by control over portions and sovereign functions: the target zone in Caracas for the capture, the air/strike environment needed to carry it out, sea lanes through blockade and oil quarantine, custody of Venezuelan sovereign oil revenues, and the announced plan to run or administer Venezuela’s transition under threat of more force.\\n\\nThe defense will lean on Rubio’s labels: not a war against Venezuela, not an invasion, not extended. But labels do not defeat underlying admissions. Rubio’s own statement supplies the key facts: U.S. forces were on Venezuelan ground, used a raid to capture the effective ruler, and retained coercive options until Venezuela changed course. The proposition’s phrase “any portion” is broad. Two hours of armed control in Caracas is still control over a portion; a blockade and oil quarantine are control over access and resources; removal of the effective ruler plus asserted transition authority is control over sovereign political functions.\\n\\nNor does the law-enforcement framing save the defense. A police purpose can coexist with a military offensive if the means are military and the intended effect is control. Here the operation was preceded by lethal strikes and blockade, executed by U.S. forces inside Venezuela, and followed by continuing threats and resource control. The credible-source consensus is not that nothing happened; it is that the United States used force inside Venezuela, captured and removed Maduro, and then sought to direct Venezuela’s course.\\n\\nProvenance and limits: PX-1 and PX-2 are official U.S. sources and therefore especially strong against U.S. denial of ground presence, blockade, and resource custody, though self-serving on legal labels. PX-3 is contemporaneous AP reporting carried by PBS. PX-4 and PX-5 are expert analyses, not primary operational records, so they carry less weight than official admissions but are valuable for independent assessment and adverse framing. The record lacks a full DOD after-action report or original video transcript for every statement, but the admitted sources converge on the decisive facts.\\n\\nOn this record, it is more likely than not that the United States commenced a military offensive intended to establish control over portions of Venezuela during the required period. The proposition should be found true.\"},{\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Council members, the record now proves a serious U.S. military operation in and against Venezuela. The defense should not pretend otherwise. It proves strikes, a buildup, a Caracas raid, a two-hour ground presence, capture and removal of Maduro and Flores, oil/tanker pressure, and political leverage. But the proposition is still narrower: plaintiff must prove that the United States commenced a military offensive intended to establish control over Venezuelan territory. On this record, that missing intent remains unproved.\\n\\nStart with the official sources. PX-2 records Secretary Rubio admitting a two-hour ground presence, but in the same official statement he says the United States was not at war with Venezuela, was at war with drug-trafficking organizations, and that this was not an invasion or extended military operation. PX-4 independently preserves the same limiting point: Rubio’s answer was “not an invasion” and “we did not occupy a country.” Those labels are not conclusive, but they are highly relevant to intent.\\n\\nDX-1, the Department of War’s own article, confirms the adverse facts: an operation in Caracas, more than 150 aircraft covering a ground extraction force, and months of planning. But it repeatedly frames Operation Absolute Resolve as a capture, extraction, criminal-justice operation, and joint military/law-enforcement mission tied to a DOJ indictment. DX-2 gives the broader campaign frame: Operation Southern Spear was officially initiated to disrupt narcotics flows from designated terrorist and criminal organizations, primarily through boat strikes, interdictions, and regional deployments. That is evidence of coercive military force; it is not proof that the object was to establish control over Venezuelan land.\\n\\nPlaintiff’s argument turns “any portion” into “any tactical control during any raid.” That is too broad. Every armed entry temporarily controls some doorway, route, landing zone, airspace, or target room. If that incidental control is enough, the proposition would be true of any commando arrest or rescue operation inside foreign territory. The wording requires more: an offensive intended to establish control over a portion of Venezuela, not merely control incident to seizing a person and leaving.\\n\\nPX-1 likewise does not close the gap. It shows custody of Venezuelan oil revenues in U.S. Treasury accounts, a blockade of sanctioned oil tankers, lethal force against narcoterrorists, and an armed-forces operation in support of law enforcement. Those are grave acts of pressure and may be hostile, illegal, or interventionist. But money in Treasury accounts and tanker interdictions are not control over Venezuelan territory. A blockade may control maritime access; it does not, without more, show intent to possess, administer, or govern land that the proposition treats as Venezuelan sovereign territory.\\n\\nPX-3 is credible reporting, but its strongest points are still escalation and force: 35 boat strikes, warships, CIA operations, a late-December direct strike, and the January 3 Caracas capture. It also notes Maduro’s view that the campaign sought to oust him. Regime-change pressure is not the same as territorial-control intent. The related PBS watch-title about the United States “going to run Venezuela” is only a linked title in the submitted extract, not the video, transcript, context, or exact statement.\\n\\nPX-5 is plaintiff’s strongest source because Chatham House characterizes the operation as strikes around Caracas, special-forces abduction, and a U.S. announcement to run or administer a transition under threat of more force. The council should weigh it seriously, but also carefully. It is expert legal commentary about sovereignty and the UN Charter, not a primary operational order or full transcript. It supports that the operation may have been an unlawful use of force or aggression. It does not supply concrete facts that U.S. forces occupied, administered, or held any Venezuelan place after the raid.\\n\\nEven DX-1’s adverse transition language is equivocal. It says the United States would “oversee” Venezuela until a legitimate replacement could be identified and that Rubio was working with Delcy Rodriguez. That sounds like political direction and leverage. But the same source says Rodriguez was sworn in, that she was willing to work with the United States, and that the mission was an extraction/capture with no U.S. casualties. The record has no order establishing U.S. military government, no map of controlled territory, no duration beyond the two-hour raid, no U.S. checkpoints, no occupied ministries, no seized ports or bases held afterward, and no source showing U.S. forces remained to administer land.\\n\\nThat distinction decides the case. The record proves force, illegality arguments, coercion, and perhaps regime-change influence. It does not prove by a preponderance that territorial control was the intended object of the offensive. The credible-source consensus is mixed: official sources say capture, law enforcement, counter-narcotics, no invasion, no occupation; secondary sources condemn the operation and infer broader control, but rely on thinly captured transition language and legal characterization.\\n\\nThe plaintiff bears the burden. Because the admitted record does not show that the United States intended to establish control over Venezuelan territory, as opposed to conducting a short capture/extraction and applying continuing non-territorial pressure, the council should find the proposition not proved.\"}],\"closings\":[{\"phase\":\"closings\",\"role\":\"plaintiff\",\"text\":\"Council members, the proposition is proven by a preponderance of the admitted record.\\n\\nThe defense is right about one thing: this case is not decided by the word “invasion” in a press release. It is decided by the proposition’s actual test: whether, during the window, the United States commenced a military offensive intended to establish control over any portion of Venezuela.\\n\\nThe record establishes the military offensive. PX-3 shows the broader escalation: repeated lethal strikes, a major naval and air buildup, CIA operations inside Venezuela, a direct operation on Venezuelan soil, and on January 3 a large-scale strike across Caracas that captured Maduro and Flores and flew them out of the country. PX-1, an official White House source, confirms lethal-force authorization, a blockade of sanctioned oil tankers going in and out of Venezuela, and an extraordinary U.S. armed-forces operation to bring Maduro to justice. PX-2, another official source, admits U.S. forces were on the ground in Venezuela for about two hours.\\n\\nThe record also establishes intended control over a portion of Venezuela. This is where DX-1, the defense’s own official Department of War exhibit, is decisive. DX-1 does not describe a spontaneous police pickup. It describes Operation Absolute Resolve in Caracas against a heavily fortified military fortress in the heart of Venezuela’s capital; months of planning by joint forces, special operations forces, and intelligence agencies; complex air, ground, space, and maritime operations; more than 150 military aircraft covering the ground extraction force; and a massive joint military and law-enforcement raid. A force does not conduct that operation without intending to control the target portion of Caracas and the surrounding operational environment long enough to accomplish the seizure.\\n\\nThe defense says that is only tactical control. But the proposition says “any portion,” and it does not require permanent occupation, annexation, checkpoints, or weeks of administration. Planned armed domination of a fortified military site in the capital, backed by 150 aircraft and integrated military domains, is control over a portion. The fact that the control was temporary does not make it accidental or legally invisible.\\n\\nThe record further shows that the control objective was not limited to a room or doorway. DX-1 reports Trump saying the United States would oversee Venezuela until a safe transition could be identified, with Rubio working directly with Delcy Rodriguez and Rodriguez willing to do what the United States thought necessary. PX-5 independently characterizes the same event as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction of a sitting president, and U.S. administration of a transition under threat of more force. PX-1 adds custody of Venezuelan sovereign oil revenues and blockade pressure; PX-2 adds continued oil quarantine, pressure, retained options, and demanded changes.\\n\\nThe defense’s contrary proof does not defeat the burden. Rubio’s “not an invasion” label and DX-2’s counter-narcotics framing are relevant, but they are not controlling. DX-2 addresses the broader Southern Spear campaign and admits its mission statement is classified; it does not negate the specific Caracas operation. Official legal labels are self-serving. The underlying facts are stronger: military force inside Venezuela, control of a fortified capital target, removal of the effective ruler, blockade and resource custody, and asserted transition oversight.\\n\\nThe record has limits. There is no map of every controlled street and no full after-action report. But preponderance does not require perfect operational detail. A consensus of official sources, AP/PBS reporting, and independent expert analysis shows that the United States crossed the line from pressure and strikes into a planned military offensive to control at least portions and sovereign functions of Venezuela.\\n\\nFind the proposition true.\"},{\"phase\":\"closings\",\"role\":\"defendant\",\"text\":\"Council members, the defense closing does not ask you to minimize what happened. The admitted record shows a major U.S. military operation involving strikes, regional buildup, a Caracas raid, a two-hour ground presence, capture and removal of Maduro and Flores, oil and tanker pressure, and sharp U.S. political leverage over Venezuela’s future. The question is whether that record proves the proposition actually before you: a military offensive intended to establish control over Venezuelan territory.\\n\\nIt does not.\\n\\nThe plaintiff’s strongest argument is that a planned raid on a fortified military site in Caracas necessarily involved control over “any portion” of Venezuela. But the proposition does not ask whether U.S. forces temporarily dominated a target area. It asks whether the United States commenced an offensive intended to establish control. That intent element matters. A force can control a site long enough to enter, capture, and leave without intending to establish control over that site as territory. Plaintiff’s reading would make the territorial-control element automatic in every armed cross-border arrest, rescue, or extraction at a defended location.\\n\\nDX-1 is the central exhibit, and it cuts both ways. It confirms the adverse facts: Caracas, a heavily fortified target, months of planning, integrated military domains, and more than 150 aircraft covering the extraction force. But its repeated description of the operation is capture, extraction, criminal proceedings, and a joint military and law-enforcement mission. That is not just a label; it is the operational object described by the official source. It shows tactical control in service of seizure and removal, not a plan to possess, administer, or govern Venezuelan land.\\n\\nPX-2 and PX-4 reinforce that limiting inference. Rubio admitted the two-hour ground presence, but said the United States was not at war with Venezuela, was acting against drug-trafficking organizations, and that the action was not an invasion, not an extended operation, and not an occupation. Those statements are self-serving, but they are still official evidence of intent. DX-2 places the broader campaign in the same frame: counter-narcotics, interdiction, boat strikes, tanker seizures, and a classified mission statement. It is proof of coercive force, not proof of territorial administration.\\n\\nPlaintiff’s second strong point is transition language: DX-1 says the United States would oversee Venezuela until a safe transition could be identified, and PX-5 describes U.S. administration of a transition under threat of force. That evidence is troubling and deserves weight. But it remains ambiguous on the decisive issue. Political leverage over Delcy Rodriguez, pressure on resources, or demands about Venezuela’s policy direction are not the same as control over Venezuelan territory. The record does not show U.S. troops remained after the raid, that they held ministries, ports, bases, roads, neighborhoods, or oil fields, that they established checkpoints, that they drew controlled boundaries, or that they installed a military government over any place.\\n\\nPX-1 likewise proves pressure, not territorial control. Custody of oil revenues in U.S. Treasury accounts and a blockade of sanctioned tankers may be coercive, even unlawful. But they are not possession or administration of Venezuelan land. PX-3 proves escalation and force, but its submitted extract does not provide the full content behind the linked “run Venezuela” item. PX-5 is credible expert commentary on international law, but it is not a primary operational order, full transcript, or after-action record proving that control of territory was the intended object.\\n\\nThe council can find that the United States violated Venezuelan sovereignty. It can find that the operation was aggressive, interventionist, coercive, and politically consequential. Those findings still do not answer the proposition unless the record also shows intended establishment of territorial control.\\n\\nOn that decisive element, the record is at best mixed. Plaintiff has powerful evidence of military force and temporary tactical domination. The defense has official evidence that the mission object was capture, extraction, law enforcement, and counter-narcotics, plus a record gap on any continuing territorial mechanism. Under a preponderance standard, ambiguity on the proposition’s central intent element means plaintiff has not carried its burden.\\n\\nFind the proposition not proved.\"}],\"evidence\":[{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:20:59Z\",\"evidence_id\":\"ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-01-plaintiff-0c5c88687b2a.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Official U.S. source admitting oil-revenue custody, blockade, lethal-force authorization, and an armed forces operation against Maduro within the case window.\",\"retrieval_timestamp\":\"2026-06-30T00:20:00Z\",\"sha256\":\"0c5c88687b2a889093788193bdd900106b95ff6ccfab1af50709f67df61cb673\",\"size_bytes\":1819,\"source_description\":\"White House fact sheet page, extracted via web.open on 2026-06-30.\",\"source_url\":\"https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\",\"storage_name\":\"0c/0c5c88687b2a889093788193bdd900106b95ff6ccfab1af50709f67df61cb673\",\"submitted_by_role\":\"plaintiff\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"PX-1 White House fact sheet on Venezuelan oil revenue and U.S. operation\"},{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:24:59Z\",\"evidence_id\":\"ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-06-defendant-26011b5f6d79.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Official source on Operation Absolute Resolve showing both adverse facts (Caracas operation and transition comments) and defense facts (capture/extraction, criminal proceedings, joint military/law-enforcement mission, no U.S. casualties, anti-narcoterrorism context).\",\"retrieval_timestamp\":\"2026-06-30T00:29:30Z\",\"sha256\":\"26011b5f6d792bc39d1eabe168123482dcc270e34745035055127683c27c55e1\",\"size_bytes\":2203,\"source_description\":\"Department of War/Pentagon News article by Matthew Olay, opened via web.open on 2026-06-30.\",\"source_url\":\"https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\",\"storage_name\":\"26/26011b5f6d792bc39d1eabe168123482dcc270e34745035055127683c27c55e1\",\"submitted_by_role\":\"defendant\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"DX-1 Department of War article on Maduro capture as joint law-enforcement mission\"},{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:21:36Z\",\"evidence_id\":\"ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-03-plaintiff-2efdab998e47.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Contemporaneous credible reporting on the U.S. buildup, strikes, first known operation on Venezuelan soil, Jan. 3 large-scale strike across Caracas, capture/removal of Maduro and Flores, and related military posture.\",\"retrieval_timestamp\":\"2026-06-30T00:21:00Z\",\"sha256\":\"2efdab998e47ae16cff6d6becb03e7e9216bee4b668814addd1ef89d84c57ec8\",\"size_bytes\":2038,\"source_description\":\"PBS NewsHour page carrying Associated Press timeline by Ben Finley, Konstantin Toropin, and Regina Garcia Cano; extracted via web.open/find on 2026-06-30.\",\"source_url\":\"https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\",\"storage_name\":\"2e/2efdab998e47ae16cff6d6becb03e7e9216bee4b668814addd1ef89d84c57ec8\",\"submitted_by_role\":\"plaintiff\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"PX-3 PBS/AP timeline of U.S. escalation and Maduro capture\"},{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:21:52Z\",\"evidence_id\":\"ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-04-plaintiff-52e4d5a16b2f.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Independent expert analysis confirming a Jan. 3 U.S. special operation in Caracas and preserving the adverse official claim that it was not an invasion or occupation.\",\"retrieval_timestamp\":\"2026-06-30T00:21:30Z\",\"sha256\":\"52e4d5a16b2f936b7515e76a65ecfde48c040e48b94b144702fbe1e32123f0c3\",\"size_bytes\":1680,\"source_description\":\"Brookings Institution analysis page, extracted via web.open on 2026-06-30.\",\"source_url\":\"https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\",\"storage_name\":\"52/52e4d5a16b2f936b7515e76a65ecfde48c040e48b94b144702fbe1e32123f0c3\",\"submitted_by_role\":\"plaintiff\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"PX-4 Brookings analysis of Jan. 3 Maduro operation and legal limit\"},{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:25:19Z\",\"evidence_id\":\"ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-07-defendant-53782f10ceb9.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Official oversight source characterizing Operation Southern Spear as a mission to disrupt narcotics flows, with boat strikes, deployments, and interdictions, supporting defense that the broader campaign was counter-narcotics rather than territorial occupation.\",\"retrieval_timestamp\":\"2026-06-30T00:18:00Z\",\"sha256\":\"53782f10ceb9c41feb405f741ad20b53fef01f5306f2442df751c9f7a09e5345\",\"size_bytes\":1989,\"source_description\":\"Lead Inspector General report to Congress on Operation Southern Spear, January 1-March 31 2026, opened via web.open PDF extraction on 2026-06-30.\",\"source_url\":\"https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\",\"storage_name\":\"53/53782f10ceb9c41feb405f741ad20b53fef01f5306f2442df751c9f7a09e5345\",\"submitted_by_role\":\"defendant\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"DX-2 Lead IG Operation Southern Spear report extract on counter-narcotics mission\"},{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:21:17Z\",\"evidence_id\":\"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-02-plaintiff-6627f15cd3a4.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Official U.S. statements acknowledging two-hour U.S. ground presence in Venezuela, oil quarantine/pressure, retained options, and the adverse claim that the action was not an invasion.\",\"retrieval_timestamp\":\"2026-06-30T00:20:30Z\",\"sha256\":\"6627f15cd3a42cc9018d2ab70f1951aa4f1687bd18848c031287516048d42d80\",\"size_bytes\":1793,\"source_description\":\"White House release page, extracted via web.open on 2026-06-30.\",\"source_url\":\"https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\",\"storage_name\":\"66/6627f15cd3a42cc9018d2ab70f1951aa4f1687bd18848c031287516048d42d80\",\"submitted_by_role\":\"plaintiff\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"PX-2 White House release collecting Secretary Rubio statements\"},{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:22:10Z\",\"evidence_id\":\"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-05-plaintiff-94e861ebadbf.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Independent international-law analysis characterizing the operation as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction, and a U.S. announcement to run/administer a transition under threat of force.\",\"retrieval_timestamp\":\"2026-06-30T00:22:00Z\",\"sha256\":\"94e861ebadbf2849cd4257d954fcd51afc5f6a8d01c7b5f2df165cc6d4180151\",\"size_bytes\":1755,\"source_description\":\"Chatham House expert comment by Marc Weller, extracted via web.open/find on 2026-06-30.\",\"source_url\":\"https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\",\"storage_name\":\"94/94e861ebadbf2849cd4257d954fcd51afc5f6a8d01c7b5f2df165cc6d4180151\",\"submitted_by_role\":\"plaintiff\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"PX-5 Chatham House analysis of U.S. capture, strikes, and transition control\"}],\"exhibits\":[{\"evidence_id\":\"ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a\",\"label\":\"PX-1 White House fact sheet on operation, blockade, and oil revenues\",\"phase\":\"arguments\",\"role\":\"plaintiff\",\"text\":\"Source: The White House, Fact Sheet: President Donald J. Trump Safeguards Venezuelan Oil Revenue for the Good of the American and Venezuelan People. Date on page: January 9, 2026. URL: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\\n\\nExtracted relevant page text:\\n- President Trump signed an Executive Order declaring a national emergency to safeguard Venezuelan oil revenue held in U.S. Treasury accounts from attachment or judicial process, preserving the funds to advance U.S. foreign policy objectives.\\n- Foreign Government Deposit Funds are defined as Venezuelan oil revenues and diluent sales held in U.S. Treasury accounts.\\n- The order affirms the funds are sovereign property of Venezuela held in U.S. custody for governmental and diplomatic purposes.\\n- The White House says loss of control over these revenues would weaken efforts to bring peace, prosperity, and stability to Venezuela and the Western Hemisphere.\\n- The fact sheet states: President Trump authorized lethal force against narcoterrorists to stop the flow of deadly drugs into this country.\\n- It states: President Trump ordered a total and complete blockade of all sanctioned oil tankers going in and out of Venezuela.\\n- It states: President Trump offered multiple off ramps to Maduro and his illegitimate regime, but he was clear that the drug trafficking must stop.\\n- It states: Last week, U.S. armed forces conducted an extraordinary military operation in support of law enforcement to bring outlaw dictator Maduro to justice.\\n- It states that the President's actions reestablish deterrence in the Western hemisphere and that safeguarding these oil revenues promotes stability in Venezuela while advancing U.S. objectives.\"},{\"evidence_id\":\"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4\",\"label\":\"PX-2 White House Rubio statements on ground presence and pressure\",\"phase\":\"arguments\",\"role\":\"plaintiff\",\"text\":\"Source: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\\n\\nExtracted relevant page text:\\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\"},{\"evidence_id\":\"ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47\",\"label\":\"PX-3 PBS/AP timeline of escalation and Caracas strike\",\"phase\":\"arguments\",\"role\":\"plaintiff\",\"text\":\"Source: PBS NewsHour / Associated Press, A timeline of U.S. military escalation against Venezuela leading to Maduro's capture. By Ben Finley, Konstantin Toropin, Regina Garcia Cano. Date on page: Jan. 3, 2026 1:54 PM EDT. URL: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\\n\\nExtracted relevant page text:\\n- AP reported that Trump had threatened military strikes on targets on Venezuelan territory after months of attacks on boats accused of carrying drugs from Venezuela; Maduro said U.S. military operations were a thinly veiled effort to oust him.\\n- On Jan. 3 the U.S. conducted a large-scale strike against Venezuela. Maduro and Cilia Flores were taken from their home on a military base and were aboard a U.S. warship on their way to New York to face criminal charges.\\n- Before the escalation, there had been 35 known strikes against alleged drug-smuggling boats in South American waters since early September, killing at least 115 people according to administration announcements.\\n- The U.S. sent a fleet of warships to the region, the largest buildup of forces in generations; the naval force grew to include guided-missile destroyers, three amphibious assault ships and other vessels, about 6,000 sailors and Marines, aircraft, F-35 fighter jets in Puerto Rico, and a Navy submarine carrying cruise missiles off South America.\\n- On Oct. 15, Trump confirmed he had authorized the CIA to conduct covert operations inside Venezuela and was weighing land operations in the country.\\n- On Dec. 29/30, a drone strike at a docking area believed used by Venezuelan drug cartels was reported as the first known direct operation on Venezuelan soil since the strikes began.\\n- On Jan. 3, AP reported that the U.S. conducted a large-scale strike across Caracas, captured Maduro and Flores, and flew them out of the country.\\n- The related PBS page links included a watch item titled: Trump says U.S. is going to run Venezuela until transition of power after capturing Maduro.\"},{\"evidence_id\":\"ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f\",\"label\":\"PX-4 Brookings analysis and adverse Rubio framing\",\"phase\":\"arguments\",\"role\":\"plaintiff\",\"text\":\"Source: Brookings Institution, Making sense of the US military operation in Venezuela. URL: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\\n\\nExtracted relevant page text:\\n- Brookings states: On January 3, 2026, the United States launched a special operation to exfiltrate Venezuelan President Nicolás Maduro and his wife from Caracas.\\n- Scott R. Anderson writes that the operation to capture Maduro underscores the broad authority modern presidents exercise over military force and potentially its limits.\\n- Brookings notes the executive branch position that the president has constitutional authority to use military force without congressional authorization if supporting U.S. interests and not expected to result in prolonged and substantial military engagements.\\n- Anderson writes it is not surprising for the administration to argue that the president can take targeted military action like the Maduro operation, even where consequential for Venezuela and contrary to international law.\\n- Brookings records Secretary Rubio's response when asked why congressional authorization was not needed: This was not an invasion, we did not occupy a country. Brookings treats that as suggesting broader campaigns might exceed unilateral authority.\\n- Brookings states a second wave of the sort threatened by President Trump still might encounter limits.\\n- Brookings separately states that Maduro is gone and what comes next is unclear; maintaining Delcy Rodríguez indefinitely would undermine the expressed will of Venezuelans, and threatening force to keep the Rodríguez government in line may work in the short term but is not sustainable.\"},{\"evidence_id\":\"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf\",\"label\":\"PX-5 Chatham House analysis of operation and transition control\",\"phase\":\"arguments\",\"role\":\"plaintiff\",\"text\":\"Source: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\\n\\nExtracted relevant page text:\\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\"},{\"evidence_id\":\"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4\",\"label\":\"PX-2 White House Rubio statements on ground presence and no-invasion/no-occupation framing\",\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Source: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\\n\\nExtracted relevant page text:\\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\"},{\"evidence_id\":\"ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f\",\"label\":\"PX-4 Brookings analysis preserving Rubio no-invasion/no-occupation framing\",\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Source: Brookings Institution, Making sense of the US military operation in Venezuela. URL: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\\n\\nExtracted relevant page text:\\n- Brookings states: On January 3, 2026, the United States launched a special operation to exfiltrate Venezuelan President Nicolás Maduro and his wife from Caracas.\\n- Scott R. Anderson writes that the operation to capture Maduro underscores the broad authority modern presidents exercise over military force and potentially its limits.\\n- Brookings notes the executive branch position that the president has constitutional authority to use military force without congressional authorization if supporting U.S. interests and not expected to result in prolonged and substantial military engagements.\\n- Anderson writes it is not surprising for the administration to argue that the president can take targeted military action like the Maduro operation, even where consequential for Venezuela and contrary to international law.\\n- Brookings records Secretary Rubio's response when asked why congressional authorization was not needed: This was not an invasion, we did not occupy a country. Brookings treats that as suggesting broader campaigns might exceed unilateral authority.\\n- Brookings states a second wave of the sort threatened by President Trump still might encounter limits.\\n- Brookings separately states that Maduro is gone and what comes next is unclear; maintaining Delcy Rodríguez indefinitely would undermine the expressed will of Venezuelans, and threatening force to keep the Rodríguez government in line may work in the short term but is not sustainable.\"},{\"evidence_id\":\"ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79\",\"label\":\"DX-1 Department of War article framing Absolute Resolve as capture/extraction and joint law-enforcement mission\",\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Source: U.S. Department of War / Pentagon News, Trump Announces U.S. Military's Capture of Maduro. Date on page: Jan. 3, 2026. URL: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\\n\\nExtracted relevant page text:\\n- President Donald J. Trump announced the capture of Venezuelan leader Nicolas Maduro after a successful overnight joint U.S. military extraction in Caracas, Venezuela.\\n- The article identifies the matter as Operation Absolute Resolve in Caracas.\\n- Trump said U.S. armed forces conducted an extraordinary military operation in the capital of Venezuela against a heavily fortified military fortress in the heart of Caracas to bring Maduro to justice.\\n- The article states Maduro and Cilia Flores de Maduro would face criminal court proceedings tied to a 2020 U.S. Department of Justice indictment on charges including narco-terrorism and drug trafficking.\\n- The article says Operation Absolute Resolve was a joint military and law-enforcement mission to capture the Maduros, resulting from months of planning and rehearsal involving U.S. joint forces, special operations forces, and intelligence agencies.\\n- Gen. Dan Caine described integrating complex air, ground, space, and maritime operations.\\n- The article states the mission to extract the Maduros had no U.S. casualties and involved more than 150 military aircraft providing cover for the ground-based extraction force in Caracas.\\n- Secretary Hegseth called it a massive joint military and law-enforcement raid, and said the mission concerned safety, security, freedom, and prosperity of the American people.\\n- The article also reports adverse transition language: with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition to a legitimate replacement could be identified; Trump said Marco Rubio was working directly with Delcy Rodriguez and that she was willing to do what the United States thought necessary.\\n- The article frames preceding tensions around September 2025 targeted boat strikes, November 2025 designation of Cartel de los Soles as a terror organization, and options to address a narco-terror threat in the region.\"},{\"evidence_id\":\"ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9\",\"label\":\"DX-2 Lead IG report framing Southern Spear as counter-narcotics operation\",\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Source: Lead Inspector General report to Congress, Operation Southern Spear, January 1, 2026-March 31, 2026. PDF URL: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\\n\\nExtracted relevant text:\\n- The Lead IG report states that in November 2025 the Department of War initiated Operation Southern Spear as the U.S. mission to disrupt the flow of narcotics from designated terrorist organizations and transnational criminal organizations in the Western Hemisphere.\\n- The report covers January 1 through March 31, 2026 and presents oversight work by the Department of War OIG, State OIG, and partner oversight agencies.\\n- The report summary states Operation Southern Spear is the Department of War operation to disrupt the flow of narcotics in the Western Hemisphere from drug cartels designated by the President as terrorist organizations.\\n- The report states OSS primarily involves lethal airstrikes against small boats suspected of shipping illegal narcotics in the Caribbean Sea and eastern Pacific Ocean.\\n- It states that from September 2025 through March 2026, the U.S. military struck at least 45 small boats, resulting in 156 individuals killed or presumed dead.\\n- It states the Department of War began moving significant Navy and Marine Corps assets into the USSOUTHCOM area of operations in August 2025 to support OSS.\\n- It states Joint Interagency Task Force-South is the U.S. Government's interagency effort to detect, monitor, and target illicit drug trafficking in the air and at sea with the support of 19 partner nations.\\n- It states U.S. forces interdicted at least 10 sanctioned tankers around the world since OSS began, including some tracked as far as the Indian Ocean.\\n- It states the OSS mission statement is classified.\\n\\nLimitations: this extracted text does not decide Operation Absolute Resolve's territorial-control intent; it is offered to show the official oversight framing of the broader campaign and the classified-source gap.\"},{\"evidence_id\":\"ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a\",\"label\":\"PX-1 White House fact sheet on oil revenues, blockade, and law-enforcement operation\",\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Source: The White House, Fact Sheet: President Donald J. Trump Safeguards Venezuelan Oil Revenue for the Good of the American and Venezuelan People. Date on page: January 9, 2026. URL: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\\n\\nExtracted relevant page text:\\n- President Trump signed an Executive Order declaring a national emergency to safeguard Venezuelan oil revenue held in U.S. Treasury accounts from attachment or judicial process, preserving the funds to advance U.S. foreign policy objectives.\\n- Foreign Government Deposit Funds are defined as Venezuelan oil revenues and diluent sales held in U.S. Treasury accounts.\\n- The order affirms the funds are sovereign property of Venezuela held in U.S. custody for governmental and diplomatic purposes.\\n- The White House says loss of control over these revenues would weaken efforts to bring peace, prosperity, and stability to Venezuela and the Western Hemisphere.\\n- The fact sheet states: President Trump authorized lethal force against narcoterrorists to stop the flow of deadly drugs into this country.\\n- It states: President Trump ordered a total and complete blockade of all sanctioned oil tankers going in and out of Venezuela.\\n- It states: President Trump offered multiple off ramps to Maduro and his illegitimate regime, but he was clear that the drug trafficking must stop.\\n- It states: Last week, U.S. armed forces conducted an extraordinary military operation in support of law enforcement to bring outlaw dictator Maduro to justice.\\n- It states that the President's actions reestablish deterrence in the Western hemisphere and that safeguarding these oil revenues promotes stability in Venezuela while advancing U.S. objectives.\"},{\"evidence_id\":\"ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47\",\"label\":\"PX-3 PBS/AP timeline of escalation, strikes, and Maduro capture\",\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Source: PBS NewsHour / Associated Press, A timeline of U.S. military escalation against Venezuela leading to Maduro's capture. By Ben Finley, Konstantin Toropin, Regina Garcia Cano. Date on page: Jan. 3, 2026 1:54 PM EDT. URL: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\\n\\nExtracted relevant page text:\\n- AP reported that Trump had threatened military strikes on targets on Venezuelan territory after months of attacks on boats accused of carrying drugs from Venezuela; Maduro said U.S. military operations were a thinly veiled effort to oust him.\\n- On Jan. 3 the U.S. conducted a large-scale strike against Venezuela. Maduro and Cilia Flores were taken from their home on a military base and were aboard a U.S. warship on their way to New York to face criminal charges.\\n- Before the escalation, there had been 35 known strikes against alleged drug-smuggling boats in South American waters since early September, killing at least 115 people according to administration announcements.\\n- The U.S. sent a fleet of warships to the region, the largest buildup of forces in generations; the naval force grew to include guided-missile destroyers, three amphibious assault ships and other vessels, about 6,000 sailors and Marines, aircraft, F-35 fighter jets in Puerto Rico, and a Navy submarine carrying cruise missiles off South America.\\n- On Oct. 15, Trump confirmed he had authorized the CIA to conduct covert operations inside Venezuela and was weighing land operations in the country.\\n- On Dec. 29/30, a drone strike at a docking area believed used by Venezuelan drug cartels was reported as the first known direct operation on Venezuelan soil since the strikes began.\\n- On Jan. 3, AP reported that the U.S. conducted a large-scale strike across Caracas, captured Maduro and Flores, and flew them out of the country.\\n- The related PBS page links included a watch item titled: Trump says U.S. is going to run Venezuela until transition of power after capturing Maduro.\"},{\"evidence_id\":\"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf\",\"label\":\"PX-5 Chatham House adverse analysis of sovereignty violation and transition-control claim\",\"phase\":\"arguments\",\"role\":\"defendant\",\"text\":\"Source: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\\n\\nExtracted relevant page text:\\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\"},{\"evidence_id\":\"ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79\",\"label\":\"DX-1 Department of War article on capture/extraction mission and transition language\",\"phase\":\"surrebuttals\",\"role\":\"defendant\",\"text\":\"Source: U.S. Department of War / Pentagon News, Trump Announces U.S. Military's Capture of Maduro. Date on page: Jan. 3, 2026. URL: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\\n\\nExtracted relevant page text:\\n- President Donald J. Trump announced the capture of Venezuelan leader Nicolas Maduro after a successful overnight joint U.S. military extraction in Caracas, Venezuela.\\n- The article identifies the matter as Operation Absolute Resolve in Caracas.\\n- Trump said U.S. armed forces conducted an extraordinary military operation in the capital of Venezuela against a heavily fortified military fortress in the heart of Caracas to bring Maduro to justice.\\n- The article states Maduro and Cilia Flores de Maduro would face criminal court proceedings tied to a 2020 U.S. Department of Justice indictment on charges including narco-terrorism and drug trafficking.\\n- The article says Operation Absolute Resolve was a joint military and law-enforcement mission to capture the Maduros, resulting from months of planning and rehearsal involving U.S. joint forces, special operations forces, and intelligence agencies.\\n- Gen. Dan Caine described integrating complex air, ground, space, and maritime operations.\\n- The article states the mission to extract the Maduros had no U.S. casualties and involved more than 150 military aircraft providing cover for the ground-based extraction force in Caracas.\\n- Secretary Hegseth called it a massive joint military and law-enforcement raid, and said the mission concerned safety, security, freedom, and prosperity of the American people.\\n- The article also reports adverse transition language: with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition to a legitimate replacement could be identified; Trump said Marco Rubio was working directly with Delcy Rodriguez and that she was willing to do what the United States thought necessary.\\n- The article frames preceding tensions around September 2025 targeted boat strikes, November 2025 designation of Cartel de los Soles as a terror organization, and options to address a narco-terror threat in the region.\"},{\"evidence_id\":\"ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9\",\"label\":\"DX-2 Lead IG Southern Spear counter-narcotics mission extract\",\"phase\":\"surrebuttals\",\"role\":\"defendant\",\"text\":\"Source: Lead Inspector General report to Congress, Operation Southern Spear, January 1, 2026-March 31, 2026. PDF URL: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\\n\\nExtracted relevant text:\\n- The Lead IG report states that in November 2025 the Department of War initiated Operation Southern Spear as the U.S. mission to disrupt the flow of narcotics from designated terrorist organizations and transnational criminal organizations in the Western Hemisphere.\\n- The report covers January 1 through March 31, 2026 and presents oversight work by the Department of War OIG, State OIG, and partner oversight agencies.\\n- The report summary states Operation Southern Spear is the Department of War operation to disrupt the flow of narcotics in the Western Hemisphere from drug cartels designated by the President as terrorist organizations.\\n- The report states OSS primarily involves lethal airstrikes against small boats suspected of shipping illegal narcotics in the Caribbean Sea and eastern Pacific Ocean.\\n- It states that from September 2025 through March 2026, the U.S. military struck at least 45 small boats, resulting in 156 individuals killed or presumed dead.\\n- It states the Department of War began moving significant Navy and Marine Corps assets into the USSOUTHCOM area of operations in August 2025 to support OSS.\\n- It states Joint Interagency Task Force-South is the U.S. Government's interagency effort to detect, monitor, and target illicit drug trafficking in the air and at sea with the support of 19 partner nations.\\n- It states U.S. forces interdicted at least 10 sanctioned tankers around the world since OSS began, including some tracked as far as the Indian Ocean.\\n- It states the OSS mission statement is classified.\\n\\nLimitations: this extracted text does not decide Operation Absolute Resolve's territorial-control intent; it is offered to show the official oversight framing of the broader campaign and the classified-source gap.\"},{\"evidence_id\":\"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4\",\"label\":\"PX-2 Rubio ground-presence and no-invasion/no-occupation statements\",\"phase\":\"surrebuttals\",\"role\":\"defendant\",\"text\":\"Source: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\\n\\nExtracted relevant page text:\\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\\n- Rubio stated Maduro was not the head of state and was an illegitimate president.\"},{\"evidence_id\":\"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf\",\"label\":\"PX-5 Chatham House adverse transition-control analysis\",\"phase\":\"surrebuttals\",\"role\":\"defendant\",\"text\":\"Source: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\\n\\nExtracted relevant page text:\\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela.\"}],\"openings\":[{\"phase\":\"openings\",\"role\":\"plaintiff\",\"text\":\"Council members, the proposition is not asking whether the United States used harsh rhetoric toward Venezuela, or whether a short raid can be called an invasion in ordinary speech. It asks a narrower factual question: during the window from November 3, 2025 through January 31, 2026, did the United States commence a military offensive intended to establish control over any portion of Venezuelan territory?\\n\\nThe current record is empty. No case-packet evidence, source documents, exhibits, or submitted evidence are yet before you. For that reason, this opening is a roadmap, not a request to decide on assertions unsupported by admitted proof. The plaintiff’s burden is preponderance of the evidence, and the decisive proof will need to come from credible-source consensus, preferably including official U.S. statements, contemporaneous news reporting, and independent expert analysis.\\n\\nOur theory is that this was an invasion under the proposition’s definition because the expected evidence will show an integrated U.S. military campaign, not an isolated arrest. The relevant facts will likely include the sequence of military buildup, maritime interdiction or blockade, strikes on or against Venezuelan territory, armed entry into Caracas or other Venezuelan sites, seizure and removal of the sitting effective ruler, temporary U.S. control over the places and routes needed to carry out that seizure, and follow-on statements or acts showing an intent to dictate Venezuela’s political transition or control Venezuelan resources. If that proof is admitted, it satisfies the proposition even if the United States did not permanently annex land or maintain a long occupation. The proposition requires an offensive intended to establish control over any portion of territory; temporary military control of a target area, base, airspace, port, route, or government seat can be enough if credible sources show it was part of the intended operation.\\n\\nThe defense’s best answer is predictable and important: it will say the United States conducted a brief law-enforcement or counter-narcotics operation, that any ground presence lasted only long enough to capture a criminal defendant, and that there was no intent to hold Venezuelan territory. That is the real dispute. A mere strike, a naval seizure outside Venezuela, or a short exfiltration with no intended territorial control would not, standing alone, meet the proposition. Nor would generalized political pressure or sanctions. The council should therefore focus on evidence of planned control: operational objectives, official descriptions of the forces and targets, whether U.S. forces controlled Venezuelan land or facilities even temporarily, whether the operation displaced Venezuela’s effective government, and whether U.S. officials claimed authority to administer the aftermath.\\n\\nThe plaintiff will seek to build the record with primary and near-primary sources: official White House, State, Defense, and Justice materials; transcripts of relevant press briefings and interviews; contemporaneous wire-service reporting; and independent legal or foreign-policy analysis that addresses the same facts. We will also test adverse material, especially any official claim that this was not an invasion and not an occupation. Those claims matter, but they are not conclusive if the underlying conduct and intent show a military offensive to establish control over Venezuelan territory.\\n\\nAt the end of the case, the question should be answered by the weight of credible sources, not labels. If the admitted record shows only a narrow arrest operation without territorial-control intent, plaintiff should lose. But if the admitted record shows that the United States used military force inside Venezuela as part of a planned campaign to seize control of places, routes, institutions, or resources necessary to impose a political outcome, then the proposition is more likely than not true.\"},{\"phase\":\"openings\",\"role\":\"defendant\",\"text\":\"Council members, the proposition is not whether the United States used force against Venezuela, whether officials used aggressive rhetoric, whether Congress debated war-powers limits, or whether an operation was lawful under domestic or international law. The proposition asks a narrower factual question: did the United States commence a military offensive, during the defined window, intended to establish control over any portion of Venezuelan territory?\\n\\nThe answer cannot be supplied by labels. “Hostilities,” “intervention,” “aggression,” “raid,” “capture,” “extraction,” and “regime pressure” may all matter as evidence leads, but none is the element the council must find. The plaintiff must prove by a preponderance, through a consensus of credible sources, both military action and the specific intent to establish territorial control. If the eventual record shows only strikes, maritime interdictions, sanctions enforcement, a law-enforcement capture operation, temporary tactical presence for entry and exit, or political pressure on Venezuela’s leadership, plaintiff has not met the proposition as written.\\n\\nThe current record contains no admitted evidence at all. There are no case-packet files, no exhibits, and no submitted source materials. The plaintiff’s opening properly recognizes that a mere strike or short exfiltration without intended territorial control would not be enough. That concession identifies the real dispute. The defense will hold plaintiff to it.\\n\\nOur theory is that the decisive proof, if admitted, will show a counter-narcotics, interdiction, and extraction frame rather than an offensive to take and hold Venezuelan territory. The defense will not ask the council to ignore adverse evidence. If plaintiff later admits credible primary materials showing that U.S. forces set out to control ports, airfields, ministries, bases, roads, oil fields, neighborhoods, or other Venezuelan land as an object of the operation, that would be serious evidence for plaintiff. So would proof that the United States administered territory, installed a military authority over a place, maintained checkpoints for territorial governance, or claimed a continuing right to control Venezuelan facilities or resources.\\n\\nBut that is exactly the proof the plaintiff must produce. A military force can briefly control a doorway, route, landing zone, compound, airspace, or vessel as an incident of an arrest, strike, rescue, evacuation, or interdiction without intending to establish control over Venezuelan territory in the sense required by this proposition. Likewise, a government can seek a leader’s prosecution, weaken a hostile regime, interdict trafficking, or apply coercive pressure without crossing this proposition’s territorial-control line. The council should separate those categories carefully.\\n\\nThe coming evidence should therefore be tested around five questions. First, what was the actual operational objective, as shown by primary official materials, contemporaneous reporting, and reliable expert analysis? Second, what physical presence occurred inside land deemed Venezuelan territory as of September 6, 2025, and how long did it last? Third, did U.S. forces exercise control merely to complete a mission and leave, or did they seek to possess, administer, or deny Venezuela control of a place? Fourth, what did the United States do after the operation: withdraw, transfer custody, or govern territory? Fifth, do credible sources converge on territorial-control intent, or only on force, illegality, hostilities, or political consequences?\\n\\nProvenance will matter. Official statements may understate conflict; hostile governments may overstate occupation; secondary commentary may collapse legal “aggression” into the different factual standard here. The most valuable evidence will be original government documents, full transcripts, congressional materials, after-action or oversight reports, and contemporaneous reporting that distinguishes what happened from what advocates called it.\\n\\nAt the close of this case, if the record shows the United States began an offensive meant to establish control over Venezuelan territory, the plaintiff should prevail. But if the record shows military force, even serious and controversial force, without that intended territorial-control objective, the proposition fails. On the present empty record, and under the plaintiff’s burden, the defense position is that the council should require that missing link before finding an invasion.\"}],\"prior_council_votes\":[],\"rebuttals\":[{\"phase\":\"rebuttals\",\"role\":\"plaintiff\",\"text\":\"Council members, defendant’s argument narrows the proposition too far. It concedes the record proves a serious U.S. military operation in and against Venezuela: strikes, buildup, a Caracas raid, two-hour ground presence, capture/removal of Maduro and Flores, oil/tanker pressure, and political leverage. The remaining question is whether the object included control over any portion of Venezuela.\\n\\nDefendant says plaintiff’s theory would make any brief commando raid an invasion. But this record is not about a doorway or landing zone. Defendant’s own DX-1 describes Operation Absolute Resolve as a U.S. military operation in Caracas against a heavily fortified military fortress in the heart of Venezuela’s capital. It followed months of planning by joint forces, special operations forces, and intelligence agencies. Gen. Caine described complex air, ground, space, and maritime operations. More than 150 military aircraft covered the ground extraction force. Hegseth called it a massive joint military and law-enforcement raid.\\n\\nThose facts satisfy “any portion.” A planned armed domination of a fortified military site in Caracas, covered by 150 aircraft and integrated domains, is control over a portion of Venezuelan territory. It need not be permanent. The mission could not succeed unless U.S. forces intended to deny Venezuelan control over that site and surrounding operational environment long enough to seize and remove the effective ruler.\\n\\nDefendant also separates regime-change pressure from territorial control. DX-1 defeats that separation. It reports that with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition could be identified; Rubio was working directly with Delcy Rodriguez; and Rodriguez was willing to do what the United States thought necessary. PX-5 independently captures that as U.S. administration of a transition under threat of more force. That is not merely prosecution in New York.\\n\\nDX-2 does not rescue the defense. It frames Southern Spear as counter-narcotics and boat interdiction, but also admits major Navy/Marine deployments, lethal strikes, tanker interdictions, and a classified mission statement. It does not negate the specific intent of Operation Absolute Resolve in Caracas.\\n\\nThe defense imports an occupation requirement the proposition does not contain. The question is whether the United States commenced a military offensive intended to establish control over any portion of Venezuela, not whether it held checkpoints for weeks or annexed land. Rubio’s “not an invasion” label deserves consideration, but labels cannot outweigh the record facts: military force inside Venezuela, control of the necessary Caracas target area, removal of Maduro, and asserted authority to shape Venezuela’s transition and resources. That is enough under the actual proposition.\"}],\"submitted_evidence\":[{\"evidence_id\":\"ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a\",\"mime_type\":\"text/plain\",\"phase\":\"arguments\",\"relevance\":\"Official U.S. source admitting oil-revenue custody, blockade, lethal-force authorization, and an armed forces operation against Maduro within the case window.\",\"retrieval_timestamp\":\"2026-06-30T00:20:00Z\",\"role\":\"plaintiff\",\"sha256\":\"0c5c88687b2a889093788193bdd900106b95ff6ccfab1af50709f67df61cb673\",\"size_bytes\":1819,\"source_description\":\"White House fact sheet page, extracted via web.open on 2026-06-30.\",\"source_url\":\"https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\",\"title\":\"PX-1 White House fact sheet on Venezuelan oil revenue and U.S. operation\"},{\"evidence_id\":\"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4\",\"mime_type\":\"text/plain\",\"phase\":\"arguments\",\"relevance\":\"Official U.S. statements acknowledging two-hour U.S. ground presence in Venezuela, oil quarantine/pressure, retained options, and the adverse claim that the action was not an invasion.\",\"retrieval_timestamp\":\"2026-06-30T00:20:30Z\",\"role\":\"plaintiff\",\"sha256\":\"6627f15cd3a42cc9018d2ab70f1951aa4f1687bd18848c031287516048d42d80\",\"size_bytes\":1793,\"source_description\":\"White House release page, extracted via web.open on 2026-06-30.\",\"source_url\":\"https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\",\"title\":\"PX-2 White House release collecting Secretary Rubio statements\"},{\"evidence_id\":\"ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47\",\"mime_type\":\"text/plain\",\"phase\":\"arguments\",\"relevance\":\"Contemporaneous credible reporting on the U.S. buildup, strikes, first known operation on Venezuelan soil, Jan. 3 large-scale strike across Caracas, capture/removal of Maduro and Flores, and related military posture.\",\"retrieval_timestamp\":\"2026-06-30T00:21:00Z\",\"role\":\"plaintiff\",\"sha256\":\"2efdab998e47ae16cff6d6becb03e7e9216bee4b668814addd1ef89d84c57ec8\",\"size_bytes\":2038,\"source_description\":\"PBS NewsHour page carrying Associated Press timeline by Ben Finley, Konstantin Toropin, and Regina Garcia Cano; extracted via web.open/find on 2026-06-30.\",\"source_url\":\"https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\",\"title\":\"PX-3 PBS/AP timeline of U.S. escalation and Maduro capture\"},{\"evidence_id\":\"ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f\",\"mime_type\":\"text/plain\",\"phase\":\"arguments\",\"relevance\":\"Independent expert analysis confirming a Jan. 3 U.S. special operation in Caracas and preserving the adverse official claim that it was not an invasion or occupation.\",\"retrieval_timestamp\":\"2026-06-30T00:21:30Z\",\"role\":\"plaintiff\",\"sha256\":\"52e4d5a16b2f936b7515e76a65ecfde48c040e48b94b144702fbe1e32123f0c3\",\"size_bytes\":1680,\"source_description\":\"Brookings Institution analysis page, extracted via web.open on 2026-06-30.\",\"source_url\":\"https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\",\"title\":\"PX-4 Brookings analysis of Jan. 3 Maduro operation and legal limit\"},{\"evidence_id\":\"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf\",\"mime_type\":\"text/plain\",\"phase\":\"arguments\",\"relevance\":\"Independent international-law analysis characterizing the operation as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction, and a U.S. announcement to run/administer a transition under threat of force.\",\"retrieval_timestamp\":\"2026-06-30T00:22:00Z\",\"role\":\"plaintiff\",\"sha256\":\"94e861ebadbf2849cd4257d954fcd51afc5f6a8d01c7b5f2df165cc6d4180151\",\"size_bytes\":1755,\"source_description\":\"Chatham House expert comment by Marc Weller, extracted via web.open/find on 2026-06-30.\",\"source_url\":\"https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\",\"title\":\"PX-5 Chatham House analysis of U.S. capture, strikes, and transition control\"},{\"evidence_id\":\"ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79\",\"mime_type\":\"text/plain\",\"phase\":\"arguments\",\"relevance\":\"Official source on Operation Absolute Resolve showing both adverse facts (Caracas operation and transition comments) and defense facts (capture/extraction, criminal proceedings, joint military/law-enforcement mission, no U.S. casualties, anti-narcoterrorism context).\",\"retrieval_timestamp\":\"2026-06-30T00:29:30Z\",\"role\":\"defendant\",\"sha256\":\"26011b5f6d792bc39d1eabe168123482dcc270e34745035055127683c27c55e1\",\"size_bytes\":2203,\"source_description\":\"Department of War/Pentagon News article by Matthew Olay, opened via web.open on 2026-06-30.\",\"source_url\":\"https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\",\"title\":\"DX-1 Department of War article on Maduro capture as joint law-enforcement mission\"},{\"evidence_id\":\"ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9\",\"mime_type\":\"text/plain\",\"phase\":\"arguments\",\"relevance\":\"Official oversight source characterizing Operation Southern Spear as a mission to disrupt narcotics flows, with boat strikes, deployments, and interdictions, supporting defense that the broader campaign was counter-narcotics rather than territorial occupation.\",\"retrieval_timestamp\":\"2026-06-30T00:18:00Z\",\"role\":\"defendant\",\"sha256\":\"53782f10ceb9c41feb405f741ad20b53fef01f5306f2442df751c9f7a09e5345\",\"size_bytes\":1989,\"source_description\":\"Lead Inspector General report to Congress on Operation Southern Spear, January 1-March 31 2026, opened via web.open PDF extraction on 2026-06-30.\",\"source_url\":\"https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\",\"title\":\"DX-2 Lead IG Operation Southern Spear report extract on counter-narcotics mission\"}],\"surrebuttals\":[{\"phase\":\"surrebuttals\",\"role\":\"defendant\",\"text\":\"Council members, plaintiff’s rebuttal usefully narrows the dispute to two points: the Caracas site and the transition language. Neither carries plaintiff’s burden.\\n\\nFirst, plaintiff says the fortified military site in Caracas satisfies “any portion” because U.S. forces necessarily denied Venezuelan control long enough to seize and remove Maduro. That proves tactical control; it does not prove that the United States commenced an offensive intended to establish territorial control. Those are different things. A raid, arrest, rescue, or extraction at a defended facility always requires temporary domination of the target area. If that alone satisfies the proposition, the phrase “intended to establish control” does no work, and every cross-border commando raid becomes an invasion under this standard.\\n\\nThe record does not show the Caracas site was an object to be held, administered, possessed, governed, or transferred as territory. DX-1 describes a ground-based extraction force, a capture, criminal proceedings, and a joint military/law-enforcement mission. It is adverse because the operation was large and military; it is still not proof that the United States intended to establish control over Venezuelan land rather than control the scene long enough to extract two people.\\n\\nSecond, plaintiff relies on “oversee Venezuela” and PX-5’s transition-control wording. That is the strongest contrary evidence, but it remains ambiguous. Political leverage over a successor government is not the same as territorial control. DX-1 says Delcy Rodriguez was sworn in and was willing to work with the United States. That is not the United States installing a military government over a place, holding facilities, drawing boundaries, manning checkpoints, or leaving forces in control after the raid.\\n\\nPlaintiff says the defense imports an occupation requirement. No. The defense accepts that the proposition does not require annexation or a long occupation. But it does require an intent to establish control over territory. A short duration can qualify if the object is control of the place. Here the record shows a short duration whose object was capture and extraction. The admitted sources show force, pressure, and influence; they do not show a territorial-control objective.\\n\\nDX-2 still matters for that reason. Plaintiff says it does not negate Operation Absolute Resolve. True, it does not decide the whole case. But it is an official oversight account of the broader campaign as counter-narcotics, interdiction, and strikes, with the mission statement classified. Plaintiff has not filled that classified gap with an operational order, full transcript, or post-operation facts showing that the Caracas raid changed into a territorial-control campaign.\\n\\nThe council can condemn the operation as unlawful, coercive, or interventionist and still find the proposition not proved. The question is not whether the United States used overwhelming force inside Venezuela. It did. The question is whether credible sources show, more likely than not, that the United States intended to establish control over Venezuelan territory. The record remains at most equivocal on that decisive element, so plaintiff has not carried the burden.\"}],\"technical_reports\":[{\"phase\":\"arguments\",\"role\":\"plaintiff\",\"summary\":\"Before filing, plaintiff checked the record and found no case-packet evidence. Plaintiff submitted five text-readable source captures. Official White House materials are strong provenance for U.S. admissions but self-serving on labels; AP/PBS provides contemporaneous reporting; Brookings and Chatham House provide independent expert analysis, including adverse framing. Missing but potentially useful later sources include DOD after-action or press briefing text, a direct video/transcript of President Trump's transition-control statement, and fuller mapping of exact ground-control sites.\",\"title\":\"Plaintiff Source and Weight Ledger\"},{\"phase\":\"arguments\",\"role\":\"defendant\",\"summary\":\"Defendant inspected the record with get_case/list_evidence and read all five plaintiff text exhibits with read_evidence_range. Defendant submitted and read back two official defense exhibits: Department of War/Pentagon News on Operation Absolute Resolve and the Lead IG Operation Southern Spear report extract. Additional searches found DOJ and War/State leads but they were not submitted because the admitted official record already captured the key law-enforcement/counter-narcotics framing. Weight assessment: PX-2, DX-1, and DX-2 are official and strong for source identity; PX-5 is credible expert commentary but not a primary operational order or full transcript. Unresolved gaps include the full Trump transition-control video/transcript, full State transcript, and post-operation facts about who actually governed territory.\",\"title\":\"Defense Source and Weight Ledger\"},{\"phase\":\"surrebuttals\",\"role\":\"defendant\",\"summary\":\"Defendant inspected get_case and list_evidence before filing. Plaintiff rebuttal added no new evidence; it relied on existing DX-1, DX-2, and PX-5. Prior exact reads of those text exhibits remain controlling. No new external source was submitted because the rebuttal turned on interpretation of the existing record, not a new factual source.\",\"title\":\"Surrebuttal Evidence Check\"}]}}},\"turn\":{\"attempts_max\":3,\"attempts_remaining\":3,\"completed\":false,\"deadline\":\"2026-06-30T00:48:10.359530297Z\",\"deliberation_round\":1,\"member_id\":\"C2\",\"opportunity_id\":\"deliberation:1:C2\",\"phase\":\"deliberation\",\"remaining_ms\":881479,\"role_id\":\"council\",\"turn_number\":10}}"}],"structuredContent":{"case_id":"arb-ex05-20260630001330","member_id":"C2","ok":true,"result":{"case":{"evidence_standard":"Preponderance of the evidence.","member":{"member_id":"C2","model":"openrouter://mistralai/mistral-medium-3-5","persona_filename":"personas/generic.md"},"opportunity":{"allowed_tools":["submit_council_vote"],"id":"deliberation:1:C2","may_pass":false,"objective":"council vote by C2","phase":"deliberation","role":"council"},"phase":"deliberation","proposition":"The United States invaded Venezuela between November 3, 2025, and\nJanuary 31, 2026, 11:59 PM ET.  In particular,the United States\ncommenced a military offensive intended to establish control over any\nportion of Venezuela between November 3, 2025, and January 31, 2026,\n11:59 PM ET. Land de facto controlled by Venezuela or the United\nStates as of September 6, 2025, 12:00 PM ET, is considered to the\nsovereign territory of that country. The resolution source is a\nconsensus of credible sources.","record":{"arguments":[{"phase":"arguments","role":"plaintiff","text":"Council members, the admitted record now answers the defendant’s missing-link argument. The proposition requires a U.S. military offensive intended to establish control over any portion of Venezuelan territory. It does not require permanent annexation, a months-long occupation, or magic words from U.S. officials.\n\nThe record proves a campaign, not a one-off arrest. AP/PBS reports a months-long escalation: 35 known strikes against alleged drug-smuggling boats, a regional naval buildup including destroyers, amphibious assault ships, about 6,000 sailors and Marines, aircraft, F-35s and a cruise-missile submarine, then CIA operations inside Venezuela. It further reports a late-December direct operation on Venezuelan soil and, on January 3, a large-scale strike across Caracas, capture of Maduro and Flores, and their removal from the country. PX-3.\n\nThe official U.S. record confirms the coercive structure. The White House says President Trump authorized lethal force, ordered a total and complete blockade of sanctioned oil tankers going in and out of Venezuela, offered Maduro “off ramps,” and that U.S. armed forces conducted an extraordinary military operation to bring Maduro to justice. It also states Venezuelan sovereign oil revenues were held in U.S. custody and protected to advance U.S. foreign-policy objectives in Venezuela. PX-1.\n\nMost importantly, the official adverse source admits territorial entry. Secretary Rubio’s White House release says U.S. forces were on the ground in Venezuela for about two hours when they went to capture Maduro. It also says Venezuela would continue to face an oil quarantine, U.S. pressure, seizure of sanctioned boats, targeting of drug boats, and “potentially other things” until the changes demanded by the United States were made. PX-2. That is not just a completed criminal arrest; it is ground force, blockade, coercive options, and compelled policy change.\n\nIndependent sources confirm the meaning of those facts. Brookings describes the January 3 operation as a U.S. special operation to exfiltrate Maduro and his wife from Caracas; it fairly preserves Rubio’s answer that this was not an invasion and the U.S. did not occupy a country. PX-4. Chatham House goes further on the facts relevant here: U.S. forces operating in Venezuela, strikes on military targets in and around Caracas, U.S. special forces forcibly abducting the sitting president, and President Trump announcing that the United States would run Venezuela and administer a political transition or regime change under threat of further, more massive force. PX-5.\n\nThis record proves all elements by a preponderance. First, the date is inside the window: late December direct action on Venezuelan soil and the January 3 Caracas operation occurred before January 31, 2026. Second, it was military: armed forces, special forces, strikes, warships, aircraft, a submarine, lethal force, and blockade. Third, it reached Venezuelan territory: Caracas, a military-base home, military targets in and around the capital, and official admission of U.S. forces on Venezuelan ground. Fourth, the intended control element is satisfied by control over portions and sovereign functions: the target zone in Caracas for the capture, the air/strike environment needed to carry it out, sea lanes through blockade and oil quarantine, custody of Venezuelan sovereign oil revenues, and the announced plan to run or administer Venezuela’s transition under threat of more force.\n\nThe defense will lean on Rubio’s labels: not a war against Venezuela, not an invasion, not extended. But labels do not defeat underlying admissions. Rubio’s own statement supplies the key facts: U.S. forces were on Venezuelan ground, used a raid to capture the effective ruler, and retained coercive options until Venezuela changed course. The proposition’s phrase “any portion” is broad. Two hours of armed control in Caracas is still control over a portion; a blockade and oil quarantine are control over access and resources; removal of the effective ruler plus asserted transition authority is control over sovereign political functions.\n\nNor does the law-enforcement framing save the defense. A police purpose can coexist with a military offensive if the means are military and the intended effect is control. Here the operation was preceded by lethal strikes and blockade, executed by U.S. forces inside Venezuela, and followed by continuing threats and resource control. The credible-source consensus is not that nothing happened; it is that the United States used force inside Venezuela, captured and removed Maduro, and then sought to direct Venezuela’s course.\n\nProvenance and limits: PX-1 and PX-2 are official U.S. sources and therefore especially strong against U.S. denial of ground presence, blockade, and resource custody, though self-serving on legal labels. PX-3 is contemporaneous AP reporting carried by PBS. PX-4 and PX-5 are expert analyses, not primary operational records, so they carry less weight than official admissions but are valuable for independent assessment and adverse framing. The record lacks a full DOD after-action report or original video transcript for every statement, but the admitted sources converge on the decisive facts.\n\nOn this record, it is more likely than not that the United States commenced a military offensive intended to establish control over portions of Venezuela during the required period. The proposition should be found true."},{"phase":"arguments","role":"defendant","text":"Council members, the record now proves a serious U.S. military operation in and against Venezuela. The defense should not pretend otherwise. It proves strikes, a buildup, a Caracas raid, a two-hour ground presence, capture and removal of Maduro and Flores, oil/tanker pressure, and political leverage. But the proposition is still narrower: plaintiff must prove that the United States commenced a military offensive intended to establish control over Venezuelan territory. On this record, that missing intent remains unproved.\n\nStart with the official sources. PX-2 records Secretary Rubio admitting a two-hour ground presence, but in the same official statement he says the United States was not at war with Venezuela, was at war with drug-trafficking organizations, and that this was not an invasion or extended military operation. PX-4 independently preserves the same limiting point: Rubio’s answer was “not an invasion” and “we did not occupy a country.” Those labels are not conclusive, but they are highly relevant to intent.\n\nDX-1, the Department of War’s own article, confirms the adverse facts: an operation in Caracas, more than 150 aircraft covering a ground extraction force, and months of planning. But it repeatedly frames Operation Absolute Resolve as a capture, extraction, criminal-justice operation, and joint military/law-enforcement mission tied to a DOJ indictment. DX-2 gives the broader campaign frame: Operation Southern Spear was officially initiated to disrupt narcotics flows from designated terrorist and criminal organizations, primarily through boat strikes, interdictions, and regional deployments. That is evidence of coercive military force; it is not proof that the object was to establish control over Venezuelan land.\n\nPlaintiff’s argument turns “any portion” into “any tactical control during any raid.” That is too broad. Every armed entry temporarily controls some doorway, route, landing zone, airspace, or target room. If that incidental control is enough, the proposition would be true of any commando arrest or rescue operation inside foreign territory. The wording requires more: an offensive intended to establish control over a portion of Venezuela, not merely control incident to seizing a person and leaving.\n\nPX-1 likewise does not close the gap. It shows custody of Venezuelan oil revenues in U.S. Treasury accounts, a blockade of sanctioned oil tankers, lethal force against narcoterrorists, and an armed-forces operation in support of law enforcement. Those are grave acts of pressure and may be hostile, illegal, or interventionist. But money in Treasury accounts and tanker interdictions are not control over Venezuelan territory. A blockade may control maritime access; it does not, without more, show intent to possess, administer, or govern land that the proposition treats as Venezuelan sovereign territory.\n\nPX-3 is credible reporting, but its strongest points are still escalation and force: 35 boat strikes, warships, CIA operations, a late-December direct strike, and the January 3 Caracas capture. It also notes Maduro’s view that the campaign sought to oust him. Regime-change pressure is not the same as territorial-control intent. The related PBS watch-title about the United States “going to run Venezuela” is only a linked title in the submitted extract, not the video, transcript, context, or exact statement.\n\nPX-5 is plaintiff’s strongest source because Chatham House characterizes the operation as strikes around Caracas, special-forces abduction, and a U.S. announcement to run or administer a transition under threat of more force. The council should weigh it seriously, but also carefully. It is expert legal commentary about sovereignty and the UN Charter, not a primary operational order or full transcript. It supports that the operation may have been an unlawful use of force or aggression. It does not supply concrete facts that U.S. forces occupied, administered, or held any Venezuelan place after the raid.\n\nEven DX-1’s adverse transition language is equivocal. It says the United States would “oversee” Venezuela until a legitimate replacement could be identified and that Rubio was working with Delcy Rodriguez. That sounds like political direction and leverage. But the same source says Rodriguez was sworn in, that she was willing to work with the United States, and that the mission was an extraction/capture with no U.S. casualties. The record has no order establishing U.S. military government, no map of controlled territory, no duration beyond the two-hour raid, no U.S. checkpoints, no occupied ministries, no seized ports or bases held afterward, and no source showing U.S. forces remained to administer land.\n\nThat distinction decides the case. The record proves force, illegality arguments, coercion, and perhaps regime-change influence. It does not prove by a preponderance that territorial control was the intended object of the offensive. The credible-source consensus is mixed: official sources say capture, law enforcement, counter-narcotics, no invasion, no occupation; secondary sources condemn the operation and infer broader control, but rely on thinly captured transition language and legal characterization.\n\nThe plaintiff bears the burden. Because the admitted record does not show that the United States intended to establish control over Venezuelan territory, as opposed to conducting a short capture/extraction and applying continuing non-territorial pressure, the council should find the proposition not proved."}],"closings":[{"phase":"closings","role":"plaintiff","text":"Council members, the proposition is proven by a preponderance of the admitted record.\n\nThe defense is right about one thing: this case is not decided by the word “invasion” in a press release. It is decided by the proposition’s actual test: whether, during the window, the United States commenced a military offensive intended to establish control over any portion of Venezuela.\n\nThe record establishes the military offensive. PX-3 shows the broader escalation: repeated lethal strikes, a major naval and air buildup, CIA operations inside Venezuela, a direct operation on Venezuelan soil, and on January 3 a large-scale strike across Caracas that captured Maduro and Flores and flew them out of the country. PX-1, an official White House source, confirms lethal-force authorization, a blockade of sanctioned oil tankers going in and out of Venezuela, and an extraordinary U.S. armed-forces operation to bring Maduro to justice. PX-2, another official source, admits U.S. forces were on the ground in Venezuela for about two hours.\n\nThe record also establishes intended control over a portion of Venezuela. This is where DX-1, the defense’s own official Department of War exhibit, is decisive. DX-1 does not describe a spontaneous police pickup. It describes Operation Absolute Resolve in Caracas against a heavily fortified military fortress in the heart of Venezuela’s capital; months of planning by joint forces, special operations forces, and intelligence agencies; complex air, ground, space, and maritime operations; more than 150 military aircraft covering the ground extraction force; and a massive joint military and law-enforcement raid. A force does not conduct that operation without intending to control the target portion of Caracas and the surrounding operational environment long enough to accomplish the seizure.\n\nThe defense says that is only tactical control. But the proposition says “any portion,” and it does not require permanent occupation, annexation, checkpoints, or weeks of administration. Planned armed domination of a fortified military site in the capital, backed by 150 aircraft and integrated military domains, is control over a portion. The fact that the control was temporary does not make it accidental or legally invisible.\n\nThe record further shows that the control objective was not limited to a room or doorway. DX-1 reports Trump saying the United States would oversee Venezuela until a safe transition could be identified, with Rubio working directly with Delcy Rodriguez and Rodriguez willing to do what the United States thought necessary. PX-5 independently characterizes the same event as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction of a sitting president, and U.S. administration of a transition under threat of more force. PX-1 adds custody of Venezuelan sovereign oil revenues and blockade pressure; PX-2 adds continued oil quarantine, pressure, retained options, and demanded changes.\n\nThe defense’s contrary proof does not defeat the burden. Rubio’s “not an invasion” label and DX-2’s counter-narcotics framing are relevant, but they are not controlling. DX-2 addresses the broader Southern Spear campaign and admits its mission statement is classified; it does not negate the specific Caracas operation. Official legal labels are self-serving. The underlying facts are stronger: military force inside Venezuela, control of a fortified capital target, removal of the effective ruler, blockade and resource custody, and asserted transition oversight.\n\nThe record has limits. There is no map of every controlled street and no full after-action report. But preponderance does not require perfect operational detail. A consensus of official sources, AP/PBS reporting, and independent expert analysis shows that the United States crossed the line from pressure and strikes into a planned military offensive to control at least portions and sovereign functions of Venezuela.\n\nFind the proposition true."},{"phase":"closings","role":"defendant","text":"Council members, the defense closing does not ask you to minimize what happened. The admitted record shows a major U.S. military operation involving strikes, regional buildup, a Caracas raid, a two-hour ground presence, capture and removal of Maduro and Flores, oil and tanker pressure, and sharp U.S. political leverage over Venezuela’s future. The question is whether that record proves the proposition actually before you: a military offensive intended to establish control over Venezuelan territory.\n\nIt does not.\n\nThe plaintiff’s strongest argument is that a planned raid on a fortified military site in Caracas necessarily involved control over “any portion” of Venezuela. But the proposition does not ask whether U.S. forces temporarily dominated a target area. It asks whether the United States commenced an offensive intended to establish control. That intent element matters. A force can control a site long enough to enter, capture, and leave without intending to establish control over that site as territory. Plaintiff’s reading would make the territorial-control element automatic in every armed cross-border arrest, rescue, or extraction at a defended location.\n\nDX-1 is the central exhibit, and it cuts both ways. It confirms the adverse facts: Caracas, a heavily fortified target, months of planning, integrated military domains, and more than 150 aircraft covering the extraction force. But its repeated description of the operation is capture, extraction, criminal proceedings, and a joint military and law-enforcement mission. That is not just a label; it is the operational object described by the official source. It shows tactical control in service of seizure and removal, not a plan to possess, administer, or govern Venezuelan land.\n\nPX-2 and PX-4 reinforce that limiting inference. Rubio admitted the two-hour ground presence, but said the United States was not at war with Venezuela, was acting against drug-trafficking organizations, and that the action was not an invasion, not an extended operation, and not an occupation. Those statements are self-serving, but they are still official evidence of intent. DX-2 places the broader campaign in the same frame: counter-narcotics, interdiction, boat strikes, tanker seizures, and a classified mission statement. It is proof of coercive force, not proof of territorial administration.\n\nPlaintiff’s second strong point is transition language: DX-1 says the United States would oversee Venezuela until a safe transition could be identified, and PX-5 describes U.S. administration of a transition under threat of force. That evidence is troubling and deserves weight. But it remains ambiguous on the decisive issue. Political leverage over Delcy Rodriguez, pressure on resources, or demands about Venezuela’s policy direction are not the same as control over Venezuelan territory. The record does not show U.S. troops remained after the raid, that they held ministries, ports, bases, roads, neighborhoods, or oil fields, that they established checkpoints, that they drew controlled boundaries, or that they installed a military government over any place.\n\nPX-1 likewise proves pressure, not territorial control. Custody of oil revenues in U.S. Treasury accounts and a blockade of sanctioned tankers may be coercive, even unlawful. But they are not possession or administration of Venezuelan land. PX-3 proves escalation and force, but its submitted extract does not provide the full content behind the linked “run Venezuela” item. PX-5 is credible expert commentary on international law, but it is not a primary operational order, full transcript, or after-action record proving that control of territory was the intended object.\n\nThe council can find that the United States violated Venezuelan sovereignty. It can find that the operation was aggressive, interventionist, coercive, and politically consequential. Those findings still do not answer the proposition unless the record also shows intended establishment of territorial control.\n\nOn that decisive element, the record is at best mixed. Plaintiff has powerful evidence of military force and temporary tactical domination. The defense has official evidence that the mission object was capture, extraction, law enforcement, and counter-narcotics, plus a record gap on any continuing territorial mechanism. Under a preponderance standard, ambiguity on the proposition’s central intent element means plaintiff has not carried its burden.\n\nFind the proposition not proved."}],"evidence":[{"admissibility_status":"submitted_evidence","created_at":"2026-06-30T00:20:59Z","evidence_id":"ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a","mime_type":"text/plain","original_name":"submitted-evidence-01-plaintiff-0c5c88687b2a.txt","record_visibility":"juror_visible","relevance":"Official U.S. source admitting oil-revenue custody, blockade, lethal-force authorization, and an armed forces operation against Maduro within the case window.","retrieval_timestamp":"2026-06-30T00:20:00Z","sha256":"0c5c88687b2a889093788193bdd900106b95ff6ccfab1af50709f67df61cb673","size_bytes":1819,"source_description":"White House fact sheet page, extracted via web.open on 2026-06-30.","source_url":"https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/","storage_name":"0c/0c5c88687b2a889093788193bdd900106b95ff6ccfab1af50709f67df61cb673","submitted_by_role":"plaintiff","submitted_phase":"arguments","text_readable":true,"title":"PX-1 White House fact sheet on Venezuelan oil revenue and U.S. operation"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-30T00:24:59Z","evidence_id":"ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79","mime_type":"text/plain","original_name":"submitted-evidence-06-defendant-26011b5f6d79.txt","record_visibility":"juror_visible","relevance":"Official source on Operation Absolute Resolve showing both adverse facts (Caracas operation and transition comments) and defense facts (capture/extraction, criminal proceedings, joint military/law-enforcement mission, no U.S. casualties, anti-narcoterrorism context).","retrieval_timestamp":"2026-06-30T00:29:30Z","sha256":"26011b5f6d792bc39d1eabe168123482dcc270e34745035055127683c27c55e1","size_bytes":2203,"source_description":"Department of War/Pentagon News article by Matthew Olay, opened via web.open on 2026-06-30.","source_url":"https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/","storage_name":"26/26011b5f6d792bc39d1eabe168123482dcc270e34745035055127683c27c55e1","submitted_by_role":"defendant","submitted_phase":"arguments","text_readable":true,"title":"DX-1 Department of War article on Maduro capture as joint law-enforcement mission"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-30T00:21:36Z","evidence_id":"ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47","mime_type":"text/plain","original_name":"submitted-evidence-03-plaintiff-2efdab998e47.txt","record_visibility":"juror_visible","relevance":"Contemporaneous credible reporting on the U.S. buildup, strikes, first known operation on Venezuelan soil, Jan. 3 large-scale strike across Caracas, capture/removal of Maduro and Flores, and related military posture.","retrieval_timestamp":"2026-06-30T00:21:00Z","sha256":"2efdab998e47ae16cff6d6becb03e7e9216bee4b668814addd1ef89d84c57ec8","size_bytes":2038,"source_description":"PBS NewsHour page carrying Associated Press timeline by Ben Finley, Konstantin Toropin, and Regina Garcia Cano; extracted via web.open/find on 2026-06-30.","source_url":"https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture","storage_name":"2e/2efdab998e47ae16cff6d6becb03e7e9216bee4b668814addd1ef89d84c57ec8","submitted_by_role":"plaintiff","submitted_phase":"arguments","text_readable":true,"title":"PX-3 PBS/AP timeline of U.S. escalation and Maduro capture"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-30T00:21:52Z","evidence_id":"ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f","mime_type":"text/plain","original_name":"submitted-evidence-04-plaintiff-52e4d5a16b2f.txt","record_visibility":"juror_visible","relevance":"Independent expert analysis confirming a Jan. 3 U.S. special operation in Caracas and preserving the adverse official claim that it was not an invasion or occupation.","retrieval_timestamp":"2026-06-30T00:21:30Z","sha256":"52e4d5a16b2f936b7515e76a65ecfde48c040e48b94b144702fbe1e32123f0c3","size_bytes":1680,"source_description":"Brookings Institution analysis page, extracted via web.open on 2026-06-30.","source_url":"https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/","storage_name":"52/52e4d5a16b2f936b7515e76a65ecfde48c040e48b94b144702fbe1e32123f0c3","submitted_by_role":"plaintiff","submitted_phase":"arguments","text_readable":true,"title":"PX-4 Brookings analysis of Jan. 3 Maduro operation and legal limit"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-30T00:25:19Z","evidence_id":"ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9","mime_type":"text/plain","original_name":"submitted-evidence-07-defendant-53782f10ceb9.txt","record_visibility":"juror_visible","relevance":"Official oversight source characterizing Operation Southern Spear as a mission to disrupt narcotics flows, with boat strikes, deployments, and interdictions, supporting defense that the broader campaign was counter-narcotics rather than territorial occupation.","retrieval_timestamp":"2026-06-30T00:18:00Z","sha256":"53782f10ceb9c41feb405f741ad20b53fef01f5306f2442df751c9f7a09e5345","size_bytes":1989,"source_description":"Lead Inspector General report to Congress on Operation Southern Spear, January 1-March 31 2026, opened via web.open PDF extraction on 2026-06-30.","source_url":"https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF","storage_name":"53/53782f10ceb9c41feb405f741ad20b53fef01f5306f2442df751c9f7a09e5345","submitted_by_role":"defendant","submitted_phase":"arguments","text_readable":true,"title":"DX-2 Lead IG Operation Southern Spear report extract on counter-narcotics mission"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-30T00:21:17Z","evidence_id":"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4","mime_type":"text/plain","original_name":"submitted-evidence-02-plaintiff-6627f15cd3a4.txt","record_visibility":"juror_visible","relevance":"Official U.S. statements acknowledging two-hour U.S. ground presence in Venezuela, oil quarantine/pressure, retained options, and the adverse claim that the action was not an invasion.","retrieval_timestamp":"2026-06-30T00:20:30Z","sha256":"6627f15cd3a42cc9018d2ab70f1951aa4f1687bd18848c031287516048d42d80","size_bytes":1793,"source_description":"White House release page, extracted via web.open on 2026-06-30.","source_url":"https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/","storage_name":"66/6627f15cd3a42cc9018d2ab70f1951aa4f1687bd18848c031287516048d42d80","submitted_by_role":"plaintiff","submitted_phase":"arguments","text_readable":true,"title":"PX-2 White House release collecting Secretary Rubio statements"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-30T00:22:10Z","evidence_id":"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf","mime_type":"text/plain","original_name":"submitted-evidence-05-plaintiff-94e861ebadbf.txt","record_visibility":"juror_visible","relevance":"Independent international-law analysis characterizing the operation as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction, and a U.S. announcement to run/administer a transition under threat of force.","retrieval_timestamp":"2026-06-30T00:22:00Z","sha256":"94e861ebadbf2849cd4257d954fcd51afc5f6a8d01c7b5f2df165cc6d4180151","size_bytes":1755,"source_description":"Chatham House expert comment by Marc Weller, extracted via web.open/find on 2026-06-30.","source_url":"https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification","storage_name":"94/94e861ebadbf2849cd4257d954fcd51afc5f6a8d01c7b5f2df165cc6d4180151","submitted_by_role":"plaintiff","submitted_phase":"arguments","text_readable":true,"title":"PX-5 Chatham House analysis of U.S. capture, strikes, and transition control"}],"exhibits":[{"evidence_id":"ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a","label":"PX-1 White House fact sheet on operation, blockade, and oil revenues","phase":"arguments","role":"plaintiff","text":"Source: The White House, Fact Sheet: President Donald J. Trump Safeguards Venezuelan Oil Revenue for the Good of the American and Venezuelan People. Date on page: January 9, 2026. URL: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\n\nExtracted relevant page text:\n- President Trump signed an Executive Order declaring a national emergency to safeguard Venezuelan oil revenue held in U.S. Treasury accounts from attachment or judicial process, preserving the funds to advance U.S. foreign policy objectives.\n- Foreign Government Deposit Funds are defined as Venezuelan oil revenues and diluent sales held in U.S. Treasury accounts.\n- The order affirms the funds are sovereign property of Venezuela held in U.S. custody for governmental and diplomatic purposes.\n- The White House says loss of control over these revenues would weaken efforts to bring peace, prosperity, and stability to Venezuela and the Western Hemisphere.\n- The fact sheet states: President Trump authorized lethal force against narcoterrorists to stop the flow of deadly drugs into this country.\n- It states: President Trump ordered a total and complete blockade of all sanctioned oil tankers going in and out of Venezuela.\n- It states: President Trump offered multiple off ramps to Maduro and his illegitimate regime, but he was clear that the drug trafficking must stop.\n- It states: Last week, U.S. armed forces conducted an extraordinary military operation in support of law enforcement to bring outlaw dictator Maduro to justice.\n- It states that the President's actions reestablish deterrence in the Western hemisphere and that safeguarding these oil revenues promotes stability in Venezuela while advancing U.S. objectives."},{"evidence_id":"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4","label":"PX-2 White House Rubio statements on ground presence and pressure","phase":"arguments","role":"plaintiff","text":"Source: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\n\nExtracted relevant page text:\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\n- Rubio stated Maduro was not the head of state and was an illegitimate president."},{"evidence_id":"ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47","label":"PX-3 PBS/AP timeline of escalation and Caracas strike","phase":"arguments","role":"plaintiff","text":"Source: PBS NewsHour / Associated Press, A timeline of U.S. military escalation against Venezuela leading to Maduro's capture. By Ben Finley, Konstantin Toropin, Regina Garcia Cano. Date on page: Jan. 3, 2026 1:54 PM EDT. URL: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\n\nExtracted relevant page text:\n- AP reported that Trump had threatened military strikes on targets on Venezuelan territory after months of attacks on boats accused of carrying drugs from Venezuela; Maduro said U.S. military operations were a thinly veiled effort to oust him.\n- On Jan. 3 the U.S. conducted a large-scale strike against Venezuela. Maduro and Cilia Flores were taken from their home on a military base and were aboard a U.S. warship on their way to New York to face criminal charges.\n- Before the escalation, there had been 35 known strikes against alleged drug-smuggling boats in South American waters since early September, killing at least 115 people according to administration announcements.\n- The U.S. sent a fleet of warships to the region, the largest buildup of forces in generations; the naval force grew to include guided-missile destroyers, three amphibious assault ships and other vessels, about 6,000 sailors and Marines, aircraft, F-35 fighter jets in Puerto Rico, and a Navy submarine carrying cruise missiles off South America.\n- On Oct. 15, Trump confirmed he had authorized the CIA to conduct covert operations inside Venezuela and was weighing land operations in the country.\n- On Dec. 29/30, a drone strike at a docking area believed used by Venezuelan drug cartels was reported as the first known direct operation on Venezuelan soil since the strikes began.\n- On Jan. 3, AP reported that the U.S. conducted a large-scale strike across Caracas, captured Maduro and Flores, and flew them out of the country.\n- The related PBS page links included a watch item titled: Trump says U.S. is going to run Venezuela until transition of power after capturing Maduro."},{"evidence_id":"ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f","label":"PX-4 Brookings analysis and adverse Rubio framing","phase":"arguments","role":"plaintiff","text":"Source: Brookings Institution, Making sense of the US military operation in Venezuela. URL: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\n\nExtracted relevant page text:\n- Brookings states: On January 3, 2026, the United States launched a special operation to exfiltrate Venezuelan President Nicolás Maduro and his wife from Caracas.\n- Scott R. Anderson writes that the operation to capture Maduro underscores the broad authority modern presidents exercise over military force and potentially its limits.\n- Brookings notes the executive branch position that the president has constitutional authority to use military force without congressional authorization if supporting U.S. interests and not expected to result in prolonged and substantial military engagements.\n- Anderson writes it is not surprising for the administration to argue that the president can take targeted military action like the Maduro operation, even where consequential for Venezuela and contrary to international law.\n- Brookings records Secretary Rubio's response when asked why congressional authorization was not needed: This was not an invasion, we did not occupy a country. Brookings treats that as suggesting broader campaigns might exceed unilateral authority.\n- Brookings states a second wave of the sort threatened by President Trump still might encounter limits.\n- Brookings separately states that Maduro is gone and what comes next is unclear; maintaining Delcy Rodríguez indefinitely would undermine the expressed will of Venezuelans, and threatening force to keep the Rodríguez government in line may work in the short term but is not sustainable."},{"evidence_id":"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf","label":"PX-5 Chatham House analysis of operation and transition control","phase":"arguments","role":"plaintiff","text":"Source: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\n\nExtracted relevant page text:\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela."},{"evidence_id":"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4","label":"PX-2 White House Rubio statements on ground presence and no-invasion/no-occupation framing","phase":"arguments","role":"defendant","text":"Source: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\n\nExtracted relevant page text:\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\n- Rubio stated Maduro was not the head of state and was an illegitimate president."},{"evidence_id":"ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f","label":"PX-4 Brookings analysis preserving Rubio no-invasion/no-occupation framing","phase":"arguments","role":"defendant","text":"Source: Brookings Institution, Making sense of the US military operation in Venezuela. URL: https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/\n\nExtracted relevant page text:\n- Brookings states: On January 3, 2026, the United States launched a special operation to exfiltrate Venezuelan President Nicolás Maduro and his wife from Caracas.\n- Scott R. Anderson writes that the operation to capture Maduro underscores the broad authority modern presidents exercise over military force and potentially its limits.\n- Brookings notes the executive branch position that the president has constitutional authority to use military force without congressional authorization if supporting U.S. interests and not expected to result in prolonged and substantial military engagements.\n- Anderson writes it is not surprising for the administration to argue that the president can take targeted military action like the Maduro operation, even where consequential for Venezuela and contrary to international law.\n- Brookings records Secretary Rubio's response when asked why congressional authorization was not needed: This was not an invasion, we did not occupy a country. Brookings treats that as suggesting broader campaigns might exceed unilateral authority.\n- Brookings states a second wave of the sort threatened by President Trump still might encounter limits.\n- Brookings separately states that Maduro is gone and what comes next is unclear; maintaining Delcy Rodríguez indefinitely would undermine the expressed will of Venezuelans, and threatening force to keep the Rodríguez government in line may work in the short term but is not sustainable."},{"evidence_id":"ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79","label":"DX-1 Department of War article framing Absolute Resolve as capture/extraction and joint law-enforcement mission","phase":"arguments","role":"defendant","text":"Source: U.S. Department of War / Pentagon News, Trump Announces U.S. Military's Capture of Maduro. Date on page: Jan. 3, 2026. URL: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\n\nExtracted relevant page text:\n- President Donald J. Trump announced the capture of Venezuelan leader Nicolas Maduro after a successful overnight joint U.S. military extraction in Caracas, Venezuela.\n- The article identifies the matter as Operation Absolute Resolve in Caracas.\n- Trump said U.S. armed forces conducted an extraordinary military operation in the capital of Venezuela against a heavily fortified military fortress in the heart of Caracas to bring Maduro to justice.\n- The article states Maduro and Cilia Flores de Maduro would face criminal court proceedings tied to a 2020 U.S. Department of Justice indictment on charges including narco-terrorism and drug trafficking.\n- The article says Operation Absolute Resolve was a joint military and law-enforcement mission to capture the Maduros, resulting from months of planning and rehearsal involving U.S. joint forces, special operations forces, and intelligence agencies.\n- Gen. Dan Caine described integrating complex air, ground, space, and maritime operations.\n- The article states the mission to extract the Maduros had no U.S. casualties and involved more than 150 military aircraft providing cover for the ground-based extraction force in Caracas.\n- Secretary Hegseth called it a massive joint military and law-enforcement raid, and said the mission concerned safety, security, freedom, and prosperity of the American people.\n- The article also reports adverse transition language: with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition to a legitimate replacement could be identified; Trump said Marco Rubio was working directly with Delcy Rodriguez and that she was willing to do what the United States thought necessary.\n- The article frames preceding tensions around September 2025 targeted boat strikes, November 2025 designation of Cartel de los Soles as a terror organization, and options to address a narco-terror threat in the region."},{"evidence_id":"ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9","label":"DX-2 Lead IG report framing Southern Spear as counter-narcotics operation","phase":"arguments","role":"defendant","text":"Source: Lead Inspector General report to Congress, Operation Southern Spear, January 1, 2026-March 31, 2026. PDF URL: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\n\nExtracted relevant text:\n- The Lead IG report states that in November 2025 the Department of War initiated Operation Southern Spear as the U.S. mission to disrupt the flow of narcotics from designated terrorist organizations and transnational criminal organizations in the Western Hemisphere.\n- The report covers January 1 through March 31, 2026 and presents oversight work by the Department of War OIG, State OIG, and partner oversight agencies.\n- The report summary states Operation Southern Spear is the Department of War operation to disrupt the flow of narcotics in the Western Hemisphere from drug cartels designated by the President as terrorist organizations.\n- The report states OSS primarily involves lethal airstrikes against small boats suspected of shipping illegal narcotics in the Caribbean Sea and eastern Pacific Ocean.\n- It states that from September 2025 through March 2026, the U.S. military struck at least 45 small boats, resulting in 156 individuals killed or presumed dead.\n- It states the Department of War began moving significant Navy and Marine Corps assets into the USSOUTHCOM area of operations in August 2025 to support OSS.\n- It states Joint Interagency Task Force-South is the U.S. Government's interagency effort to detect, monitor, and target illicit drug trafficking in the air and at sea with the support of 19 partner nations.\n- It states U.S. forces interdicted at least 10 sanctioned tankers around the world since OSS began, including some tracked as far as the Indian Ocean.\n- It states the OSS mission statement is classified.\n\nLimitations: this extracted text does not decide Operation Absolute Resolve's territorial-control intent; it is offered to show the official oversight framing of the broader campaign and the classified-source gap."},{"evidence_id":"ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a","label":"PX-1 White House fact sheet on oil revenues, blockade, and law-enforcement operation","phase":"arguments","role":"defendant","text":"Source: The White House, Fact Sheet: President Donald J. Trump Safeguards Venezuelan Oil Revenue for the Good of the American and Venezuelan People. Date on page: January 9, 2026. URL: https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\n\nExtracted relevant page text:\n- President Trump signed an Executive Order declaring a national emergency to safeguard Venezuelan oil revenue held in U.S. Treasury accounts from attachment or judicial process, preserving the funds to advance U.S. foreign policy objectives.\n- Foreign Government Deposit Funds are defined as Venezuelan oil revenues and diluent sales held in U.S. Treasury accounts.\n- The order affirms the funds are sovereign property of Venezuela held in U.S. custody for governmental and diplomatic purposes.\n- The White House says loss of control over these revenues would weaken efforts to bring peace, prosperity, and stability to Venezuela and the Western Hemisphere.\n- The fact sheet states: President Trump authorized lethal force against narcoterrorists to stop the flow of deadly drugs into this country.\n- It states: President Trump ordered a total and complete blockade of all sanctioned oil tankers going in and out of Venezuela.\n- It states: President Trump offered multiple off ramps to Maduro and his illegitimate regime, but he was clear that the drug trafficking must stop.\n- It states: Last week, U.S. armed forces conducted an extraordinary military operation in support of law enforcement to bring outlaw dictator Maduro to justice.\n- It states that the President's actions reestablish deterrence in the Western hemisphere and that safeguarding these oil revenues promotes stability in Venezuela while advancing U.S. objectives."},{"evidence_id":"ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47","label":"PX-3 PBS/AP timeline of escalation, strikes, and Maduro capture","phase":"arguments","role":"defendant","text":"Source: PBS NewsHour / Associated Press, A timeline of U.S. military escalation against Venezuela leading to Maduro's capture. By Ben Finley, Konstantin Toropin, Regina Garcia Cano. Date on page: Jan. 3, 2026 1:54 PM EDT. URL: https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture\n\nExtracted relevant page text:\n- AP reported that Trump had threatened military strikes on targets on Venezuelan territory after months of attacks on boats accused of carrying drugs from Venezuela; Maduro said U.S. military operations were a thinly veiled effort to oust him.\n- On Jan. 3 the U.S. conducted a large-scale strike against Venezuela. Maduro and Cilia Flores were taken from their home on a military base and were aboard a U.S. warship on their way to New York to face criminal charges.\n- Before the escalation, there had been 35 known strikes against alleged drug-smuggling boats in South American waters since early September, killing at least 115 people according to administration announcements.\n- The U.S. sent a fleet of warships to the region, the largest buildup of forces in generations; the naval force grew to include guided-missile destroyers, three amphibious assault ships and other vessels, about 6,000 sailors and Marines, aircraft, F-35 fighter jets in Puerto Rico, and a Navy submarine carrying cruise missiles off South America.\n- On Oct. 15, Trump confirmed he had authorized the CIA to conduct covert operations inside Venezuela and was weighing land operations in the country.\n- On Dec. 29/30, a drone strike at a docking area believed used by Venezuelan drug cartels was reported as the first known direct operation on Venezuelan soil since the strikes began.\n- On Jan. 3, AP reported that the U.S. conducted a large-scale strike across Caracas, captured Maduro and Flores, and flew them out of the country.\n- The related PBS page links included a watch item titled: Trump says U.S. is going to run Venezuela until transition of power after capturing Maduro."},{"evidence_id":"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf","label":"PX-5 Chatham House adverse analysis of sovereignty violation and transition-control claim","phase":"arguments","role":"defendant","text":"Source: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\n\nExtracted relevant page text:\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela."},{"evidence_id":"ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79","label":"DX-1 Department of War article on capture/extraction mission and transition language","phase":"surrebuttals","role":"defendant","text":"Source: U.S. Department of War / Pentagon News, Trump Announces U.S. Military's Capture of Maduro. Date on page: Jan. 3, 2026. URL: https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/\n\nExtracted relevant page text:\n- President Donald J. Trump announced the capture of Venezuelan leader Nicolas Maduro after a successful overnight joint U.S. military extraction in Caracas, Venezuela.\n- The article identifies the matter as Operation Absolute Resolve in Caracas.\n- Trump said U.S. armed forces conducted an extraordinary military operation in the capital of Venezuela against a heavily fortified military fortress in the heart of Caracas to bring Maduro to justice.\n- The article states Maduro and Cilia Flores de Maduro would face criminal court proceedings tied to a 2020 U.S. Department of Justice indictment on charges including narco-terrorism and drug trafficking.\n- The article says Operation Absolute Resolve was a joint military and law-enforcement mission to capture the Maduros, resulting from months of planning and rehearsal involving U.S. joint forces, special operations forces, and intelligence agencies.\n- Gen. Dan Caine described integrating complex air, ground, space, and maritime operations.\n- The article states the mission to extract the Maduros had no U.S. casualties and involved more than 150 military aircraft providing cover for the ground-based extraction force in Caracas.\n- Secretary Hegseth called it a massive joint military and law-enforcement raid, and said the mission concerned safety, security, freedom, and prosperity of the American people.\n- The article also reports adverse transition language: with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition to a legitimate replacement could be identified; Trump said Marco Rubio was working directly with Delcy Rodriguez and that she was willing to do what the United States thought necessary.\n- The article frames preceding tensions around September 2025 targeted boat strikes, November 2025 designation of Cartel de los Soles as a terror organization, and options to address a narco-terror threat in the region."},{"evidence_id":"ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9","label":"DX-2 Lead IG Southern Spear counter-narcotics mission extract","phase":"surrebuttals","role":"defendant","text":"Source: Lead Inspector General report to Congress, Operation Southern Spear, January 1, 2026-March 31, 2026. PDF URL: https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF\n\nExtracted relevant text:\n- The Lead IG report states that in November 2025 the Department of War initiated Operation Southern Spear as the U.S. mission to disrupt the flow of narcotics from designated terrorist organizations and transnational criminal organizations in the Western Hemisphere.\n- The report covers January 1 through March 31, 2026 and presents oversight work by the Department of War OIG, State OIG, and partner oversight agencies.\n- The report summary states Operation Southern Spear is the Department of War operation to disrupt the flow of narcotics in the Western Hemisphere from drug cartels designated by the President as terrorist organizations.\n- The report states OSS primarily involves lethal airstrikes against small boats suspected of shipping illegal narcotics in the Caribbean Sea and eastern Pacific Ocean.\n- It states that from September 2025 through March 2026, the U.S. military struck at least 45 small boats, resulting in 156 individuals killed or presumed dead.\n- It states the Department of War began moving significant Navy and Marine Corps assets into the USSOUTHCOM area of operations in August 2025 to support OSS.\n- It states Joint Interagency Task Force-South is the U.S. Government's interagency effort to detect, monitor, and target illicit drug trafficking in the air and at sea with the support of 19 partner nations.\n- It states U.S. forces interdicted at least 10 sanctioned tankers around the world since OSS began, including some tracked as far as the Indian Ocean.\n- It states the OSS mission statement is classified.\n\nLimitations: this extracted text does not decide Operation Absolute Resolve's territorial-control intent; it is offered to show the official oversight framing of the broader campaign and the classified-source gap."},{"evidence_id":"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4","label":"PX-2 Rubio ground-presence and no-invasion/no-occupation statements","phase":"surrebuttals","role":"defendant","text":"Source: The White House, RUBIO: This Is Our Hemisphere -- and President Trump Will Not Allow Our Security to be Threatened. Date on page: January 4, 2026. URL: https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/\n\nExtracted relevant page text:\n- The release says Secretary of State Marco Rubio discussed the administration's operation that apprehended Nicolás Maduro.\n- Rubio stated: There is not a war against Venezuela; the U.S. is at war against drug trafficking organizations.\n- Rubio stated that the U.S. did not have forces on the ground in Venezuela at the time of the interviews, but they were on the ground for about two hours when they went to capture Maduro.\n- Rubio stated that the first steps are securing what is in the national interest of the United States and beneficial to the people of Venezuela, including no more drug trafficking, no more Iran/Hezbollah presence, and no more use of the oil industry to enrich U.S. adversaries.\n- Rubio stated this was not an action requiring congressional approval because it was not an invasion and not an extended military operation.\n- Rubio stated the United States wants Venezuela to move in a certain direction because it is good for Venezuela and in the U.S. national interest.\n- Rubio stated: We retain all the options we had before this raid and this capture and this arrest until such time as changes are made.\n- Rubio stated Venezuela would continue to face an oil quarantine, U.S. pressure, targeting of drug boats, seizure of sanctioned boats with court orders, and potentially other things until the issues the United States wants addressed are addressed.\n- Rubio stated Maduro was not the head of state and was an illegitimate president."},{"evidence_id":"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf","label":"PX-5 Chatham House adverse transition-control analysis","phase":"surrebuttals","role":"defendant","text":"Source: Chatham House, The US capture of President Nicolás Maduro - and attacks on Venezuela - have no justification in international law. Author on page: Marc Weller, Director, Global Governance and Security Centre, International Law Programme, Chatham House. Published Jan. 4, 2026; updated Jan. 6, 2026. URL: https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification\n\nExtracted relevant page text:\n- The page states that the capture of Venezuelan President Nicolás Maduro and his wife by U.S. forces operating in Venezuela, and his forced transfer to the U.S. for trial, poses a significant challenge for international law.\n- It states the United States described the operation as a judicial extraction mission undertaken by law enforcement operatives supported by the military.\n- Chatham House states that this was a military operation of considerable scale involving strikes on military targets in and around Caracas, the capital, and the forcible abduction of a sitting president by U.S. special forces.\n- It calls the operation a significant violation of Venezuelan sovereignty and the UN Charter.\n- It states this is compounded by President Trump's Jan. 3 press-conference announcement that the United States will run Venezuela and administer a political transition or regime change under threat of further, more massive uses of force.\n- It also states there seems to be a determination to use the threat of force to extract funds and resources in compensation for supposed stolen or nationalized U.S. assets and oil.\n- It states there is no UN Security Council mandate authorizing force and that this was not U.S. self-defense triggered by a prior or ongoing armed attack by Venezuela."}],"openings":[{"phase":"openings","role":"plaintiff","text":"Council members, the proposition is not asking whether the United States used harsh rhetoric toward Venezuela, or whether a short raid can be called an invasion in ordinary speech. It asks a narrower factual question: during the window from November 3, 2025 through January 31, 2026, did the United States commence a military offensive intended to establish control over any portion of Venezuelan territory?\n\nThe current record is empty. No case-packet evidence, source documents, exhibits, or submitted evidence are yet before you. For that reason, this opening is a roadmap, not a request to decide on assertions unsupported by admitted proof. The plaintiff’s burden is preponderance of the evidence, and the decisive proof will need to come from credible-source consensus, preferably including official U.S. statements, contemporaneous news reporting, and independent expert analysis.\n\nOur theory is that this was an invasion under the proposition’s definition because the expected evidence will show an integrated U.S. military campaign, not an isolated arrest. The relevant facts will likely include the sequence of military buildup, maritime interdiction or blockade, strikes on or against Venezuelan territory, armed entry into Caracas or other Venezuelan sites, seizure and removal of the sitting effective ruler, temporary U.S. control over the places and routes needed to carry out that seizure, and follow-on statements or acts showing an intent to dictate Venezuela’s political transition or control Venezuelan resources. If that proof is admitted, it satisfies the proposition even if the United States did not permanently annex land or maintain a long occupation. The proposition requires an offensive intended to establish control over any portion of territory; temporary military control of a target area, base, airspace, port, route, or government seat can be enough if credible sources show it was part of the intended operation.\n\nThe defense’s best answer is predictable and important: it will say the United States conducted a brief law-enforcement or counter-narcotics operation, that any ground presence lasted only long enough to capture a criminal defendant, and that there was no intent to hold Venezuelan territory. That is the real dispute. A mere strike, a naval seizure outside Venezuela, or a short exfiltration with no intended territorial control would not, standing alone, meet the proposition. Nor would generalized political pressure or sanctions. The council should therefore focus on evidence of planned control: operational objectives, official descriptions of the forces and targets, whether U.S. forces controlled Venezuelan land or facilities even temporarily, whether the operation displaced Venezuela’s effective government, and whether U.S. officials claimed authority to administer the aftermath.\n\nThe plaintiff will seek to build the record with primary and near-primary sources: official White House, State, Defense, and Justice materials; transcripts of relevant press briefings and interviews; contemporaneous wire-service reporting; and independent legal or foreign-policy analysis that addresses the same facts. We will also test adverse material, especially any official claim that this was not an invasion and not an occupation. Those claims matter, but they are not conclusive if the underlying conduct and intent show a military offensive to establish control over Venezuelan territory.\n\nAt the end of the case, the question should be answered by the weight of credible sources, not labels. If the admitted record shows only a narrow arrest operation without territorial-control intent, plaintiff should lose. But if the admitted record shows that the United States used military force inside Venezuela as part of a planned campaign to seize control of places, routes, institutions, or resources necessary to impose a political outcome, then the proposition is more likely than not true."},{"phase":"openings","role":"defendant","text":"Council members, the proposition is not whether the United States used force against Venezuela, whether officials used aggressive rhetoric, whether Congress debated war-powers limits, or whether an operation was lawful under domestic or international law. The proposition asks a narrower factual question: did the United States commence a military offensive, during the defined window, intended to establish control over any portion of Venezuelan territory?\n\nThe answer cannot be supplied by labels. “Hostilities,” “intervention,” “aggression,” “raid,” “capture,” “extraction,” and “regime pressure” may all matter as evidence leads, but none is the element the council must find. The plaintiff must prove by a preponderance, through a consensus of credible sources, both military action and the specific intent to establish territorial control. If the eventual record shows only strikes, maritime interdictions, sanctions enforcement, a law-enforcement capture operation, temporary tactical presence for entry and exit, or political pressure on Venezuela’s leadership, plaintiff has not met the proposition as written.\n\nThe current record contains no admitted evidence at all. There are no case-packet files, no exhibits, and no submitted source materials. The plaintiff’s opening properly recognizes that a mere strike or short exfiltration without intended territorial control would not be enough. That concession identifies the real dispute. The defense will hold plaintiff to it.\n\nOur theory is that the decisive proof, if admitted, will show a counter-narcotics, interdiction, and extraction frame rather than an offensive to take and hold Venezuelan territory. The defense will not ask the council to ignore adverse evidence. If plaintiff later admits credible primary materials showing that U.S. forces set out to control ports, airfields, ministries, bases, roads, oil fields, neighborhoods, or other Venezuelan land as an object of the operation, that would be serious evidence for plaintiff. So would proof that the United States administered territory, installed a military authority over a place, maintained checkpoints for territorial governance, or claimed a continuing right to control Venezuelan facilities or resources.\n\nBut that is exactly the proof the plaintiff must produce. A military force can briefly control a doorway, route, landing zone, compound, airspace, or vessel as an incident of an arrest, strike, rescue, evacuation, or interdiction without intending to establish control over Venezuelan territory in the sense required by this proposition. Likewise, a government can seek a leader’s prosecution, weaken a hostile regime, interdict trafficking, or apply coercive pressure without crossing this proposition’s territorial-control line. The council should separate those categories carefully.\n\nThe coming evidence should therefore be tested around five questions. First, what was the actual operational objective, as shown by primary official materials, contemporaneous reporting, and reliable expert analysis? Second, what physical presence occurred inside land deemed Venezuelan territory as of September 6, 2025, and how long did it last? Third, did U.S. forces exercise control merely to complete a mission and leave, or did they seek to possess, administer, or deny Venezuela control of a place? Fourth, what did the United States do after the operation: withdraw, transfer custody, or govern territory? Fifth, do credible sources converge on territorial-control intent, or only on force, illegality, hostilities, or political consequences?\n\nProvenance will matter. Official statements may understate conflict; hostile governments may overstate occupation; secondary commentary may collapse legal “aggression” into the different factual standard here. The most valuable evidence will be original government documents, full transcripts, congressional materials, after-action or oversight reports, and contemporaneous reporting that distinguishes what happened from what advocates called it.\n\nAt the close of this case, if the record shows the United States began an offensive meant to establish control over Venezuelan territory, the plaintiff should prevail. But if the record shows military force, even serious and controversial force, without that intended territorial-control objective, the proposition fails. On the present empty record, and under the plaintiff’s burden, the defense position is that the council should require that missing link before finding an invasion."}],"prior_council_votes":[],"rebuttals":[{"phase":"rebuttals","role":"plaintiff","text":"Council members, defendant’s argument narrows the proposition too far. It concedes the record proves a serious U.S. military operation in and against Venezuela: strikes, buildup, a Caracas raid, two-hour ground presence, capture/removal of Maduro and Flores, oil/tanker pressure, and political leverage. The remaining question is whether the object included control over any portion of Venezuela.\n\nDefendant says plaintiff’s theory would make any brief commando raid an invasion. But this record is not about a doorway or landing zone. Defendant’s own DX-1 describes Operation Absolute Resolve as a U.S. military operation in Caracas against a heavily fortified military fortress in the heart of Venezuela’s capital. It followed months of planning by joint forces, special operations forces, and intelligence agencies. Gen. Caine described complex air, ground, space, and maritime operations. More than 150 military aircraft covered the ground extraction force. Hegseth called it a massive joint military and law-enforcement raid.\n\nThose facts satisfy “any portion.” A planned armed domination of a fortified military site in Caracas, covered by 150 aircraft and integrated domains, is control over a portion of Venezuelan territory. It need not be permanent. The mission could not succeed unless U.S. forces intended to deny Venezuelan control over that site and surrounding operational environment long enough to seize and remove the effective ruler.\n\nDefendant also separates regime-change pressure from territorial control. DX-1 defeats that separation. It reports that with Maduro out of power, Trump said the United States would oversee Venezuela until a safe transition could be identified; Rubio was working directly with Delcy Rodriguez; and Rodriguez was willing to do what the United States thought necessary. PX-5 independently captures that as U.S. administration of a transition under threat of more force. That is not merely prosecution in New York.\n\nDX-2 does not rescue the defense. It frames Southern Spear as counter-narcotics and boat interdiction, but also admits major Navy/Marine deployments, lethal strikes, tanker interdictions, and a classified mission statement. It does not negate the specific intent of Operation Absolute Resolve in Caracas.\n\nThe defense imports an occupation requirement the proposition does not contain. The question is whether the United States commenced a military offensive intended to establish control over any portion of Venezuela, not whether it held checkpoints for weeks or annexed land. Rubio’s “not an invasion” label deserves consideration, but labels cannot outweigh the record facts: military force inside Venezuela, control of the necessary Caracas target area, removal of Maduro, and asserted authority to shape Venezuela’s transition and resources. That is enough under the actual proposition."}],"submitted_evidence":[{"evidence_id":"ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a","mime_type":"text/plain","phase":"arguments","relevance":"Official U.S. source admitting oil-revenue custody, blockade, lethal-force authorization, and an armed forces operation against Maduro within the case window.","retrieval_timestamp":"2026-06-30T00:20:00Z","role":"plaintiff","sha256":"0c5c88687b2a889093788193bdd900106b95ff6ccfab1af50709f67df61cb673","size_bytes":1819,"source_description":"White House fact sheet page, extracted via web.open on 2026-06-30.","source_url":"https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/","title":"PX-1 White House fact sheet on Venezuelan oil revenue and U.S. operation"},{"evidence_id":"ev_6627f15cd3a4_submitted-evidence-02-plaintiff-6627f15cd3a4","mime_type":"text/plain","phase":"arguments","relevance":"Official U.S. statements acknowledging two-hour U.S. ground presence in Venezuela, oil quarantine/pressure, retained options, and the adverse claim that the action was not an invasion.","retrieval_timestamp":"2026-06-30T00:20:30Z","role":"plaintiff","sha256":"6627f15cd3a42cc9018d2ab70f1951aa4f1687bd18848c031287516048d42d80","size_bytes":1793,"source_description":"White House release page, extracted via web.open on 2026-06-30.","source_url":"https://www.whitehouse.gov/releases/2026/01/rubio-this-is-our-hemisphere-and-president-trump-will-not-allow-our-security-to-be-threatened/","title":"PX-2 White House release collecting Secretary Rubio statements"},{"evidence_id":"ev_2efdab998e47_submitted-evidence-03-plaintiff-2efdab998e47","mime_type":"text/plain","phase":"arguments","relevance":"Contemporaneous credible reporting on the U.S. buildup, strikes, first known operation on Venezuelan soil, Jan. 3 large-scale strike across Caracas, capture/removal of Maduro and Flores, and related military posture.","retrieval_timestamp":"2026-06-30T00:21:00Z","role":"plaintiff","sha256":"2efdab998e47ae16cff6d6becb03e7e9216bee4b668814addd1ef89d84c57ec8","size_bytes":2038,"source_description":"PBS NewsHour page carrying Associated Press timeline by Ben Finley, Konstantin Toropin, and Regina Garcia Cano; extracted via web.open/find on 2026-06-30.","source_url":"https://www.pbs.org/newshour/world/a-timeline-of-u-s-military-escalation-against-venezuela-leading-to-maduros-capture","title":"PX-3 PBS/AP timeline of U.S. escalation and Maduro capture"},{"evidence_id":"ev_52e4d5a16b2f_submitted-evidence-04-plaintiff-52e4d5a16b2f","mime_type":"text/plain","phase":"arguments","relevance":"Independent expert analysis confirming a Jan. 3 U.S. special operation in Caracas and preserving the adverse official claim that it was not an invasion or occupation.","retrieval_timestamp":"2026-06-30T00:21:30Z","role":"plaintiff","sha256":"52e4d5a16b2f936b7515e76a65ecfde48c040e48b94b144702fbe1e32123f0c3","size_bytes":1680,"source_description":"Brookings Institution analysis page, extracted via web.open on 2026-06-30.","source_url":"https://www.brookings.edu/articles/making-sense-of-the-us-military-operation-in-venezuela/","title":"PX-4 Brookings analysis of Jan. 3 Maduro operation and legal limit"},{"evidence_id":"ev_94e861ebadbf_submitted-evidence-05-plaintiff-94e861ebadbf","mime_type":"text/plain","phase":"arguments","relevance":"Independent international-law analysis characterizing the operation as U.S. forces operating in Venezuela, strikes around Caracas, special-forces abduction, and a U.S. announcement to run/administer a transition under threat of force.","retrieval_timestamp":"2026-06-30T00:22:00Z","role":"plaintiff","sha256":"94e861ebadbf2849cd4257d954fcd51afc5f6a8d01c7b5f2df165cc6d4180151","size_bytes":1755,"source_description":"Chatham House expert comment by Marc Weller, extracted via web.open/find on 2026-06-30.","source_url":"https://www.chathamhouse.org/2026/01/us-capture-president-nicolas-maduro-and-attacks-venezuela-have-no-justification","title":"PX-5 Chatham House analysis of U.S. capture, strikes, and transition control"},{"evidence_id":"ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79","mime_type":"text/plain","phase":"arguments","relevance":"Official source on Operation Absolute Resolve showing both adverse facts (Caracas operation and transition comments) and defense facts (capture/extraction, criminal proceedings, joint military/law-enforcement mission, no U.S. casualties, anti-narcoterrorism context).","retrieval_timestamp":"2026-06-30T00:29:30Z","role":"defendant","sha256":"26011b5f6d792bc39d1eabe168123482dcc270e34745035055127683c27c55e1","size_bytes":2203,"source_description":"Department of War/Pentagon News article by Matthew Olay, opened via web.open on 2026-06-30.","source_url":"https://www.war.gov/News/News-Stories/Article/Article/4370431/trump-announces-us-militarys-capture-of-maduro/","title":"DX-1 Department of War article on Maduro capture as joint law-enforcement mission"},{"evidence_id":"ev_53782f10ceb9_submitted-evidence-07-defendant-53782f10ceb9","mime_type":"text/plain","phase":"arguments","relevance":"Official oversight source characterizing Operation Southern Spear as a mission to disrupt narcotics flows, with boat strikes, deployments, and interdictions, supporting defense that the broader campaign was counter-narcotics rather than territorial occupation.","retrieval_timestamp":"2026-06-30T00:18:00Z","role":"defendant","sha256":"53782f10ceb9c41feb405f741ad20b53fef01f5306f2442df751c9f7a09e5345","size_bytes":1989,"source_description":"Lead Inspector General report to Congress on Operation Southern Spear, January 1-March 31 2026, opened via web.open PDF extraction on 2026-06-30.","source_url":"https://media.defense.gov/2026/May/21/2003935694/-1/-1/1/OSS_Q2_MAR2026_FINAL_508.PDF","title":"DX-2 Lead IG Operation Southern Spear report extract on counter-narcotics mission"}],"surrebuttals":[{"phase":"surrebuttals","role":"defendant","text":"Council members, plaintiff’s rebuttal usefully narrows the dispute to two points: the Caracas site and the transition language. Neither carries plaintiff’s burden.\n\nFirst, plaintiff says the fortified military site in Caracas satisfies “any portion” because U.S. forces necessarily denied Venezuelan control long enough to seize and remove Maduro. That proves tactical control; it does not prove that the United States commenced an offensive intended to establish territorial control. Those are different things. A raid, arrest, rescue, or extraction at a defended facility always requires temporary domination of the target area. If that alone satisfies the proposition, the phrase “intended to establish control” does no work, and every cross-border commando raid becomes an invasion under this standard.\n\nThe record does not show the Caracas site was an object to be held, administered, possessed, governed, or transferred as territory. DX-1 describes a ground-based extraction force, a capture, criminal proceedings, and a joint military/law-enforcement mission. It is adverse because the operation was large and military; it is still not proof that the United States intended to establish control over Venezuelan land rather than control the scene long enough to extract two people.\n\nSecond, plaintiff relies on “oversee Venezuela” and PX-5’s transition-control wording. That is the strongest contrary evidence, but it remains ambiguous. Political leverage over a successor government is not the same as territorial control. DX-1 says Delcy Rodriguez was sworn in and was willing to work with the United States. That is not the United States installing a military government over a place, holding facilities, drawing boundaries, manning checkpoints, or leaving forces in control after the raid.\n\nPlaintiff says the defense imports an occupation requirement. No. The defense accepts that the proposition does not require annexation or a long occupation. But it does require an intent to establish control over territory. A short duration can qualify if the object is control of the place. Here the record shows a short duration whose object was capture and extraction. The admitted sources show force, pressure, and influence; they do not show a territorial-control objective.\n\nDX-2 still matters for that reason. Plaintiff says it does not negate Operation Absolute Resolve. True, it does not decide the whole case. But it is an official oversight account of the broader campaign as counter-narcotics, interdiction, and strikes, with the mission statement classified. Plaintiff has not filled that classified gap with an operational order, full transcript, or post-operation facts showing that the Caracas raid changed into a territorial-control campaign.\n\nThe council can condemn the operation as unlawful, coercive, or interventionist and still find the proposition not proved. The question is not whether the United States used overwhelming force inside Venezuela. It did. The question is whether credible sources show, more likely than not, that the United States intended to establish control over Venezuelan territory. The record remains at most equivocal on that decisive element, so plaintiff has not carried the burden."}],"technical_reports":[{"phase":"arguments","role":"plaintiff","summary":"Before filing, plaintiff checked the record and found no case-packet evidence. Plaintiff submitted five text-readable source captures. Official White House materials are strong provenance for U.S. admissions but self-serving on labels; AP/PBS provides contemporaneous reporting; Brookings and Chatham House provide independent expert analysis, including adverse framing. Missing but potentially useful later sources include DOD after-action or press briefing text, a direct video/transcript of President Trump's transition-control statement, and fuller mapping of exact ground-control sites.","title":"Plaintiff Source and Weight Ledger"},{"phase":"arguments","role":"defendant","summary":"Defendant inspected the record with get_case/list_evidence and read all five plaintiff text exhibits with read_evidence_range. Defendant submitted and read back two official defense exhibits: Department of War/Pentagon News on Operation Absolute Resolve and the Lead IG Operation Southern Spear report extract. Additional searches found DOJ and War/State leads but they were not submitted because the admitted official record already captured the key law-enforcement/counter-narcotics framing. Weight assessment: PX-2, DX-1, and DX-2 are official and strong for source identity; PX-5 is credible expert commentary but not a primary operational order or full transcript. Unresolved gaps include the full Trump transition-control video/transcript, full State transcript, and post-operation facts about who actually governed territory.","title":"Defense Source and Weight Ledger"},{"phase":"surrebuttals","role":"defendant","summary":"Defendant inspected get_case and list_evidence before filing. Plaintiff rebuttal added no new evidence; it relied on existing DX-1, DX-2, and PX-5. Prior exact reads of those text exhibits remain controlling. No new external source was submitted because the rebuttal turned on interpretation of the existing record, not a new factual source.","title":"Surrebuttal Evidence Check"}]}}},"turn":{"attempts_max":3,"attempts_remaining":3,"completed":false,"deadline":"2026-06-30T00:48:10.359530297Z","deliberation_round":1,"member_id":"C2","opportunity_id":"deliberation:1:C2","phase":"deliberation","remaining_ms":881479,"role_id":"council","turn_number":10}},"isError":false},"server":"aar","tool":"get_case"},"isError":false,"timestamp":1782779608885},{"role":"assistant","content":[{"type":"text","text":"Now let me list all the admitted evidence to examine the full picture:"},{"type":"toolCall","id":"dtjHWna3P","name":"mcp","arguments":{"tool":"aar_list_evidence","args":"{}"}}],"api":"openai-completions","provider":"openrouter","model":"mistralai/mistral-medium-3-5","usage":{"input":20908,"output":35,"cacheRead":19344,"cacheWrite":0,"totalTokens":40287,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1782779608889,"responseId":"gen-1782779609-bgLwHQeNxMIBuB1LnbJc","responseModel":"mistralai/mistral-medium-3.5-20260430"},{"role":"toolResult","toolCallId":"dtjHWna3P","toolName":"mcp","content":[{"type":"text","text":"ok: true\nmember_id: C2\ncase_id: arb-ex05-20260630001330\nphase: deliberation\nopportunity_id: deliberation:1:C2\nremaining_ms: 877700\nattempts_remaining: 3\njson: {\"case_id\":\"arb-ex05-20260630001330\",\"member_id\":\"C2\",\"ok\":true,\"result\":{\"evidence\":[{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:20:59Z\",\"evidence_id\":\"ev_0c5c88687b2a_submitted-evidence-01-plaintiff-0c5c88687b2a\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-01-plaintiff-0c5c88687b2a.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Official U.S. source admitting oil-revenue custody, blockade, lethal-force authorization, and an armed forces operation against Maduro within the case window.\",\"retrieval_timestamp\":\"2026-06-30T00:20:00Z\",\"sha256\":\"0c5c88687b2a889093788193bdd900106b95ff6ccfab1af50709f67df61cb673\",\"size_bytes\":1819,\"source_description\":\"White House fact sheet page, extracted via web.open on 2026-06-30.\",\"source_url\":\"https://www.whitehouse.gov/fact-sheets/2026/01/fact-sheet-president-donald-j-trump-safeguards-venezuelan-oil-revenue-for-the-good-of-the-american-and-venezuelan-people/\",\"storage_name\":\"0c/0c5c88687b2a889093788193bdd900106b95ff6ccfab1af50709f67df61cb673\",\"submitted_by_role\":\"plaintiff\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"PX-1 White House fact sheet on Venezuelan oil revenue and U.S. operation\"},{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-30T00:24:59Z\",\"evidence_id\":\"ev_26011b5f6d79_submitted-evidence-06-defendant-26011b5f6d79\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-06-defendant-26011b5f6d79.txt\",\"record_visibility\":\"juror_visibl