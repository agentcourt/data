erms.txt\"},{\"admissibility_status\":\"submitted_evidence\",\"created_at\":\"2026-06-29T21:53:35Z\",\"evidence_id\":\"ev_db357d4e9407_submitted-evidence-01-plaintiff-db357d4e9407\",\"mime_type\":\"text/plain\",\"original_name\":\"submitted-evidence-01-plaintiff-db357d4e9407.txt\",\"record_visibility\":\"juror_visible\",\"relevance\":\"Establishes that the White House officially published a video page titled President Trump Attends the FIFA World Cup Drawing, dated December 5, 2025, with a full-video link and related World Cup Draw videos; relevant to source chain and event context.\",\"retrieval_timestamp\":\"2026-06-29T21:52:12Z\",\"sha256\":\"db357d4e940728d417ae4f7f3caac6b78d3fd3e4aba70d46fe10c6132d45997a\",\"size_bytes\":1300,\"source_description\":\"Official White House video page; retrieved by web open/fetch during plaintiff merits investigation\",\"source_url\":\"https://www.whitehouse.gov/videos/president-trump-attends-the-fifa-world-cup-drawing/\",\"storage_name\":\"db/db357d4e940728d417ae4f7f3caac6b78d3fd3e4aba70d46fe10c6132d45997a\",\"submitted_by_role\":\"plaintiff\",\"submitted_phase\":\"arguments\",\"text_readable\":true,\"title\":\"Official White House video page capture: President Trump Attends the FIFA World Cup Drawing\"}]},\"turn\":{\"attempts_max\":3,\"attempts_remaining\":3,\"completed\":false,\"deadline\":\"2026-06-29T22:18:45.386037689Z\",\"deliberation_round\":1,\"member_id\":\"C2\",\"opportunity_id\":\"deliberation:1:C2\",\"phase\":\"deliberation\",\"remaining_ms\":884322,\"role_id\":\"council\",\"turn_number\":10}}"}],"details":{"mode":"call","mcpResult":{"content":[{"type":"text","text":"ok: true\nmember_id: C2\ncase_id: arb-ex03a-20260629214245\nphase: deliberation\nopportunity_id: deliberation:1:C2\nremaining_ms: 884322\nattempts_remaining: 3\njson: {\"case_id\":\"arb-ex03a-20260629214245\",\"member_id\":\"C2\",\"ok\":true,\"result\":{\"evidence\":[{\"admissibility_status\":\"case_packet\",\"created_at\":\"2026-06-29T21:42:53Z\",\"evide