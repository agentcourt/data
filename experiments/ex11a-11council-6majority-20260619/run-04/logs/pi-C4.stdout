d-evidence-03-plaintiff-a6be31686c80.txt","record_visibility":"juror_visible","relevance":"Credible reporting corroborating the NOTAM, CAA attribution, affected airports including listed market airports, operational limits, timing, and non-weather/security context.","retrieval_timestamp":"2026-06-19T23:59:40Z","sha256":"a6be31686c80176d9d7195f76281647eb9a9d9b39b77a59b0b8e3d3ddbf8afa6","size_bytes":1759,"source_description":"Indian Express article captured in argument phase; reports Iranian CAA NOTAM OIIX A1010/26, operational airports, daylight restrictions, fresh approval requirement, and security/diplomatic context.","source_url":"https://indianexpress.com/article/world/us-news/iran-closes-airspace-trump-cancels-plans-us-military-strikes-rubio-india-10704692/","storage_name":"a6/a6be31686c80176d9d7195f76281647eb9a9d9b39b77a59b0b8e3d3ddbf8afa6","submitted_by_role":"plaintiff","submitted_phase":"arguments","text_readable":true,"title":"Indian Express May 23 report on Iran western airspace closure"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-19T23:59:33Z","evidence_id":"ev_a95b8d7e6e97_submitted-evidence-01-plaintiff-a95b8d7e6e97","mime_type":"text/plain","original_name":"submitted-evidence-01-plaintiff-a95b8d7e6e97.txt","record_visibility":"juror_visible","relevance":"Primary-like NOTAM text for Iran/Tehran FIR airport closure effective May 22-May 25, 2026; proves scope, timing, exceptions, CAA permission requirement, and non-weather aviation restriction source chain.","retrieval_timestamp":"2026-06-19T23:59:00Z","sha256":"a95b8d7e6e97fa3e3ce64d2dbd0386a2e9cd33cc24d601a9d0a01f396d661025","size_bytes":1286,"source_description":"Notamify OIIX NOTAM page captured in argument phase; page text includes interpretation and raw NOTAM A1010/26.","source_url":"https://notamify.com/notams/OIIX/693f2d0f-54d3-433b-8128-49f5475ba269","storage_name":"a9/a95b8d7e6e97fa3e3ce64d2dbd0386a2e9cd33cc24d601a9d0a01f396d661025","submitted_by_role":"plaintiff","submit