":884774,\"role_id\":\"council\",\"turn_number\":11}}"}],"structuredContent":{"case_id":"arb-ex11a-20260619230546","member_id":"C3","ok":true,"result":{"evidence":{"admissibility_status":"submitted_evidence","created_at":"2026-06-19T23:17:18Z","evidence_id":"ev_71e31604802f_submitted-evidence-04-defendant-71e31604802f","mime_type":"text/plain","original_name":"submitted-evidence-04-defendant-71e31604802f.txt","record_visibility":"juror_visible","relevance":"Provides a raw NOTAM display indicating the restriction was framed as airport operations: all airports in the west part of Tehran FIR closed except listed airports operating sunrise-to-sunset, with new CAA permission required for civil IFR passenger flights. This helps assess whether plaintiff proved a broad airspace closure versus airport-operation restrictions, and highlights continued lack of official NOTAM custody.","retrieval_timestamp":"2026-06-19T23:24:00Z","sha256":"71e31604802f299283d565fcfb26d01e5297bb5daa92e273621fe63a95b9a052","size_bytes":1492,"source_description":"Notamify OIIX NOTAM page captured through web search/open on 2026-06-19. Page displays an interpretation and raw NOTAM text for A1010/26. Submitted for exact wording/scope nuance and provenance limits; Notamify is an aggregator, not the Iranian issuing authority.","source_url":"https://notamify.com/notams/OIIX/693f2d0f-54d3-433b-8128-49f5475ba269","storage_name":"71/71e31604802f299283d565fcfb26d01e5297bb5daa92e273621fe63a95b9a052","submitted_by_role":"defendant","submitted_phase":"arguments","text_readable":true,"title":"Notamify display of OIIX A1010/26 raw NOTAM and interpretation"},"limits":{"max_read_bytes":65536,"max_read_bytes_per_opportunity":524288,"max_reads_per_opportunity":32,"remaining_read_bytes_for_opportunity":524288,"remaining_reads_for_opportunity":32}},"turn":{"attempts_max":3,"attempts_remaining":3,"completed":false,"deadline":"2026-06-19T23:38:50.99098259Z","deliberation_round":1,"member_id":"C3","opportunity_id":"delib