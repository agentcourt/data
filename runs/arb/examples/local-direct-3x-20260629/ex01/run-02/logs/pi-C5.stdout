,\"source_description\":\"Initial case packet file\",\"storage_name\":\"64/6488cfe4679b7585aa73ff094a7a64f642ec2a10fcf85ad10c14e45aa54ca5cf\",\"submitted_by_role\":\"system\",\"submitted_phase\":\"case_packet\",\"text_readable\":true,\"title\":\"distribution-work-order.txt\"},{\"admissibility_status\":\"case_packet\",\"created_at\":\"2026-06-29T17:27:05Z\",\"evidence_id\":\"ev_77ec661ab33b_confession\",\"mime_type\":\"text/plain\",\"original_name\":\"confession.txt\",\"record_visibility\":\"juror_visible\",\"sha256\":\"77ec661ab33beb0fefe5bb74e263c812fbf9ea3c3d8f90175f54d4e209aeeccd\",\"size_bytes\":505,\"source_description\":\"Initial case packet file\",\"storage_name\":\"77/77ec661ab33beb0fefe5bb74e263c812fbf9ea3c3d8f90175f54d4e209aeeccd\",\"submitted_by_role\":\"system\",\"submitted_phase\":\"case_packet\",\"text_readable\":true,\"title\":\"confession.txt\"},{\"admissibility_status\":\"case_packet\",\"created_at\":\"2026-06-29T17:27:05Z\",\"evidence_id\":\"ev_839024ec3b20_damages-breakdown\",\"mime_type\":\"text/plain\",\"original_name\":\"damages-breakdown.txt\",\"record_visibility\":\"juror_visible\",\"sha256\":\"839024ec3b2028f7b3ec049a07e3b9c6af546b24dc4daf4a34d75b906d3ceefd\",\"size_bytes\":599,\"source_description\":\"Initial case packet file\",\"storage_name\":\"83/839024ec3b2028f7b3ec049a07e3b9c6af546b24dc4daf4a34d75b906d3ceefd\",\"submitted_by_role\":\"system\",\"submitted_phase\":\"case_packet\",\"text_readable\":true,\"title\":\"damages-breakdown.txt\"},{\"admissibility_status\":\"case_packet\",\"created_at\":\"2026-06-29T17:27:05Z\",\"evidence_id\":\"ev_9d3b588a9864_time-and-token-log\",\"mime_type\":\"text/plain\",\"original_name\":\"time-and-token-log.txt\",\"record_visibility\":\"juror_visible\",\"sha256\":\"9d3b588a98646926783ac8f0525a748f3c4a825127219eeceee23655aa4d3dc9\",\"size_bytes\":443,\"source_description\":\"Initial case packet file\",\"storage_name\":\"9d/9d3b588a98646926783ac8f0525a748f3c4a825127219eeceee23655aa4d3dc9\",\"submitted_by_ro