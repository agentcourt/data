ket\",\"created_at\":\"2026-06-29T17:27:05Z\",\"evidence_id\":\"ev_fbc123d72aa5_session-summary\",\"mime_type\":\"text/plain\",\"original_name\":\"session-summary.txt\",\"record_visibility\":\"juror_visible\",\"sha256\":\"fbc123d72aa57f7b8edc41b1ef82e05237d8979863d7714747c84efec7fa6612\",\"size_bytes\":1526,\"source_description\":\"Initial case packet file\",\"storage_name\":\"fb/fbc123d72aa57f7b8edc41b1ef82e05237d8979863d7714747c84efec7fa6612\",\"submitted_by_role\":\"system\",\"submitted_phase\":\"case_packet\",\"text_readable\":true,\"title\":\"session-summary.txt\"},{\"admissibility_status\":\"case_packet\",\"created_at\":\"2026-06-29T17:27:05Z\",\"evidence_id\":\"ev_fca019619f19_deadline-message-thread\",\"mime_type\":\"text/plain\",\"original_name\":\"deadline-message-thread.txt\",\"record_visibility\":\"juror_visible\",\"sha256\":\"fca019619f1962269f42c562a17290719189614f064b884a5988f5d66eafb6b2\",\"size_bytes\":820,\"source_description\":\"Initial case packet file\",\"storage_name\":\"fc/fca019619f1962269f42c562a17290719189614f064b884a5988f5d66eafb6b2\",\"submitted_by_role\":\"system\",\"submitted_phase\":\"case_packet\",\"text_readable\":true,\"title\":\"deadline-message-thread.txt\"}]},\"turn\":{\"attempts_max\":3,\"attempts_remaining\":3,\"completed\":false,\"deadline\":\"2026-06-29T18:08:13.051736777Z\",\"deliberation_round\":1,\"member_id\":\"C5\",\"opportunity_id\":\"deliberation:1:C5\",\"phase\":\"deliberation\",\"remaining_ms\":887163,\"role_id\":\"council\",\"turn_number\":13}}"}],"details":{"mode":"call","mcpResult":{"content":[{"type":"text","text":"ok: true\nmember_id: C5\ncase_id: arb-ex01-20260629172656\nphase: deliberation\nopportunity_id: deliberation:1:C5\nremaining_ms: 887163\nattempts_remaining: 3\njson: {\"case_id\":\"arb-ex01-20260629172656\",\"member_id\":\"C5\",\"ok\":true,\"result\":{\"evidence\":[{\"admissibility_status\":\"case_packet\",\"created_at\":\"2026-06-29T17:27:05Z\",\"evidence_id\":\"ev_54c33ae78e7d_printing-invoice\",\"mime_type\":\"text/plain\",\"original_name\":\"printing-invoice.txt\",\"record_visibility\":\"juror_visible\",\"sha256\":\"54c33ae78e7d5398b8c58d3792a2d987f9ab94afd504ef2c344fad953e950f18\",\"size_bytes\":429,\"source_description\":\"Initial case packet file\",\"storage_name\":\"54/54c33ae78e7d5398b8c58d3792a2d987f9ab94afd504ef2c344fad953e950f18\",\"submitted_by_role\":\"system\",\"submitted_phase\":\"case_packet\",\"text_readable\":true,\"title\":\"printing-invoice.txt\"},{\"admissibility_status\":\"case_packet\",\"created_at\":\"2026-06-29T17:27:05Z\",\"evidence_id\":\"ev_61a6c53e0d68_confession_sig\",\"mime_type\":\"text/plain\",\"original_name\":\"confession.sig.b64\",\"record_visibility\":\"juror_visible\",\"sha256\":\"61a6c53e0d685cced0fb1ac42880c79d641d188709216da92ce35985f7f2ddb5\",\"size_bytes\":345,\"source_description\":\"Initial case packet file\",\"storage_name\":\"61/61a6c53e0d685cced0fb1ac42880c79d641d188709216da92ce35985f7f2ddb5\",\"submitted_by_role\":\"system\",\"submitted_phase\":\"case_packet\",\"text_readable\":true,\"title\":\"confession.sig.b64\"},{\"admissibility_status\":\"case_packet\",\"created_at\":\"2026-06-29T17:27:05Z\",\"evidence_id\":\"ev_6488cfe4679b_distribution-work-order\",\"mime_type\":\"text/plain\",\"original_name\":\"distribution-work-order.txt\",\"record_visibility\":\"juror_visible\",\"sha256\":\"6488cfe4679b7585aa73ff094a7a64f642ec2a10fcf85ad10c14e45aa54ca5cf\",\"size_bytes\":550,\"source_description\":\"Initial case packet file\",\"storage_name\":\"64/6488cfe4679b7585aa73ff094a7a64f642ec2a10fcf85ad10c14e45aa54ca5cf\",\"submitted_by_role\":\"system\",\"submitted_phase\":\"case_packet\",\"text_readable\":true,\"title\":\"distribution-work-order.txt\"},{\"admissibility_status\":\"case_packet\",\"created_at\":\"2026-06-29T17:27:05Z\",\"evidence_id\":\"ev_77ec661ab33b_confession\",\"mime_type\":\"text/plain\",\"original_name\":\"confession.txt\",\"record_visibility\":\"juror_visible\",\"sha256\":\"77ec661ab33beb0fefe5bb74e263c81