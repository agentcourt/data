9f5475ba269 and https://notamify.com/notams/OIIX/67435351-52f9-4d17-8f4c-497a21dd94bf","storage_name":"24/241b442bed1566db9088fa4e9dd159b18a0afcafef11dc3cc63d5db9b4564b02","submitted_by_role":"defendant","submitted_phase":"arguments","text_readable":true,"title":"Notamify raw OIIX A1010/26 and A1015/26 NOTAM mirror"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-30T14:03:08Z","evidence_id":"ev_51569ad0cb54_submitted-evidence-04-plaintiff-51569ad0cb54","mime_type":"text/plain","original_name":"submitted-evidence-04-plaintiff-51569ad0cb54.txt","record_visibility":"juror_visible","relevance":"Official aviation authority context for non-weather security risk, affected Iranian airspace, and temporary airspace closures/restrictions by states during the conflict; corroborates that the relevant aviation disruptions were conflict/security related, not weather.","retrieval_timestamp":"2026-06-30T13:56:00Z","sha256":"51569ad0cb54f847f57c566a8aa45572ff0e4c29f8a8c22912b8a1b992b49ced","size_bytes":1592,"source_description":"Captured text from official EASA conflict zone information bulletin page opened during arbitration investigation.","source_url":"https://www.easa.europa.eu/en/domains/air-operations/czibs/2026-03-r13","storage_name":"51/51569ad0cb54f847f57c566a8aa45572ff0e4c29f8a8c22912b8a1b992b49ced","submitted_by_role":"plaintiff","submitted_phase":"arguments","text_readable":true,"title":"EASA CZIB 2026-03-R13 Middle East airspace bulletin"},{"admissibility_status":"submitted_evidence","created_at":"2026-06-30T14:02:57Z","evidence_id":"ev_57917ec86ba3_submitted-evidence-02-plaintiff-57917ec86ba3","mime_type":"text/plain","original_name":"submitted-evidence-02-plaintiff-57917ec86ba3.txt","record_visibility":"juror_visible","relevance":"Independent contemporaneous reporting that Iran's Civil Aviation Organization announced temporary restrictions over western airspace, severe passenger-flight restrictions, eight airports permitted, daylight-only operations