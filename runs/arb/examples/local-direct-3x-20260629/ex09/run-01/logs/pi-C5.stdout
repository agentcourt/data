"demonstrated","not_demonstrated"],"type":"string"}},"required":["vote","rationale"],"type":"object"},"name":"submit_council_vote","read_only":false}],"turn":{"attempts_max":3,"attempts_remaining":3,"completed":false,"deadline":"2026-06-30T07:06:08.640091694Z","deliberation_round":1,"member_id":"C5","opportunity_id":"deliberation:1:C5","phase":"deliberation","remaining_ms":890292,"role_id":"council","turn_number":13},"wait":{"reason":"ready","state_version":18,"version":29}},"isError":false},"server":"aar","tool":"wait_for_opportunity"},"isError":false,"timestamp":1782802278356}]}
