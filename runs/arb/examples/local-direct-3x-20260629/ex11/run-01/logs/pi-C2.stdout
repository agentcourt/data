"qwen/qwen3.5-plus-02-15","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"stop","timestamp":1782824186974,"responseId":"gen-1782824187-8ZuZwjSQsDN3AL5ygKjK","responseModel":"qwen/qwen3.5-plus-20260216"}}
